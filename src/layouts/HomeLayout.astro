---
import '../styles/global.css';
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- <script src="https://cdn.tailwindcss.com"></script> -->
  </head>

  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col antialiased">

    <!-- Header / Navbar -->
     <header class="bg-slate-900/80 backdrop-blur-md border-b border-slate-800/60 sticky top-0 z-50 w-full">
        <nav class="w-full px-5 sm:px-8 lg:px-12 py-3.5 flex items-center justify-between gap-6">
  
        <!-- Logo - izquierda -->
        <a href="/" class="flex items-center gap-2.5 text-2xl md:text-3xl font-black tracking-tight hover:text-purple-400 transition-colors">
          <!-- Puedes reemplazar por <img src="/logo.svg" alt="Logo" class="h-9 w-auto" /> -->
          Helium
        </a>

        <!-- Centro: menú + búsqueda -->
        <div class="hidden md:flex items-center gap-4 lg:gap-8 flex-1 justify-center">

          <!-- Botones morados de navegación -->
          <div class="flex items-center gap-2.5 lg:gap-4">
            <a href="/homeUsuario" class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 active:bg-purple-800 text-white font-medium rounded-lg transition-colors shadow-sm shadow-purple-900/30">
              Inicio
            </a>
            <a href="/nuestrosServicios" class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 active:bg-purple-800 text-white font-medium rounded-lg transition-colors shadow-sm shadow-purple-900/30">
             Nuestros Servicios
            </a>
            <a href="/nosotros" class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 active:bg-purple-800 text-white font-medium rounded-lg transition-colors shadow-sm shadow-purple-900/30">
              Nosotros
            </a>
          </div>

          <!-- Barra de búsqueda -->
          <div class="relative max-w-xs w-full">
            <input
              type="search"
              placeholder="Buscar servicios..."
              class="w-full pl-10 pr-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition"
            />
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
        </div>

        <!-- Derecha: ícono usuario + dropdown -->
        <div class="relative">
          <button 
            class="flex items-center gap-2 focus:outline-none group"
            aria-label="Menú de usuario"
            id="user-menu-button"
          >
            <!-- Avatar / foto -->
            <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-purple-600/60 group-hover:border-purple-500 transition">
              <!-- Reemplaza con tu foto real o iniciales -->
              <img 
                src="" 
                alt="Usuario" 
                class="w-full h-full object-cover"
              />
              <!-- Alternativa con iniciales: -->
              <!-- <div class="w-full h-full bg-purple-700 flex items-center justify-center text-xl font-bold">S</div> -->
            </div>
            <!-- Flechita (opcional) -->
            <svg class="h-4 w-4 text-slate-400 group-hover:text-purple-400 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          <!-- Dropdown menú (usamos hover para simplicidad, o puedes usar Alpine.js / JS para click) -->
          <div 
            class="absolute right-0 mt-3 w-56 bg-slate-800 border border-slate-700 rounded-xl shadow-2xl shadow-black/40 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible translate-y-2 group-hover:translate-y-0 transition-all duration-200 z-50"
          >
            <a href="/perfil" class="block px-5 py-2.5 text-slate-300 hover:bg-slate-700 hover:text-white transition">Perfil</a>
            <a href="/configuracion" class="block px-5 py-2.5 text-slate-300 hover:bg-slate-700 hover:text-white transition">Configuración</a>
            <a href="/pagos" class="block px-5 py-2.5 text-slate-300 hover:bg-slate-700 hover:text-white transition">Métodos de pago</a>
            <hr class="my-2 border-slate-700" />
            <a href="/logout" class="block px-5 py-2.5 text-rose-400 hover:bg-slate-700 hover:text-rose-300 transition">Cerrar sesión</a>
          </div>
        </div>

      </nav>
      
    <!-- MENÚ CATEGORÍAS ensayando  -->
    <div class="bg-slate.800 py-3">
      <div class="max-w-7xl mx-auto flex justify-center gap-8 text-blue-200 font-semibold text-sm">
        <a href="#" class="hover:text-white">Desarrollo</a>
        <a href="#" class="hover:text-white">Diseño</a>
        <a href="#" class="hover:text-white">Marketing</a>
        <a href="#" class="hover:text-white">Video</a>
        <a href="#" class="hover:text-white">IA</a>
      </div>
    </div>
    </header>



    <!-- Contenido principal -->
    <main class="flex-1">
      <slot />
    </main>


    <footer class="bg-slate-950 py-16 text-amber-50">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-10">
      <!-- CATEGORÍAS -->
      <div>
        <h3 class="font-bold mb-4 text-lg">Categorías</h3>
        <a href="/categorias/desarrollo" class="block hover:text-blue-300 transition">Desarrollo</a>
        <a href="/categorias/diseno" class="block hover:text-blue-300 transition">Diseño</a>
        <a href="/categorias/marketing" class="block hover:text-blue-300 transition">Marketing</a>
        <a href="/categorias/ia" class="block hover:text-blue-300 transition">IA</a>
      </div>
      
      <!-- ACERCA DE -->
      <div>
        <h3 class="font-bold mb-4 text-lg">Acerca de</h3>
        <a href="/nosotros" class="block hover:text-blue-300 transition">Nosotros</a>
        <a href="/politica-privacidad" class="block hover:text-blue-300 transition">Política de privacidad</a>
        <a href="/condiciones" class="block hover:text-blue-300 transition">Condiciones</a>
      </div>

      <!-- APOYO -->
      <div>
        <h3 class="font-bold mb-4 text-lg">Apoyo y educación</h3>
        <a href="/centro-ayuda" class="block hover:text-blue-300 transition">Centro de ayuda</a>
        <a href="/guias" class="block hover:text-blue-300 transition">Guías</a>
        <a href="/blog" class="block hover:text-blue-300 transition">Blog</a>
      </div>

    </div>


    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 text-center">
        <p class="text-slate-400 text-lg md:text-xl">
          &copy; {new Date().getFullYear()} Helium. Hecho con ❤️ por Sara, camilo , stiven ,ronald
        </p>
        <p class="mt-3 text-slate-500 text-sm md:text-base">
          Plataforma de servicios freelance • Tolima, Colombia
        </p>
      </div>
  </footer>

  </body>
</html>