---
import '../styles/global.css';
interface Props {
  title: string;
  userName?: string;  // Nuevo prop opcional para pasar el nombre desde la página
}

const { title, userName = "sara Lopez" } = Astro.props;
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - Helium</title>
</head>

<body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col antialiased">

  <!-- Navbar superior -->
  <header class="bg-slate-900/80 backdrop-blur-md border-b border-slate-800/60 sticky top-0 z-50 w-full">
    <nav class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-3.5 flex items-center justify-between gap-6">
      <!-- Logo -->
      <a href="/" class="text-2xl md:text-3xl font-black tracking-tight hover:text-purple-400 transition-colors">
        Helium
      </a>

      <!-- Centro: botones + búsqueda -->
      <div class="hidden md:flex items-center gap-6 lg:gap-10 flex-1 justify-center">
        <div class="flex gap-3 lg:gap-5">
          <a href="/homeUsuario" class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">
            Inicio
          </a>
          <a href="/nuestrosServicios" class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">
            Servicios
          </a>
          <a href="/nosotros" class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">
            Nosotros
          </a>
          <a href="/catalogo" class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">
            Catalogo
          </a>
        </div>

        <div class="relative max-w-md w-full">
          <input
            type="search"
            placeholder="Buscar servicios, freelancers..."
            class="w-full pl-10 pr-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500"
          />
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>

      <!-- Usuario: foto + NOMBRE + flecha -->
      <div class="relative group">
        <button class="flex items-center gap-3 focus:outline-none">
          <div class="w-9 h-9 rounded-full bg-purple-700 flex items-center justify-center text-white font-bold border-2 border-purple-500/60 group-hover:border-purple-400 transition">
            S
          </div>
          <span class="font-medium text-slate-200 group-hover:text-purple-400 transition hidden sm:block">
            {userName}
          </span>
          <svg class="h-4 w-4 text-slate-400 group-hover:text-purple-400 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        

        <div class="absolute right-0 mt-3 w-56 bg-slate-800 border border-slate-700 rounded-xl shadow-2xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50">
          <a href="/perfil" class="block px-5 py-2.5 hover:bg-slate-700 transition">Perfil</a>
          <a href="/configuracion" class="block px-5 py-2.5 hover:bg-slate-700 transition">Configuracion de mi perfil</a>
        
          <a href="/logout" class="block px-5 py-2.5 text-amber-50 hover:bg-red-700 transition">Cerrar sesión</a>
        </div>
      </div>
    </nav>

    <!-- Barra de categorías comodar js para acomodar barrar de busqueda -->
    <div class="bg-slate-900/90 border-t border-slate-800">
      <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-3 flex justify-center gap-6 md:gap-10 lg:gap-12 text-sm md:text-base font-medium text-slate-300 overflow-x-auto">
        <a href="desarrolloWed" class="hover:text-purple-400 transition whitespace-nowrap">Desarrollo Wed</a>
        <a href="desarrolloMovil" class="hover:text-purple-400 transition whitespace-nowrap">Desarrollo Movil</a>
        <a href="diseñoGrafico" class="hover:text-purple-400 transition whitespace-nowrap">Diseño Grafico</a>
        <a href="marketingDigital" class="hover:text-purple-400 transition whitespace-nowrap">Marketing Digital</a>
        <a href="redaccionTraduccion" class="hover:text-purple-400 transition whitespace-nowrap">Redacción y Traducción</a>
        <a href="edicionVideo" class="hover:text-purple-400 transition whitespace-nowrap">Edición de Video y Multimedia</a>
        <a href="soporteTecnico" class="hover:text-purple-400 transition whitespace-nowrap">Soporte Técnico y TI</a>
      </div>
    </div>
  </header>

  <!-- Contenido principal -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-slate-950 border-t border-slate-800 py-12">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-10 text-slate-400">
      <div>
        <h3 class="text-white font-bold mb-4">Helium</h3>
        <p class="text-sm">Plataforma freelance colombiana</p>
      </div>
      <div>
        <h3 class="text-white font-bold mb-4">Enlaces</h3>
        
        <ul class="space-y-2 text-sm">
          <li><a href="/nosotros" class="hover:text-purple-400">Nosotros</a></li>
          <li><a href="/terminos" class="hover:text-purple-400">Términos y condiciones</a></li>
          <li><a href="/privacidad" class="hover:text-purple-400">Privacidad</a></li>
      
        </ul>
      </div>
      <div>
        <h3 class="text-white font-bold mb-4">Soporte</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/ayuda" class="hover:text-purple-400">Centro de ayuda</a></li>
          <li><a href="/contacto" class="hover:text-purple-400">Contacto</a></li>
          
        </ul>
      </div>
    </div>
  

    <div class="mt-10 text-center text-slate-500 text-sm">
      © {new Date().getFullYear()} Helium • Hecho con ❤️ en Tolima, Colombia
    </div>
  </footer>

</body>
</html>