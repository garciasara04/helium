---
interface Props {
  title: string;
}

const { title } = Astro.props;
import '../styles/global.css'; 
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Si usas Tailwind vía CDN temporalmente, está bien. Recomiendo instalarlo con npm para producción -->
    <script src="https://cdn.tailwindcss.com"></script>
  </head>

 <body class="bg-slate-900 text-slate-100 min-h-screen flex flex-col">

    <!-- Header / Navegación - más grande y con mejor presencia -->
    <header class="bg-slate-900 border-b border-slate-700 sticky top-0 z-50">
      <nav class="w-full px-6 md:px-12 lg:px-20 py-6 md:py-7 flex justify-between items-center">
        <!-- Logo más grande -->
        <a href="/" class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-white hover:text-blue-900 transition duration-300 tracking-tight">
          Bienvenid@s
        </a>

        <!-- Menú con enlaces más grandes y espaciados -->
        <ul class="flex items-center gap-8 md:gap-12 lg:gap-16 text-lg md:text-xl lg:text-2xl font-medium">
          <li>
            <a href="/" class="hover:text-blue-800 transition duration-300 hover:underline underline-offset-8">
              Inicio
            </a>
          </li>
          <li>
            <a href="/Register" class="hover:text-blue-800 transition duration-300 hover:underline underline-offset-8">
              Registrarse
            </a>
          </li>
          <li>
            <a href="/Login" class="hover:text-blue-800 transition duration-300 hover:underline underline-offset-8">
              Login
            </a>
          </li>
        </ul>
        <button onclick=""class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white rounded-lg font-semibold transition">
           Cerrar Sesión
        </button>
      </nav>
    </header>

    <!-- Contenido principal -->
    <main>
      <slot />  <!-- Aquí va el contenido de cada página -->
    </main>

    <!-- Footer - más grande, con más espacio y centrado -->
    <footer class="bg-slate-900 border-t border-slate-700 py-10 md:py-12">
      <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-16 text-center">
        <p class="text-slate-400 text-lg md:text-xl">
          &copy; {new Date().getFullYear()} Helium. Hecho con ❤️ por Sara, camilo , stiven ,ronald
        </p>
        <p class="mt-3 text-slate-500 text-sm md:text-base">
          Plataforma de servicios freelance • Tolima, Colombia
        </p>
      </div>
    </footer>

  </body>
</html>