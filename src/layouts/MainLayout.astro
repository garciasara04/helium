---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Helium</title>
  </head>

  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col">

    <!-- NAVBAR PÚBLICO -->
    <header class="bg-slate-950 border-b border-slate-700 sticky top-0 z-50">
      <nav class="w-full px-6 md:px-12 lg:px-20 py-4 flex justify-between items-center">

        <!-- Logo -->
        <a href="/" class="text-2xl md:text-3xl font-extrabold text-white hover:text-blue-500 transition tracking-tight">
          Helium
        </a>
        <!-- Logo -->
        <a href="/homeUsuario" class="text-2xl md:text-3xl font-extrabold text-white hover:text-blue-500 transition tracking-tight">
          homeUsuario
        </a>
        <a href="/miCuenta" class="text-2xl md:text-3xl font-extrabold text-white hover:text-blue-500 transition tracking-tight">
          miCuenta
        </a>
        <!-- Menú -->
        <ul class="flex items-center gap-8 text-lg font-medium">
          <li>
            <a href="/" class="hover:text-blue-400 transition hover:underline underline-offset-8">
              Inicio
            </a>
          </li>
          <li>
            <a href="/auth/register" class="hover:text-blue-400 transition hover:underline underline-offset-8">
              Registrarse
            </a>
          </li>
          <li>
            <a href="/auth/login" class="px-5 py-2 bg-purple-700 hover:bg-purple-600 rounded-lg transition">
              Login
            </a>
          </li>
        </ul>

      </nav>
    </header>

    <!-- CONTENIDO -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="bg-slate-900 border-t border-slate-700 py-8">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <p class="text-slate-400 text-lg">
          © {new Date().getFullYear()} Helium. Hecho con ❤️ por Sara, Camilo, Stiven y Ronald
        </p>
        <p class="mt-2 text-slate-500 text-sm">
          Plataforma de servicios freelance • Tolima, Colombia
        </p>
      </div>
    </footer>

  </body>
</html>
