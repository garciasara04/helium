---
import '../styles/global.css';

const { title = "Helium - Dashboard Freelancer" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="antialiased">

    <!-- HEADER FIJO -->
    <header class="fixed top-0 left-0 right-0 z-50 bg-indigo-950/80 backdrop-blur-xl border-b border-indigo-800/40">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="text-2xl font-bold bg-linear-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent">
          Helium
        </a>

        <!-- Buscador -->
        <div class="flex-1 max-w-xl mx-6 hidden md:block">
          <div class="relative">
            <input type="search" placeholder="Buscar servicios, pedidos, mensajes..." class="w-full pl-10 pr-4 py-2 bg-indigo-900/60 border border-indigo-700 rounded-full focus:outline-none focus:border-purple-500 text-white placeholder:text-indigo-300" />
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-indigo-400">🔍</span>
          </div>
        </div>

        <!-- Iconos -->
        <div class="flex items-center gap-5">
          <a href="/dashboard/notificaciones" aria-label="Notificaciones" class="text-2xl hover:text-purple-300 transition">🔔</a>
          <a href="/dashboard/mensajes" aria-label="Mensajes" class="text-2xl hover:text-purple-300 transition">💬</a>
          <a href="/dashboard/estadisticas" aria-label="Estadísticas" class="text-2xl hover:text-purple-300 transition">📊</a>

          <!-- Perfil con menú -->
          <div class="relative group">
            <img src="/tu-foto.jpg" alt="Sara" class="w-9 h-9 rounded-full cursor-pointer ring-2 ring-purple-500 object-cover" />
            <div class="absolute right-0 mt-3 w-56 bg-indigo-950/95 backdrop-blur-lg border border-indigo-800 rounded-xl shadow-xl py-2 hidden group-hover:block">
              <a href="/dashboard/perfil" class="block px-4 py-2 hover:bg-purple-900/50">Mi perfil</a>
              <a href="/dashboard/mis-servicios" class="block px-4 py-2 hover:bg-purple-900/50">Mis servicios</a>
              <a href="/dashboard/pedidos" class="block px-4 py-2 hover:bg-purple-900/50">Pedidos</a>
              <a href="/dashboard/ingresos" class="block px-4 py-2 hover:bg-purple-900/50">Ingresos</a>
              <a href="/dashboard/configuracion" class="block px-4 py-2 hover:bg-purple-900/50">Configuración</a>
              <hr class="my-1 border-indigo-800" />
              <a href="/logout" class="block px-4 py-2 text-red-400 hover:bg-red-900/50">Cerrar sesión</a>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="pt-20 pb-16 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="bg-indigo-950/70 border-t border-indigo-800/40 py-8 text-center text-sm text-indigo-300">
      <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-center gap-6 md:gap-12">
        <a href="/ayuda" class="hover:text-purple-300">Centro de ayuda</a>
        <a href="/terminos" class="hover:text-purple-300">Términos y condiciones</a>
        <a href="/privacidad" class="hover:text-purple-300">Política de privacidad</a>
        <a href="/soporte" class="hover:text-purple-300">Soporte</a>
      </div>
      <div class="mt-6 flex justify-center gap-6 text-xl">
        <!-- Iconos redes sociales -->
        <a href="#" class="hover:text-purple-300">fb</a>
        <a href="#" class="hover:text-purple-300">tw</a>
        <a href="#" class="hover:text-purple-300">ig</a>
      </div>
      <p class="mt-4">© {new Date().getFullYear()} Helium. Todos los derechos reservados.</p>
    </footer>

  </body>
</html>