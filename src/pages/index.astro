---
import PublicLayout from '../layouts/PublicLayout.astro';
---

<PublicLayout title="Helium - Conecta Talento con Oportunidades">

<div class="relative min-h-screen bg-gradient-to-br from-indigo-950 via-purple-950 to-slate-950 text-white overflow-hidden">

  <!-- Fondo animado sutil (efecto de red/partículas muy ligero) -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_30%,rgba(139,92,246,0.12)_0%,transparent_60%),radial-gradient(circle_at_80%_70%,rgba(59,130,246,0.12)_0%,transparent_60%)] animate-pulse-slow"></div>
  </div>

  <!-- Hero principal -->
  <section class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 py-20">
    <h1 class="text-6xl sm:text-8xl md:text-9xl lg:text-[10rem] font-black tracking-tighter mb-6 bg-clip-text text-transparent bg-gradient-to-r from-blue-400 via-purple-400 to-indigo-400 animate-gradient-x">
      HELIUM
    </h1>

    <p class="text-2xl sm:text-4xl md:text-5xl font-light mb-12 md:mb-16 text-center max-w-4xl leading-tight">
      La red que une talento freelance con proyectos que importan
    </p>

    <!-- Botones principales interactivos -->
    <div class="flex flex-wrap justify-center gap-6 md:gap-10 z-20 relative">
      <a
        href="#servicios"
        class="group relative px-10 py-5 bg-linear-to-r from-indigo-600 to-purple-600 rounded-xl font-bold text-lg shadow-2xl shadow-purple-900/50 hover:shadow-purple-700/70 hover:scale-105 transition-all duration-400 overflow-hidden"
      >
        <span class="relative z-10">Explorar Servicios</span>
        <div class="absolute inset-0 bg-linear-to-r from-indigo-500/40 to-purple-500/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
      </a>

      <a
        href="#nosotros"
        class="group relative px-10 py-5 border-2 border-purple-500 text-purple-300 rounded-xl font-bold text-lg hover:bg-purple-900/40 hover:text-white transition-all duration-400 hover:scale-105"
      >
        Conócenos
      </a>

      <a
        href="#satisfaccion"
        class="group relative px-10 py-5 border-2 border-blue-500 text-blue-300 rounded-xl font-bold text-lg hover:bg-blue-900/40 hover:text-white transition-all duration-400 hover:scale-105"
      >
        Lo que dicen
      </a>
    </div>

    <!-- Efecto visual de nodos/conexiones (más visible en desktop) -->
    <div class="absolute inset-0 z-0 pointer-events-none hidden lg:block">
      <div class="absolute top-[20%] left-[15%] w-10 h-10 bg-purple-500 rounded-full shadow-2xl shadow-purple-700/60 animate-pulse group-hover:scale-150 transition-transform duration-700"></div>
      <div class="absolute top-[35%] right-[20%] w-8 h-8 bg-blue-500 rounded-full shadow-2xl shadow-blue-700/60 animate-pulse delay-500"></div>
      <div class="absolute bottom-[25%] left-[30%] w-12 h-12 bg-indigo-500 rounded-full shadow-2xl shadow-indigo-700/60 animate-pulse delay-1000"></div>
      <div class="absolute bottom-[30%] right-[25%] w-9 h-9 bg-purple-400 rounded-full shadow-2xl shadow-purple-600/60 animate-pulse delay-1500"></div>

      <!-- Líneas de conexión sutiles -->
      <svg class="absolute inset-0 w-full h-full opacity-15" viewBox="0 0 100 100" preserveAspectRatio="none">
        <line x1="15" y1="20" x2="80" y2="35" stroke="url(#grad1)" stroke-width="0.6" />
        <line x1="15" y1="20" x2="30" y2="75" stroke="url(#grad2)" stroke-width="0.6" />
        <line x1="80" y1="35" x2="70" y2="70" stroke="url(#grad1)" stroke-width="0.6" />
        <defs>
          <linearGradient id="grad1" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#a78bfa" />
            <stop offset="100%" stop-color="#60a5fa" />
          </linearGradient>
          <linearGradient id="grad2" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#60a5fa" />
            <stop offset="100%" stop-color="#c084fc" />
          </linearGradient>
        </defs>
      </svg>
    </div>
  </section>

  <!-- Sección Servicios -->
  <section id="servicios" class="py-24 px-6 bg-black/30">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-5xl md:text-6xl font-bold text-center mb-16 bg-clip-text text-transparent bg-gradient-to-r from-purple-400 to-blue-400">
        Nuestros Servicios
      </h2>

      <div class="grid md:grid-cols-3 gap-8 md:gap-12">
        <div class="group bg-slate-900/70 border border-purple-800/40 rounded-2xl p-10 hover:border-purple-500 hover:shadow-2xl hover:shadow-purple-900/40 transition-all duration-500 hover:-translate-y-4">
          <div class="text-7xl mb-6 group-hover:scale-110 transition-transform duration-500">🖥️</div>
          <h3 class="text-3xl font-bold mb-4">Desarrollo Web</h3>
          <p class="text-slate-300 text-lg leading-relaxed">
            Sitios rápidos, modernos, responsivos y optimizados para posicionamiento en buscadores.
          </p>
        </div>

        <div class="group bg-slate-900/70 border border-indigo-800/40 rounded-2xl p-10 hover:border-indigo-500 hover:shadow-2xl hover:shadow-indigo-900/40 transition-all duration-500 hover:-translate-y-4">
          <div class="text-7xl mb-6 group-hover:scale-110 transition-transform duration-500">🎨</div>
          <h3 class="text-3xl font-bold mb-4">Diseño & Branding</h3>
          <p class="text-slate-300 text-lg leading-relaxed">
            Identidad visual única: logos, UI/UX, material publicitario y branding completo.
          </p>
        </div>

        <div class="group bg-slate-900/70 border border-blue-800/40 rounded-2xl p-10 hover:border-blue-500 hover:shadow-2xl hover:shadow-blue-900/40 transition-all duration-500 hover:-translate-y-4">
          <div class="text-7xl mb-6 group-hover:scale-110 transition-transform duration-500">📈</div>
          <h3 class="text-3xl font-bold mb-4">Marketing Digital</h3>
          <p class="text-slate-300 text-lg leading-relaxed">
            Estrategias SEO, redes sociales, anuncios pagados y generación de leads reales.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección Nosotros -->
  <section id="nosotros" class="py-24 px-6 bg-gradient-to-b from-purple-950/80 to-indigo-950/80">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-5xl md:text-6xl font-bold mb-12 bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-purple-400">
        Quiénes Somos
      </h2>

      <p class="text-xl md:text-2xl leading-relaxed text-slate-200 max-w-4xl mx-auto mb-12">
        Helium es la plataforma creada para conectar talento real con proyectos que valen la pena. 
        Nacimos para hacer el trabajo remoto más justo, transparente y eficiente para todos.
      </p>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-slate-900/50 p-8 rounded-2xl border border-indigo-800/30 hover:border-indigo-500 transition-all duration-300">
          <h3 class="text-2xl font-bold mb-4 text-indigo-300">Transparencia</h3>
          <p class="text-slate-300">Todo visible: pagos, tiempos, reseñas y comunicación directa.</p>
        </div>

        <div class="bg-slate-900/50 p-8 rounded-2xl border border-purple-800/30 hover:border-purple-500 transition-all duration-300">
          <h3 class="text-2xl font-bold mb-4 text-purple-300">Seguridad</h3>
          <p class="text-slate-300">Escrow inteligente, contratos claros y protección para ambas partes.</p>
        </div>

        <div class="bg-slate-900/50 p-8 rounded-2xl border border-blue-800/30 hover:border-blue-500 transition-all duration-300">
          <h3 class="text-2xl font-bold mb-4 text-blue-300">Calidad</h3>
          <p class="text-slate-300">Verificación de perfiles, reputación y soporte constante.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección Satisfacción -->
  <section id="satisfaccion" class="py-24 px-6 bg-slate-950">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-5xl md:text-6xl font-bold text-center mb-16 bg-clip-text text-transparent bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-400">
        Lo que dicen nuestros usuarios
      </h2>

      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-slate-900/70 rounded-2xl p-10 border border-purple-800/40 hover:border-purple-500 transition-all duration-500 hover:shadow-purple-900/30">
          <div class="text-5xl mb-6">★★★★★</div>
          <p class="text-lg italic mb-6 text-slate-200">"Helium cambió mi forma de trabajar. Clientes serios y pagos puntuales siempre."</p>
          <p class="font-semibold text-purple-300 mt-4">— Laura M. • Diseñadora</p>
        </div>

        <div class="bg-slate-900/70 rounded-2xl p-10 border border-indigo-800/40 hover:border-indigo-500 transition-all duration-500 hover:shadow-indigo-900/30">
          <div class="text-5xl mb-6">★★★★★</div>
          <p class="text-lg italic mb-6 text-slate-200">"Encontré talento de alto nivel en menos de 48 horas. Plataforma increíble."</p>
          <p class="font-semibold text-indigo-300 mt-4">— Carlos R. • Emprendedor</p>
        </div>

        <div class="bg-slate-900/70 rounded-2xl p-10 border border-blue-800/40 hover:border-blue-500 transition-all duration-500 hover:shadow-blue-900/30">
          <div class="text-5xl mb-6">★★★★★</div>
          <p class="text-lg italic mb-6 text-slate-200">"La mejor experiencia como empresa. Recomendaciones reales y soporte excelente."</p>
          <p class="font-semibold text-blue-300 mt-4">— Tech Startup X</p>
        </div>
      </div>
    </div>
  </section>

</div>

<style>
  @keyframes gradient-x {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient-x {
    background-size: 300% 300%;
    animation: gradient-x 18s ease infinite;
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.12); }
  }
  .animate-pulse-slow {
    animation: pulse-slow 12s ease-in-out infinite;
  }
</style>

</PublicLayout>