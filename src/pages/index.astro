---
import PublicLayout from "../layouts/PublicLayout.astro";

const views = [
  {
    title: "Panel Cliente",
    image: "vista-cliente.png",
    desc: "Encuentra freelancers y contrata servicios fácilmente."
  },
  {
    title: "Panel Freelancer",
    image: "/images/vista-freelancer.png",
    desc: "Publica servicios y gestiona pedidos."
  },
  {
    title: "Panel Empresa",
    image: "/images/vista-company.png",
    desc: "Gestiona proyectos y contrata talento."
  }
];
---

<PublicLayout title="Helium - Marketplace Freelance">

<!-- HERO -->
<section class="bg-slate-950 text-slate-100">
  <div class="max-w-7xl mx-auto px-6 py-24 text-center">
    <h1 class="text-5xl md:text-6xl font-bold mb-6">
      Encuentra el <span class="text-purple-500">talento perfecto</span>
    </h1>
    <p class="text-slate-400 max-w-2xl mx-auto mb-10 text-lg">
      Helium conecta empresas y clientes con freelancers profesionales
      en desarrollo, diseño, marketing y más.
    </p>
    <div class="flex justify-center gap-5 flex-wrap">
      <a href="/register" class="bg-purple-600 hover:bg-purple-700 px-8 py-4 rounded-xl font-semibold transition text-lg">
        Explorar servicios
      </a>
      <a href="/register" class="border border-slate-600 hover:border-purple-500 px-8 py-4 rounded-xl transition text-lg">
        Crear cuenta
      </a>
    </div>
  </div>
</section>

<!-- CAROUSEL -->
<section class="bg-slate-950 py-16 md:py-24 overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-6">

    <div class="relative flex items-center justify-center min-h-105 md:min-h-125">

      <!-- Botones -->
      <button id="prev" class="absolute left-4 md:left-8 z-20 bg-slate-900/80 hover:bg-purple-700/80 backdrop-blur-sm p-4 rounded-full text-2xl transition-all duration-300 shadow-xl">
        ←
      </button>

      <button id="next" class="absolute right-4 md:right-8 z-20 bg-slate-900/80 hover:bg-purple-700/80 backdrop-blur-sm p-4 rounded-full text-2xl transition-all duration-300 shadow-xl">
        →
      </button>

      <!-- Contenedor del carousel -->
      <div id="carousel" class="flex items-center justify-center gap-4 md:gap-8 transition-transform duration-700 ease-out">
        {
          views.map((view, index) => (
            <div
              class="carousel-item min-w-[280px] md:min-w-[380px] bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-xl transition-all duration-700 cursor-pointer group"
              data-index={index}
            >
              <img
                src={view.image}
                alt={view.title}
                class="w-full h-56 md:h-72 object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="p-6 md:p-8">
                <h3 class="text-xl md:text-2xl font-semibold mb-3 text-slate-100">
                  {view.title}
                </h3>
                <p class="text-slate-400 text-sm md:text-base">
                  {view.desc}
                </p>
              </div>
            </div>
          ))
        }
      </div>

    </div>
  </div>
</section>

<!-- SERVICIOS -->
<section class="bg-slate-950 py-20">
  <div class="max-w-7xl mx-auto px-6">
    <h2 class="text-4xl font-bold text-slate-100 mb-16 text-center">
      Servicios populares
    </h2>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Desarrollo Web -->
      <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl hover:border-purple-600/50 transition-all duration-300 group">
        <h3 class="text-2xl font-semibold text-slate-100 mb-4 group-hover:text-purple-400 transition-colors">
          Desarrollo Web
        </h3>
        <p class="text-slate-400 mb-6">
          Freelancers expertos en Astro, React y Node.js
        </p>
        <a href="/nuestrosServicios"class="bg-purple-600 hover:bg-purple-700 px-6 py-3 rounded-xl font-medium transition">
          Ver servicios
        </a>
      </div>

      <!-- Diseño UI/UX -->
      <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl hover:border-purple-600/50 transition-all duration-300 group">
        <h3 class="text-2xl font-semibold text-slate-100 mb-4 group-hover:text-purple-400 transition-colors">
          Diseño UI / UX
        </h3>
        <p class="text-slate-400 mb-6">
          Diseños profesionales para apps y sitios web.
        </p>
        <a href="/nuestrosServicios"class="bg-purple-600 hover:bg-purple-700 px-6 py-3 rounded-xl font-medium transition">
          Ver servicios
        </a>
      </div>

      <!-- Marketing Digital -->
      <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl hover:border-purple-600/50 transition-all duration-300 group">
        <h3 class="text-2xl font-semibold text-slate-100 mb-4 group-hover:text-purple-400 transition-colors">
          Marketing Digital
        </h3>
        <p class="text-slate-400 mb-6">
          SEO, publicidad y crecimiento online.
        </p>
        <a href="/nuestrosServicios" class="bg-purple-600 hover:bg-purple-700 px-6 py-3 rounded-xl font-medium transition">
          Ver servicios
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  let current = 1;
  const carousel = document.getElementById("carousel");
  const items = document.querySelectorAll(".carousel-item");
  const total = items.length;

  function updateCarousel() {
    items.forEach((item, index) => {
      item.classList.remove(
        "scale-100", "scale-90", "scale-75",
        "opacity-100", "opacity-70", "opacity-40",
        "z-20", "z-10", "z-0",
        "-translate-x-1/3", "translate-x-1/3"
      );

      const diff = index - current;

      if (diff === 0) {
        item.classList.add("scale-100", "opacity-100", "z-20");
      } else if (Math.abs(diff) === 1) {
        item.classList.add("scale-90", "opacity-70", "z-10");
        if (diff < 0) item.classList.add("-translate-x-1/3");
        else item.classList.add("translate-x-1/3");
      } else {
        item.classList.add("scale-75", "opacity-40", "z-0");
      }
    });
  }

  document.getElementById("next").onclick = () => {
    current = (current + 1) % total;
    updateCarousel();
  };

  document.getElementById("prev").onclick = () => {
    current = (current - 1 + total) % total;
    updateCarousel();
  };

  items.forEach((item, index) => {
    item.onclick = () => {
      current = index;
      updateCarousel();
    };
  });

  // Inicializar
  updateCarousel();

  // Opcional: autoplay (descomenta si lo quieres)
  /*
  setInterval(() => {
    current = (current + 1) % total;
    updateCarousel();
  }, 5000);
  */
</script>

</PublicLayout>