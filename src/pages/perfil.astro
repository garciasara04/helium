---
// src/pages/mi-perfil.astro  (o donde quieras ponerla: dashboard.astro, perfil.astro, etc.)
import HomeLayout from '../layouts/HomeLayout.astro';

// Datos de ejemplo (en producción: vienen de tu backend / sesión / API)
const user = {
  name: "Sara López",
  email: "sara.lopez@example.com",
  photo: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=80", // o ruta local /uploads/tu-foto.jpg
  
};
---

<HomeLayout title="Mi Perfil - Helium">

  <div class="min-h-screen bg-linear-to-b from-gray-950 via-gray-900 to-gray-950 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">

      <!-- Tarjeta principal del perfil -->
      <div class="bg-gray-900/80 backdrop-blur-md border border-gray-800 rounded-2xl shadow-2xl shadow-purple-900/20 overflow-hidden">
        
        {/* Header con foto y nombre */}
        <div class="relative h-48 bg-linear-to-r from-purple-900/40 to-indigo-900/40">
          <div class="absolute -bottom-16 left-1/2 -translate-x-1/2">
            <div class="relative">
              <img
                src={user.photo}
                alt={user.name}
                class="w-32 h-32 rounded-full object-cover border-4 border-purple-600 shadow-xl shadow-purple-900/40"
              />
              <div class="absolute -bottom-1 -right-1 bg-green-500 w-6 h-6 rounded-full border-4 border-gray-900"></div>
            </div>
          </div>
        </div>

        {/* Contenido principal */}
        <div class="pt-20 pb-10 px-6 sm:px-10 text-center">
          <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">
            {user.name}
          </h1>
          
          <p class="text-lg text-purple-400 font-medium mb-8">
            {user.email}
          </p>

          {}
          <a
            href="/editar-perfil"
            class="inline-flex items-center gap-2 px-8 py-4 bg-purple-700 hover:bg-purple-600 text-white font-semibold text-lg rounded-xl transition-all duration-300 shadow-lg shadow-purple-900/40 hover:shadow-purple-600/50 transform hover:-translate-y-1"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
            </svg>
            Actualizar perfil
          </a>

          {/* Información adicional (puedes expandir después) */}
          <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-6 text-left">
            <div class="bg-gray-800/50 p-6 rounded-xl border border-gray-700">
              <h3 class="text-lg font-semibold text-purple-300 mb-3">Datos básicos</h3>
              <p class="text-gray-300">
                <span class="font-medium text-white">Nombre:</span> {user.name}<br>
                <span class="font-medium text-white">Correo:</span> {user.email}
              </p>
            </div>

            <div class="bg-gray-800/50 p-6 rounded-xl border border-gray-700">
              <h3 class="text-lg font-semibold text-purple-300 mb-3">Estado de cuenta</h3>
              <p class="text-gray-300">
                Cuenta verificada ✓<br>
                Miembro desde febrero 2026<br>
                Rol: Usuario 
              </p>
            </div>
          </div>
        </div>
      </div>

     <div class="mt-10 text-center">
        <button 
            onclick="if(confirm('¿Cerrar sesión?')) window.location.href = '/';"
            class="text-red-400 hover:text-red-300 font-medium text-lg transition flex items-center justify-center gap-2 mx-auto"
        >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Cerrar sesión
        </button>
        </div>

    </div>
  </div>

</HomeLayout>