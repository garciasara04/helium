---
// src/pages/nuestrosServicios.astro
import PublicLayout from "../layouts/PublicLayout.astro";

// Datos de ejemplo (puedes venir de una API, JSON o base de datos)
const services = [
  {
    title: "Desarrollo Web Personalizado",
    description: "Sitios web modernos, rápidos y responsivos con tecnologías como Astro, React, Next.js o WordPress.",
    priceFrom: "Desde $250",
    icon: "🌐",
    features: ["Diseño responsive", "Optimización SEO", "Integraciones API", "Mantenimiento incluido"],
    category: "Desarrollo",
  },
  {
    title: "Diseño Gráfico y Logos",
    description: "Logos profesionales, identidades visuales, banners y material publicitario único.",
    priceFrom: "Desde $45",
    icon: "🎨",
    features: ["Revisiones ilimitadas", "Archivos fuente", "Variaciones de color", "Uso comercial"],
    category: "Diseño",
  },
  {
    title: "Edición y Producción de Video",
    description: "Edición profesional, motion graphics, videos explicativos y anuncios para redes sociales.",
    priceFrom: "Desde $80",
    icon: "🎥",
    features: ["4K disponible", "Música sin derechos", "Subtítulos", "Entrega en múltiples formatos"],
    category: "Video",
  },
  {
    title: "Posicionamiento SEO y Marketing",
    description: "Estrategias SEO, Google Ads, redes sociales y contenido que posiciona tu marca.",
    priceFrom: "Desde $120",
    icon: "📈",
    features: ["Auditoría inicial gratis", "Reportes mensuales", "Palabras clave locales", "Optimización on-page"],
    category: "Marketing",
  },
  {
    title: "Redacción y Traducción",
    description: "Artículos de blog, copywriting persuasivo, traducciones profesionales y guiones.",
    priceFrom: "Desde $30",
    icon: "✍️",
    features: ["100% original", "SEO friendly", "Idiomas: ES/EN/PT", "Entrega rápida"],
    category: "Escritura",
  },
  {
    title: "Inteligencia Artificial y Automatización",
    description: "Chatbots, generación de contenido con IA, automatizaciones y scripts personalizados.",
    priceFrom: "Desde $150",
    icon: "🤖",
    features: ["Modelos GPT personalizados", "Automatización de procesos", "Integración con herramientas", "Soporte continuo"],
    category: "IA",
  },
];
---

<PublicLayout title="Nuestros Servicios">

  <!-- Hero superior -->
  <section class="relative py-20 md:py-32 bg-linear-to-br from-slate-950 via-slate-900 to-purple-950/30">
    <div class="absolute inset-0 bg-grid-slate-800/20"></div>
    <div class="relative max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 tracking-tight">
        Nuestros Servicios
      </h1>
      <p class="text-xl md:text-2xl text-slate-300 max-w-3xl mx-auto mb-10">
        Encuentra el talento especializado que tu proyecto necesita. Calidad profesional, precios transparentes y satisfacción garantizada.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="nuestrosServicios" class="px-8 py-4 bg-purple-700 hover:bg-purple-600 text-white font-bold rounded-xl transition shadow-lg shadow-purple-900/30">
          Ver todos los servicios ↓
        </a>
        <a href="/login" class="px-8 py-4 bg-slate-800 hover:bg-slate-700 border border-slate-600 text-white font-bold rounded-xl transition">
          Mi red de freelancers
        </a>
      </div>
    </div>
  </section>

  <!-- Grid de servicios -->
  <section id="servicios" class="py-16 md:py-24 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
        {services.map((service) => (
          <div class="group bg-slate-900/80 border border-slate-800 rounded-2xl overflow-hidden hover:border-purple-600/70 transition-all duration-300 hover:shadow-2xl hover:shadow-purple-900/20">
            {/* Icono o imagen superior */}
            <div class="h-48 bg-linear-to-br from-purple-900/30 to-slate-900 flex items-center justify-center text-6xl">
              {service.icon}
            </div>

            <div class="p-6 md:p-8">
              <h3 class="text-2xl font-bold text-white group-hover:text-purple-400 transition-colors mb-3">
                {service.title}
              </h3>

              <p class="text-slate-300 mb-6">
                {service.description}
              </p>

              <div class="flex items-center justify-between mb-6">
                <span class="text-purple-400 font-bold text-xl">
                  {service.priceFrom}
                </span>
                <span class="text-sm px-3 py-1 bg-purple-900/40 rounded-full text-purple-300">
                  {service.category}
                </span>
              </div>

              <ul class="space-y-2 mb-8 text-slate-400 text-sm">
                {service.features.map((feature) => (
                  <li class="flex items-center gap-2">
                    <span class="text-green-400">✓</span> {feature}
                  </li>
                ))}
              </ul>

              <a 
                href="login"
                class="block w-full py-3.5 bg-purple-700 hover:bg-purple-600 text-white font-semibold rounded-lg text-center transition shadow-md hover:shadow-purple-700/30"
              >
                Contratar ahora
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-20 bg-linear-to-br from-purple-950/50 to-slate-950">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        ¿Listo para empezar tu proyecto?
      </h2>
      <p class="text-xl text-slate-300 mb-10">
        Elige el servicio que necesitas y conecta con talento verificado en minutos.
      </p>
      <a 
        href="/login"
        class="inline-block px-10 py-5 bg-purple-700 hover:bg-purple-600 text-white text-xl font-bold rounded-xl transition shadow-2xl shadow-purple-900/40"
      >
        Ver freelancers disponibles →
      </a>
    </div>
  </section>

</PublicLayout>