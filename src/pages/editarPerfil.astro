---
//en la linea 29 se debe hacer un script para la modificacion de la foto 
import HomeLayout from '../layouts/HomeLayout.astro';
const user = {
  nombre: "Sara López",
  email: "sara.lopez.bpo@gmail.com",
  celular: "+57 310 555 9876",
  nit: "900.123.456-1",
  direccion: "Carrera A # 12-34, Barrio Centro, Ibagué",
  pais: "Colombia",
  ciudad: "Ibagué",
  descripcion: "Ofrezco servicios de call center, atención al cliente bilingüe, gestión de leads y soporte técnico nivel 1.",
  portafolioUrl: "https://portafolio.saralopez.co",
  experiencia: "5 años en BPO • 3 años como supervisora de cuentas • Certificada en atención al cliente digital",
  tarifaHora: "18",
  idiomas: "Español (nativo), Inglés (B2)",
};
---
<HomeLayout title="ensayo">
<div class="relative max-w-4xl mx-auto px-5 py-12 md:py-16">

    <div class="text-center mb-12">
      <div class="relative inline-block mx-auto">
        <div class="w-28 h-28 md:w-36 md:h-36 bg-purple-900/40 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-16 h-16 md:w-20 md:h-20 text-purple-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <button class="absolute -bottom-1 right-0 bg-purple-700 hover:bg-purple-600 text-white text-xs px-4 py-1.5 rounded-full shadow-md">
          Cambiar foto
        </button>
      </div>

      <h1 class="mt-8 text-4xl md:text-5xl font-bold tracking-tight">Editar Mi Perfil</h1>
      <p class="mt-3 text-indigo-300 text-lg">
        Para actualizar tu perfil, por favor ingresa o modifica los siguientes datos:
      </p>
    </div>

    <form class="bg-gray-900/50 backdrop-blur-sm border border-indigo-800/30 rounded-2xl p-8 md:p-10 shadow-2xl space-y-7">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div>
          <label class="block text-sm font-medium text-indigo-200 mb-2">País</label>
          <input type="text" value={user.pais} class="w-full px-5 py-3 bg-gray-800/70 border border-indigo-700/50 rounded-xl text-white focus:border-purple-500 focus:ring-purple-500" />
        </div>

        <div>
          <label class="block text-sm font-medium text-indigo-200 mb-2">Ciudad</label>
          <input type="text" value={user.ciudad} class="w-full px-5 py-3 bg-gray-800/70 border border-indigo-700/50 rounded-xl text-white focus:border-purple-500 focus:ring-purple-500" />
        </div>

      </div>

      <div>
        <label class="block text-sm font-medium text-indigo-200 mb-2">Descripción / Sobre mí</label>
        <textarea rows="5" class="w-full px-5 py-3 bg-gray-800/70 border border-indigo-700/50 rounded-xl text-white focus:border-purple-500 focus:ring-purple-500 resize-y">{user.descripcion}</textarea>
      </div>

      <div>
        <label class="block text-sm font-medium text-indigo-200 mb-2">Portafolio (URL)</label>
        <input type="url" value={user.portafolioUrl} placeholder="https://..." class="w-full px-5 py-3 bg-gray-800/70 border border-indigo-700/50 rounded-xl text-white focus:border-purple-500 focus:ring-purple-500" />
      </div>

      <div>
        <label class="block text-sm font-medium text-indigo-200 mb-2">Experiencia laboral (resumen)</label>
        <textarea rows="4" class="w-full px-5 py-3 bg-gray-800/70 border border-indigo-700/50 rounded-xl text-white focus:border-purple-500 focus:ring-purple-500">{user.experiencia}</textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div>
          <label class="block text-sm font-medium text-indigo-200 mb-2">Tarifa por hora (USD)</label>
          <input type="number" value={user.tarifaHora} min="1" step="0.5" class="w-full px-5 py-3 bg-gray-800/70 border border-indigo-700/50 rounded-xl text-white focus:border-purple-500 focus:ring-purple-500" />
        </div>

        <div>
          <label class="block text-sm font-medium text-indigo-200 mb-2">Idiomas (separados por coma)</label>
          <input type="text" value={user.idiomas} placeholder="Español (nativo), Inglés (B2), ..." class="w-full px-5 py-3 bg-gray-800/70 border border-indigo-700/50 rounded-xl text-white focus:border-purple-500 focus:ring-purple-500" />
        </div>

      </div>

      <div class="pt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <button
          type="submit"
          class="flex-1 max-w-sm bg-linear-to-r from-purple-600 to-purple-700 hover:from-purple-700 hover:to-purple-800 text-white font-semibold py-4 px-8 rounded-xl shadow-lg shadow-purple-900/40 transition-all duration-300 transform hover:scale-[1.02]"
        >
          Actualizar Perfil
        </button>

        <a
          href="/miCuenta"
          class="flex-1 max-w-sm text-center py-4 px-8 border border-purple-500/60 text-purple-200 font-medium rounded-xl hover:bg-purple-900/30 transition-colors"
        >
          Cancelar
        </a>
      </div>

    </form>

  </div>
</HomeLayout>
