---
import PublicLayout from "../layouts/PublicLayout.astro";
---

<PublicLayout>

<div class="min-h-screen bg-slate-900 py-10">

  <section class="max-w-2xl mx-auto px-6">

    <!-- Card -->
    <div class="bg-slate-900/90 border border-slate-800 rounded-2xl p-8 shadow-lg">

      <h2 class="text-2xl font-bold text-white mb-6">
        Cambiar contraseña
      </h2>

      <p class="text-slate-400 mb-8">
        Actualiza tu contraseña para mantener tu cuenta segura.
      </p>

      <form id="loginForm" class="space-y-6">

        <!-- Contraseña actual -->
        <div>
          <label class="block text-sm text-slate-300 mb-2">
            Contraseña actual
          </label>

          <input
            type="password"
            name="current_password"
            placeholder="Ingresa tu contraseña actual"
            class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-purple-500"
          />
        </div>

        <!-- Nueva contraseña -->
        <div>
          <label class="block text-sm text-slate-300 mb-2">
            Nueva contraseña
          </label>

          <input
            type="password"
            name="new_password"
            placeholder="Ingresa tu nueva contraseña"
            class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-purple-500"
          />
        </div>

        <!-- Confirmar contraseña -->
        <div>
          <label class="block text-sm text-slate-300 mb-2">
            Confirmar nueva contraseña
          </label>

          <input
            name="new_password_confirmation"
            type="password"
            placeholder="Confirma tu nueva contraseña"
            class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-purple-500"
          />
        </div>

        <!-- Botones -->
        <div class="flex gap-4 pt-4">

          <button
            type="submit"
            class="bg-purple-700 hover:bg-purple-600 text-white font-semibold px-6 py-3 rounded-lg transition shadow-lg shadow-purple-900/30"
          >
            Guardar cambios
          </button>

          <a
            href="/dashboard/freelance/perfil"
            class="bg-slate-800 hover:bg-slate-700 text-white font-semibold px-6 py-3 rounded-lg transition"
          >
            Cancelar
          </a>

        </div>

      </form>

    </div>

  </section>

</div>

<script>
   const login = document.getElementById('loginForm');
   const token = localStorage.getItem('token');

   function validatePasswordForm(formEl) {
    const current = String(formEl.current_password?.value || '').trim();
    const next = String(formEl.new_password?.value || '').trim();
    const confirm = String(formEl.new_password_confirmation?.value || '').trim();

    if (!current || !next || !confirm) {
      window.appToast('Completa todos los campos de contraseña.', { tone: 'warning' });
      return false;
    }
    if (next.length < 8) {
      window.appToast('La nueva contraseña debe tener al menos 8 caracteres.', { tone: 'warning' });
      return false;
    }
    if (next !== confirm) {
      window.appToast('La confirmación no coincide con la nueva contraseña.', { tone: 'warning' });
      return false;
    }
    return true;
   }

   login?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!token) {
      window.appToast('Sesión expirada.', { tone: 'warning' });
      window.location.href = '/Login';
      return;
    }

    if (!validatePasswordForm(login)) return;

    try {
      const formdata = new FormData(login);
      const response = await fetch('http://127.0.0.1:8000/api/password/change', {
        method: 'PATCH',
        headers:{
          'Authorization': `Bearer ${token}`,
          'Accept': 'application/json',
        },
        body: formdata
      });
      const data = await response.json();
      if (response.ok) {
        window.appToast(data.message || 'Contrasena actualizada.', { tone: 'success' });
        window.location.href = '/Login';
      } else {
        window.appToast(data.message || 'No se pudo actualizar la contrasena.', { tone: 'error' });
        login.reset();
      }
    } catch (error) {
      console.log(error);
      window.appToast('Error de conexión con el servidor.', { tone: 'error' });
    }
   });
</script>


</PublicLayout>


