---
import PublicLayout from "../layouts/PublicLayout.astro";

---

<PublicLayout >

  <div
    class="min-h-screen bg-cover bg-center bg-no-repeat relative"
    style="background-image: url(/image.png);"
  >

    <div class="relative z-10 flex min-h-screen pt-8 pb-20 px-6 md:px-16 lg:px-2">

      <div
        id="registerCard"
        class="w-full md:w-1/2 lg:w-1/2 max-w-2xl
        bg-gray-400/35 backdrop-blur-sm rounded-3xl shadow-2xl
        p-8 md:p-10 border border-gray-300/60
        opacity-0 translate-y-6 transition-all duration-700 ease-out"
      >

        <h1
          id="registerTitle"
          class="text-4xl font-bold text-center text-blue-950 mb-3
          opacity-0 translate-y-3 transition-all duration-500 ease-out"
        >
          REGISTRO
        </h1>

        <form id="registerForm"method="POST"action="/register"
          class="grid grid-cols-1 md:grid-cols-2 gap-3">

          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-amber-50 mb-1">
              Nombres
            </label>
            <input id="names"type="text"name="names"
              class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>
          </div>

          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-amber-50 mb-1">
              Apellidos
            </label>

            <input id="last_names"type="text"name="last_names"
            class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>
          </div>

          <div class="md:col-span-2">

            <label class="block text-sm font-medium text-amber-50 mb-1">
              Correo electrónico
            </label>

            <input id="email"type="email"name="email"
            class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>

          </div>

          <div>

            <label class="block text-sm font-medium text-amber-50 mb-1">
              Contraseña
            </label>

            <input id="password"type="password"name="password"
              class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>

          </div>

          <div>

            <label class="block text-sm font-medium text-amber-50 mb-1">
              Confirmar contraseña
            </label>

            <input id="password_confirmation"type="password"name="password_confirmation"
              class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>

          </div>

          <div>

            <label class="block text-sm font-medium text-amber-50 mb-1">
              Teléfono
            </label>

            <input type="tel"id="phone"name="phone"
              class="w-full px-5 py-2 rounded-xl bg-white border text-gray-900 border-gray-300"/>

          </div>

          <div>
              <label class="block text-sm font-medium text-gray-50 mb-1">Rol</label>
              <select
                id="role_id"
                name="role_id"
                class="w-full px-4 py-2 rounded-lg bg-white text-gray-900 border border-gray-300
                      focus:ring-2 focus:ring-indigo-400 focus:border-indigo-500">
              
                <option value="" disabled selected class="text-gray-400">
                  Selecciona tu rol
                </option>
                <option value="2" class="text-gray-900 bg-white">Freelancer</option>
                <option value="1" class="text-gray-900 bg-white">Usuario</option>
                <option value="3" class="text-gray-900 bg-white">Empresa</option>
              </select>
            </div>
            <div id="freelancerSection" class="hidden md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-3 p-4 bg-indigo-900/20 rounded-xl border border-indigo-500/30">
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-amber-50 mb-1">Profesión</label>
              <input id="profession" type="text" name="profession" class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-amber-50 mb-1">Experiencia (Resumen)</label>
              <input id="experience" type="text" name="experience" class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>
            </div>
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-amber-50 mb-1">Descripción</label>
              <textarea id="description" name="description" rows="2" class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"></textarea>
            </div>
          </div>

          <div id="companySection" class="hidden md:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-3 p-4 bg-emerald-900/20 rounded-xl border border-emerald-500/30">
            <div>
              <label class="block text-sm font-medium text-amber-50 mb-1">NIT</label>
              <input id="nit" type="text" name="nit" class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>
            </div>
            <div>
              <label class="block text-sm font-medium text-amber-50 mb-1">Dirección</label>
              <input id="address" type="text" name="address" class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300"/>
            </div>
          </div>

          <div class="md:col-span-2">

            <label class="block text-sm font-medium text-amber-50 mb-1">
              Foto de perfil
            </label>

            <label
              for="photo"
              class="flex items-center justify-between
              px-4 py-2 rounded-xl
              bg-white border border-gray-300
              cursor-pointer hover:bg-gray-50 transition"
            >

              <span id="fileText" class="text-gray-500">
                Selecciona una imagen
              </span>

              <span class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm">
                Subir
              </span>

            </label>

            <input
              id="photo"
              type="file"
              accept="image/*"
              class="hidden"
              name="photo"
            />

          </div>

          <div class="md:col-span-2">

            <button
              type="submit"
              class="w-full py-2 bg-gray-900 text-white rounded-xl font-bold"
            >
              Crear cuenta
            </button>

          </div>

        </form>

        <p class="text-center mt-4 text-gray-600 text-sm">

          ¿Olvidaste tu contraseña?

          <a
            href="/recuperar-contrasena"
            class="text-indigo-700 font-medium hover:underline"
          >
            Recuperar contraseña
          </a>

        </p>

        <div class="text-center mt-6 text-gray-700">

          ¿Ya tienes cuenta?

          <a
            href="/login"
            class="text-indigo-800 font-medium hover:underline"
          >
            Inicia sesión
          </a>

        </div>

      </div>

    </div>

  </div>


  <script>
    const registerForm = document.getElementById('registerForm');
    registerForm?.addEventListener('submit', async (e)=> {
      e.preventDefault();
      const formdata = new FormData(registerForm);
      try {
        const response = await fetch("http://127.0.0.1:8000/api/register", {
          method: 'POST',
          headers: {
            'Accept': 'application/json',
          },
          body: formdata
        })
        const data = await response.json();
        console.log(data);
        if (data.token){
          localStorage.setItem('token', data.token);
          const rol = parseInt(data.user.role_id)
          if(rol === 1){
            window.location.href = ('/dashboard/cliente');
          }
           if(rol === 2){
            window.location.href = ('/dashboard/freelance');
          }
           if(rol === 3){
            window.location.href = ('/dashboard/company');
          }
           if(rol === 4){
            window.location.href = ('/dashboard/admin');
          }
        }
        else{
          alert('Corrige los campos')
        }
      }
      catch (error) {
        console.log("error", error);
      }
    } )
  </script>
  <script>
    import "../js/auth/register.js";
  </script>
</PublicLayout>

