---
import MainLayout from "../layouts/MainLayout.astro";

const Title = "Registro | Bienvenid@s";
---

<MainLayout title={Title}>
  <div
    class="min-h-screen bg-cover bg-center bg-no-repeat relative"
    style="background-image: url(/image.png);"
  >
    <div class="relative z-10 flex min-h-screen pt-8 pb-20 px-6 md:px-16 lg:px-2">
      
      <div
          id="registerCard"
          class="w-full md:w-1/2 lg:w-1/2 max-w-2xl
                 bg-gray-400/35 backdrop-blur-sm rounded-3xl shadow-2xl
                 p-8 md:p-10 border border-gray-300/60
                 opacity-0 translate-y-6 transition-all duration-700 ease-out"
>
        
        <h1
          id="registerTitle"
          class="text-4xl font-bold text-center text-blue-950 mb-3
                 opacity-0 translate-y-3 transition-all duration-500 ease-out"
>
          REGISTRO
        </h1>

        <form id="registerForm" method="POST" 
            class="grid grid-cols-1 md:grid-cols-2 gap-3">
                
            <!-- Nombres -->  
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-amber-50 mb-1">Nombres</label>
              <input type="text" name="names"
                class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300" />
            </div>
          
            <!-- Email -->
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-amber-50 mb-1">Correo electrónico</label>
              <input type="email" name="email"
                class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300" />
            </div>
          
            <!-- Password -->
            <div>
              <label class="block text-sm font-medium text-amber-50 mb-1">Contraseña</label>
              <input id="password" type="password" name="password"
                class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300" />
            </div>
          
            <!-- Confirm -->
            <div>
              <label class="block text-sm font-medium text-amber-50 mb-1">Confirmar contraseña</label>
              <input id="configpassword" type="password" name="configpassword"
                class="w-full px-5 py-2 rounded-xl bg-white text-gray-900 border border-gray-300" />
            </div>
          
            <!-- Teléfono -->
            <div>
              <label class="block text-sm font-medium text-amber-50 mb-1">Teléfono</label>
              <input type="tel" name="phone"
                class="w-full px-5 py-2 rounded-xl bg-white border text-gray-900 border-gray-300" />
            </div>
          
            <!-- Rol -->
            <div>
              <label class="block text-sm font-medium text-gray-50 mb-1">Rol</label>
              <select
                id="role_id"
                name="role_id"
                class="w-full px-4 py-2 rounded-lg bg-white text-gray-900 border border-gray-300
                      focus:ring-2 focus:ring-indigo-400 focus:border-indigo-500">
              
                <option value="" disabled selected class="text-gray-400">
                  Selecciona tu rol
                </option>
                <option value="1" class="text-gray-900 bg-white">Freelancer</option>
                <option value="2" class="text-gray-900 bg-white">Usuario</option>
                <option value="3" class="text-gray-900 bg-white">Empresa</option>
              </select>
            </div>
          
            <!-- Foto -->
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-amber-50 mb-1">
                Foto de perfil
              </label>
            
              <label
                for="photo"
                class="flex items-center justify-between
                       px-4 py-2 rounded-xl
                       bg-white border border-gray-300
                       cursor-pointer hover:bg-gray-50 transition"
              >
                <span id="fileText" class="text-gray-500">
                  Selecciona una imagen
                </span>
              
                <span class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm">
                  Subir
                </span>
              </label>
            
              <input
                id="photo"
                type="file"
                accept="image/*"
                class="hidden"
              />
            </div>
          
            <!-- FREELANCER -->
            <div id="freelancerSection" class="hidden md:col-span-2  grid-cols-1 md:grid-cols-2 gap-4">
              <h3 class="md:col-span-2 text-xl font-semibold text-amber-50">Perfil Freelancer</h3>
            
              <div class="md:col-span-2">
                <label class="block text-sm font-medium text-amber-50">Descripción</label>
                <textarea name="description" rows="3" class="w-full px-4 py-2 rounded-lg bg-white border border-gray-300 focus:ring-2 focus:ring-indigo-400 focus:border-indigo-500"></textarea>
              </div>
            
              <div>
                <label class="block text-sm font-medium text-amber-50">Profesión</label>
                <input type="text" class="w-full px-5 py-2 rounded-xl bg-white border" />
              </div>
            
              <div>
                <label class="block text-sm font-medium text-amber-50">Años experiencia</label>
                <input type="number" class="w-full px-5 py-2 rounded-xl bg-white border" />
              </div>
            </div>
          
            <!-- EMPRESA -->
            <div id="companySection" class="display: none md:col-span-2 display: grid grid-cols-2 gap-4">
              <h3 class="col-span-2 text-xl font-semibold text-amber-50">Empresa</h3>
            
              <div>
                <label class="block text-sm font-medium text-amber-50">NIT</label>
                <input type="text" class="w-full px-5 py-2 rounded-xl bg-white border" />
              </div>
            
              <div>
                <label class="block text-sm font-medium text-amber-50">Dirección</label>
                <input type="text" class="w-full px-5 py-2 rounded-xl bg-white border" />
              </div>
            </div>
          
            <!-- BOTÓN -->
            <div class="md:col-span-2">
              <button type="submit"
                class="w-full py-2 bg-gray-900 text-white rounded-xl font-bold">
                Crear cuenta
              </button>
            </div>
          </form>

        <p class="text-center mt-4 text-amber-50 text-sm">
          ¿Olvidaste tu contraseña?
          <a href="/RecuperarContraseña" class="text-indigo-700 font-medium hover:underline">
            Recuperar contraseña
          </a>
        </p>

        <div class="text-center mt-6 text-amber-50">
          ¿Ya tienes cuenta?
          <a href="/login" class="text-indigo-800 font-medium hover:underline">
            Inicia sesión
          </a>
        </div>

      </div>
    </div>
  </div>

</MainLayout>

<!-- JS EXTERNO -->
<script type="module" src="/src/scripts/register.js"></script>