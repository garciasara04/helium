---
import HomeLayout from "../layouts/HomeLayout.astro"
---

<HomeLayout title="inico freelancer">
    <main class="flex-1 max-w-7xl mx-auto px-6 py-8 bg-heli-bg text-heli-text">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-10">
        <div class="bg-heli-card p-6 rounded-xl border border-slate-700/50">
        <div class="text-heli-primary text-3xl font-bold mb-1">3</div>
        <div class="text-slate-400">Proyectos Activos</div>
        <div class="text-slate-500 text-sm mt-2">Entrega: 3 días</div>
        </div>
        <div class="bg-heli-card p-6 rounded-xl border border-slate-700/50">
        <div class="text-heli-primary text-3xl font-bold mb-1">4.9 ★</div>
        <div class="text-slate-400">Calificación promedio</div>
        </div>
        <div class="bg-heli-card p-6 rounded-xl border border-slate-700/50">
        <div class="text-heli-primary text-3xl font-bold mb-1">5</div>
        <div class="text-slate-400">Mensajes nuevos</div>
        </div>
    </div>

    <!-- Proyectos Activos -->
    <section class="mb-12">
        <h2 class="text-2xl font-bold mb-5 text-white">Proyectos Activos</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        
        <!-- Proyecto 1 -->
        <div class="bg-heli-card p-6 rounded-xl border border-slate-700/50 hover:border-heli-primary/50 transition-all">
            <div class="flex items-start gap-4">
            <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=80&h=80&fit=crop" alt="Landing" class="w-16 h-16 rounded-lg object-cover">
            <div class="flex-1">
                <h3 class="font-semibold text-lg mb-1">Landing Page Empresa</h3>
                <p class="text-slate-400 text-sm mb-3">Cliente: Sara López</p>
                <div class="mb-4">
                <div class="w-full bg-slate-700 rounded-full h-2.5">
                    <div class="bg-heli-primary h-2.5 rounded-full w-[65%]"></div>
                </div>
                </div>
                <div class="flex justify-between items-center">
                <span class="text-sm text-green-400">En Progreso</span>
                <button class="bg-heli-primary/90 hover:bg-heli-primary text-white px-5 py-2 rounded-lg text-sm font-medium transition">
                    Ver Detalles
                </button>
                </div>
            </div>
            </div>
        </div>

        <!-- Proyecto 2 -->
        <div class="bg-heli-card p-6 rounded-xl border border-slate-700/50 hover:border-heli-primary/50 transition-all">
            <div class="flex items-start gap-4">
            <img src="https://images.unsplash.com/photo-1551650975-60cb6f7b6a7e?w=80&h=80&fit=crop" alt="App" class="w-16 h-16 rounded-lg object-cover">
            <div class="flex-1">
                <h3 class="font-semibold text-lg mb-1">App Móvil e-Commerce</h3>
                <p class="text-slate-400 text-sm mb-3">Cliente: Jose Martínez</p>
                <div class="mb-4">
                <div class="w-full bg-slate-700 rounded-full h-2.5">
                    <div class="bg-yellow-500 h-2.5 rounded-full w-[15%]"></div>
                </div>
                </div>
                <div class="flex justify-between items-center">
                <span class="text-sm text-yellow-400">Pendiente</span>
                <button class="bg-heli-primary/90 hover:bg-heli-primary text-white px-5 py-2 rounded-lg text-sm font-medium transition">
                    Ver Detalles
                </button>
                </div>
            </div>
            </div>
        </div>

        </div>
    </section>

    <!-- Busca Proyectos (reemplazo del estado del perfil) -->
    <section class="mb-10">
        <h2 class="text-2xl font-bold mb-5 text-white">Busca Proyectos</h2>
        <div class="bg-heli-card p-8 rounded-xl border border-slate-700/50">
        <div class="max-w-md mx-auto text-center">
            <div class="text-6xl mb-6">🔍</div>
            <h3 class="text-2xl font-bold mb-4">¡Encuentra tu próximo proyecto!</h3>
            <p class="text-slate-400 mb-8">
            Mira las oportunidades disponibles ahora mismo y envía tu propuesta en minutos.
            </p>
            <button class="bg-heli-primary hover:bg-heli-primary-dark text-white px-10 py-5 rounded-xl font-semibold text-lg shadow-lg shadow-indigo-900/40 transition-all w-full sm:w-auto">
            Ver Oportunidades Disponibles
            </button>
        </div>
        </div>
    </section>

    </main> 
    
</HomeLayout>