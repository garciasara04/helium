---
// src/pages/catalogo.astro
import HomeLayout from '../layouts/HomeLayout.astro';

// Datos de ejemplo (en producción: desde tu API Laravel)
const freelancers = [
  {
    id: 1,
    name: "Talal",
    level: "Nivel 2",
    rating: 4.9,
    reviews: 17,
    title: "Crearé un sistema de trading automatizado impulsado por IA",
    price: "Desde USD 2,095",
    image: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=400",
    tags: ["IA", "Trading", "Python", "Automatización"],
    videoConsult: true
  },
  {
    id: 2,
    name: "Mian Jim",
    level: "Nivel 2",
    rating: 5.0,
    reviews: 35,
    title: "Crearé aplicaciones web full stack de IA con React, Node y Django",
    price: "Desde USD 3,000",
    image: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=400",
    tags: ["React", "Node.js", "Django", "Full Stack", "IA"],
    videoConsult: true
  },
  {
    id: 3,
    name: "Geeksoo Agency",
    level: "Nivel 2",
    rating: 5.0,
    reviews: 9,
    title: "Nuestra agencia arreglará la codificación vibe para apps con IA",
    price: "Desde USD 750",
    image: "https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=400",
    tags: ["Mobile Apps", "IA", "Agencia", "Chatbots"],
    videoConsult: true
  },
  // Agrega más freelancers aquí...
];
---

<HomeLayout title="Catálogo - Helium">

  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-10 lg:py-16">
    <!-- Título principal -->
    <div class="mb-10">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white">
        Todos los catálogos
      </h1>
      <p class="text-xl text-slate-400 mt-3">
        Explora freelancers verificados y proyectos disponibles
      </p>
    </div>

    <!-- Grid de freelancers -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {freelancers.map(f => (
        <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-purple-600 transition-all duration-300 group shadow-lg hover:shadow-purple-900/20">
          {/* Imagen / banner */}
          <div class="h-48 relative bg-linear-to-br from-slate-800 to-slate-900">
            <img 
              src={f.image} 
              alt={f.name}
              class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition"
            />
            {f.videoConsult && (
              <div class="absolute top-3 right-3 bg-purple-700 text-white text-xs font-bold px-3 py-1 rounded-full">
                Video consulta
              </div>
            )}
          </div>

          {/* Info */}
          <div class="p-6">
            <div class="flex items-center justify-between mb-3">
              <h3 class="text-xl font-bold text-white group-hover:text-purple-400 transition">
                {f.name}
              </h3>
              <span class="text-sm text-purple-400 font-medium">{f.level}</span>
            </div>

            <p class="text-slate-300 mb-4 line-clamp-2">
              {f.title}
            </p>

            <div class="flex items-center gap-2 mb-4">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="text-slate-400 text-sm">{f.rating} ({f.reviews})</span>
            </div>

            <div class="flex flex-wrap gap-2 mb-6">
              {f.tags.map(tag => (
                <span class="text-xs px-3 py-1 bg-slate-800 rounded-full text-purple-300">
                  {tag}
                </span>
              ))}
            </div>

            <div class="flex items-center justify-between">
              <span class="text-xl font-bold text-purple-400">
                {f.price}
              </span>
              <!-- ¡Aquí está el cambio! -->
              <a 
                href="/perfilFreelance"   
                class="px-6 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition"
              >
                Ver perfil
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* Ver más */}
    <div class="mt-16 text-center">
      <button class="px-10 py-4 bg-purple-700 hover:bg-purple-600 text-white font-bold rounded-xl transition shadow-lg shadow-purple-900/30">
        Ver más freelancers →
      </button>
    </div>
  </div>
</HomeLayout>