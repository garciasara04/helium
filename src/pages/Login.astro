---
import PublicLayout from "../layouts/PublicLayout.astro";
import backgroundImage from "../assets/image.png";
---

<PublicLayout>
  <div
    class="min-h-screen bg-cover bg-center bg-no-repeat relative"
    style={`background-image: url(${backgroundImage.src});`}
  >
    <div
      class="absolute inset-0 bg-cover bg-center bg-no-repeat transform scale-x-[-1]"
      style={`background-image: url(${backgroundImage.src});`}
    ></div>

    <div class="absolute inset-0 bg-black/25"></div>

    <div class="relative min-h-screen flex justify-end pt-8 pb-20 px-6 md:px-10 lg:px-12 xl:px-24 z-10">
      <div
        id="loginCard"
        class="w-full md:w-1/2 lg:w-1/2 max-w-2xl
        bg-gray-400/35 backdrop-blur-sm rounded-3xl shadow-2xl
        p-10 md:p-14 border border-gray-300/60
        opacity-0 translate-y-6 transition-all duration-700"
      >
        <h1 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-4">
          Inicio de Sesión
        </h1>

        <form id="loginForm" class="space-y-7" novalidate>
          <div>
            <label for="email" class="block text-sm font-medium text-amber-50 mb-2">
              Correo electrónico
            </label>

            <input
              type="email"
              id="email"
              name="email"
              class="w-full px-5 py-2 rounded-xl bg-white border border-gray-300 text-gray-900"
              required
              autocomplete="email"
            />
            <p id="loginEmailError" class="hidden mt-2 text-xs text-red-200"></p>
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-amber-50 mb-2">
              Contraseña
            </label>

            <input
              type="password"
              id="password"
              name="password"
              class="w-full px-5 py-2 rounded-xl bg-white border border-gray-300 text-gray-900"
              required
              minlength="8"
              autocomplete="current-password"
            />
            <p id="loginPasswordError" class="hidden mt-2 text-xs text-red-200"></p>
          </div>

          <div class="pt-4">
            <button
              id="loginSubmit"
              type="submit"
              class="w-full py-2 px-6 bg-gray-900 text-white font-medium text-lg rounded-xl hover:bg-gray-800 transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-gray-900 focus:ring-offset-2"
            >
              Ingresar
            </button>
          </div>

          <p id="loginFeedback" class="hidden mt-3 text-sm font-medium rounded-lg border px-3 py-2"></p>
        </form>

        <p class="text-center mt-4 text-gray-200 text-sm">
          ¿Olvidaste tu contraseña?
          <a href="/recuperar-contrasena" class="text-indigo-900 font-medium hover:underline">
            Recuperar contraseña
          </a>
        </p>
      </div>
    </div>
  </div>

  <script>
    const loginForm = document.getElementById("loginForm");
    const loginFeedback = document.getElementById("loginFeedback");
    const loginSubmit = document.getElementById("loginSubmit");
    const loginEmail = document.getElementById("email");
    const loginPassword = document.getElementById("password");
    const loginEmailError = document.getElementById("loginEmailError");
    const loginPasswordError = document.getElementById("loginPasswordError");

    function setLoginFeedback(message, tone = "error") {
      if (!loginFeedback) return;

      if (!message) {
        loginFeedback.textContent = "";
        loginFeedback.className = "hidden mt-3 text-sm font-medium rounded-lg border px-3 py-2";
        return;
      }

      const base = "mt-3 text-sm font-medium rounded-lg border px-3 py-2";
      if (tone === "success") {
        loginFeedback.className = `${base} border-emerald-500/40 bg-emerald-900/20 text-emerald-200`;
      } else if (tone === "warning") {
        loginFeedback.className = `${base} border-amber-500/40 bg-amber-900/20 text-amber-200`;
      } else {
        loginFeedback.className = `${base} border-rose-500/40 bg-rose-900/20 text-rose-200`;
      }

      loginFeedback.textContent = message;
    }

    function setFieldError(inputEl, errorEl, message) {
      if (!inputEl || !errorEl) return;
      if (!message) {
        errorEl.textContent = "";
        errorEl.classList.add("hidden");
        inputEl.classList.remove("border-red-500");
        return;
      }
      errorEl.textContent = message;
      errorEl.classList.remove("hidden");
      inputEl.classList.add("border-red-500");
    }

    function validateLoginForm() {
      let valid = true;
      const email = String(loginEmail?.value || "").trim();
      const password = String(loginPassword?.value || "").trim();
      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

      setFieldError(loginEmail, loginEmailError, "");
      setFieldError(loginPassword, loginPasswordError, "");

      if (!email) {
        setFieldError(loginEmail, loginEmailError, "Ingresa tu correo electrónico.");
        valid = false;
      } else if (!emailOk) {
        setFieldError(loginEmail, loginEmailError, "Ingresa un correo válido.");
        valid = false;
      }

      if (!password) {
        setFieldError(loginPassword, loginPasswordError, "Ingresa tu contraseña.");
        valid = false;
      } else if (password.length < 8) {
        setFieldError(loginPassword, loginPasswordError, "La contraseña debe tener al menos 8 caracteres.");
        valid = false;
      }

      return valid;
    }

    loginEmail?.addEventListener("input", () => setFieldError(loginEmail, loginEmailError, ""));
    loginPassword?.addEventListener("input", () => setFieldError(loginPassword, loginPasswordError, ""));

    loginForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      setLoginFeedback("");

      if (!validateLoginForm()) {
        setLoginFeedback("Revisa los campos resaltados.", "warning");
        return;
      }

      const formdata = new FormData(loginForm);

      try {
        if (loginSubmit) {
          loginSubmit.disabled = true;
          loginSubmit.textContent = "Ingresando...";
          loginSubmit.classList.add("opacity-70", "cursor-not-allowed");
        }

        const response = await fetch("http://127.0.0.1:8000/api/login", {
          method: "POST",
          headers: {
            Accept: "application/json",
          },
          body: formdata,
        });

        const data = await response.json().catch(() => ({}));

        if (data.token) {
          if (data.user.is_active) {
            localStorage.setItem("token", data.token);
            localStorage.setItem("user", JSON.stringify(data.user));

            if (data.user.role_id === 1) window.location.href = "dashboard/cliente";
            if (data.user.role_id === 2) window.location.href = "dashboard/freelance";
            if (data.user.role_id === 3) window.location.href = "dashboard/company";
            if (data.user.role_id === 4) window.location.href = "dashboard/admin";
          } else {
            setLoginFeedback("Su cuenta ha sido suspendida", "error");
          }
        } else {
          setLoginFeedback("Credenciales incorrectas", "error");
        }
      } catch (error) {
        console.log("error", error);
        setLoginFeedback("Error de conexión con el servidor.", "error");
      } finally {
        if (loginSubmit) {
          loginSubmit.disabled = false;
          loginSubmit.textContent = "Ingresar";
          loginSubmit.classList.remove("opacity-70", "cursor-not-allowed");
        }
      }
    });
  </script>
</PublicLayout>

<script type="module" src="/src/js/auth/login.js"></script>
