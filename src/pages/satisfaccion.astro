---
import PublicLayout from "../layouts/PublicLayout.astro";
import GarantiaSection from "../components/sections/GarantiaSection.astro";
import SidebarEnlaces from "../components/ui/SidebarEnlaces.astro";
---

<PublicLayout >
  <main class="min-h-screen bg-slate-950 text-purple-600">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-12">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
        <div class="lg:col-span-3 space-y-12">
          
          <section class="text-center border-b border-slate-800 pb-10">
            <h1 class="text-4xl font-bold mb-4">
              Satisfacción del Cliente
            </h1>
            
            <p class="text-slate-400 max-w-2xl mx-auto">
              En Helium conectamos empresas y freelancers para desarrollar proyectos
              digitales de alta calidad. Nuestro objetivo es ofrecer una experiencia
              segura, transparente y profesional para todos los usuarios.
            </p>
          </section>
          
          <GarantiaSection id="compromiso" title="Nuestro compromiso">
            <p class="text-slate-300">
              Helium trabaja constantemente para garantizar una experiencia
              profesional entre clientes, empresas y freelancers.
            </p>
            
            <p class="text-slate-300 mt-4">
              Nuestro sistema permite contratar servicios digitales de manera segura,
              con comunicación directa y seguimiento del proyecto.
            </p>
          
          </GarantiaSection>

          <GarantiaSection id="calidad" title="Calidad del servicio">
            <ul class="list-disc pl-6 space-y-3 text-slate-300">
              <li>Freelancers verificados.</li>
              <li>Perfil profesional con experiencia.</li>
              <li>Sistema de calificaciones.</li>
              <li>Seguimiento del proyecto.</li>
              <li>Comunicación directa cliente–freelancer.</li>
            </ul>
          </GarantiaSection>

          <GarantiaSection id="experiencia" title="Experiencia del usuario">
            <p class="text-slate-300">
              La plataforma Helium está diseñada para que empresas y clientes
              encuentren fácilmente al freelancer adecuado para cada proyecto.
            </p>
          </GarantiaSection>

          <GarantiaSection id="mejoras" title="Mejora continua">
            <ul class="list-disc pl-6 space-y-3 text-slate-300">
              <li>Escuchamos el feedback de los usuarios.</li>
              <li>Actualizamos constantemente la plataforma.</li>
              <li>Agregamos nuevas herramientas para facilitar la contratación.</li>
            </ul>
          </GarantiaSection>
        </div>
        
        <div class="lg:col-span-1">
          <div class="sticky top-8">
            <SidebarEnlaces />
          </div>
        </div>
      
      </div>

    </div>
  
  </main>

</PublicLayout>