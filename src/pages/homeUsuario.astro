---
import HomeLayout from '../layouts/HomeLayout.astro';

---
<HomeLayout title="">
  <!-- MAIN -->
  <main class="flex-1 p-8">

    <!-- NAVBAR SUPERIOR -->
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold">
        Bienvenida de nuevo, Sara 👋
      </h1>

    <!-- STATS -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">

      <div class="bg-white p-6 rounded-2xl shadow">
        <p class="text-gray-500">Servicios</p>
        <h2 class="text-2xl font-bold">12</h2>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <p class="text-gray-500">Pedidos activos</p>
        <h2 class="text-2xl font-bold">3</h2>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <p class="text-gray-500">Ganancias</p>
        <h2 class="text-2xl font-bold">$540</h2>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <p class="text-gray-500">Calificación</p>
        <h2 class="text-2xl font-bold">⭐ 4.9</h2>
      </div>

    </div>

    <!-- ACTIVIDAD RECIENTE -->
    <div class="bg-white p-6 rounded-2xl shadow mb-10">
      <h2 class="text-xl font-bold mb-4">Actividad reciente</h2>
      <ul class="space-y-3">
        <li class="flex justify-between border-b pb-2">
          <span>Diseño de Landing Page</span>
          <span class="text-sm text-yellow-500">En progreso</span>
        </li>
        <li class="flex justify-between border-b pb-2">
          <span>Logo corporativo</span>
          <span class="text-sm text-green-500">Completado</span>
        </li>
        <li class="flex justify-between">
          <span>Edición de video promocional</span>
          <span class="text-sm text-blue-500">Entregado</span>
        </li>
      </ul>
    </div>

    <!-- SERVICIOS RECOMENDADOS -->
    <div>
      <h2 class="text-xl font-bold mb-6">Servicios recomendados</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white rounded-2xl shadow hover:shadow-xl transition p-6">
          <div class="h-32 bg-gray-200 rounded-xl mb-4"></div>
          <h3 class="font-bold mb-2">Desarrollo Web Profesional</h3>
          <p class="text-green-600 font-semibold">Desde $120</p>
        </div>

        <div class="bg-white rounded-2xl shadow hover:shadow-xl transition p-6">
          <div class="h-32 bg-gray-200 rounded-xl mb-4"></div>
          <h3 class="font-bold mb-2">Diseño UX/UI Moderno</h3>
          <p class="text-green-600 font-semibold">Desde $95</p>
        </div>

        <div class="bg-white rounded-2xl shadow hover:shadow-xl transition p-6">
          <div class="h-32 bg-gray-200 rounded-xl mb-4"></div>
          <h3 class="font-bold mb-2">Marketing Digital</h3>
          <p class="text-green-600 font-semibold">Desde $80</p>
        </div>

      </div>
    </div>

  </main>



</HomeLayout>