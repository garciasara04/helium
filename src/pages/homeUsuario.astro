---
import HomeLayout from '../layouts/HomeLayout.astro';

// Datos de ejemplo (puedes reemplazar con datos reales desde API o props)
const recommendedFreelancers = [
  { id: 1,name: "Ana Martínez", rating: 4.9, reviews: 342, image: "/ana.jpg" },
  { id: 2,name: "Carlos Gómez", rating: 4.8, reviews: 215, image: "/images/carlos.jpg" },
  { id: 3, name: "Laura Herrera", rating: 5.0, reviews: 189, image: "/images/laura.jpg" },
  { id: 4,name: "Diego Torres", rating: 4.7, reviews: 456, image: "/images/diego.jpg" },
];

const activeProjects = [
  { title: "Rediseño sitio web Helium", freelancer: "Ana Martínez", progress: 68 },
  { title: "Contenido blog + SEO 2026", freelancer: "Laura Herrera", progress: 92 },
];

const popularServices = [
  { title: "Logo Profesional", image: "/images/logo-service.jpg" },
  { title: "Edición de Video", image: "/images/video-service.jpg" },
  { title: "Posicionamiento SEO", image: "/images/seo-service.jpg" },
  { title: "Diseño Web Moderno", image: "/images/web-service.jpg" },
];
---

<HomeLayout title="Inicio - Helium">
  <!-- Hero con imagen de fondo y contenido perfectamente centrado -->
  <section 
    class="relative min-h-[80vh] md:min-h-screen bg-cover bg-center bg-no-repeat flex items-center justify-center"
    style="background-image: url('/hero.jpg');"
  >
    <!-- Overlay suave (opcional, pero ayuda a que el texto se lea bien) -->
    <div class="absolute inset-0 bg-black/40 md:bg-black/50"></div>

    <!-- Contenido centrado en la mitad de la sección -->
    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 drop-shadow-2xl">
        Encuentra el talento perfecto
      </h2>
      <p class="text-lg md:text-xl lg:text-2xl text-slate-200 mb-10 max-w-3xl mx-auto drop-shadow-lg">
        Conecta con freelancers profesionales y lleva tu proyecto al siguiente nivel.
      </p>
      <a 
        href="/nuestrosServicios" 
        class="inline-block bg-purple-700 hover:bg-purple-600 px-8 md:px-12 py-4 md:py-5 rounded-xl font-bold text-white text-lg md:text-xl transition shadow-xl shadow-purple-900/40 hover:shadow-purple-700/60 transform hover:scale-105"
      >
        Explorar servicios →
      </a>
    </div>
  </section>

  
  <section class="py-16 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-white mb-10">
        Recomendados para ti
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {recommendedFreelancers.map(f => (
          <div class="bg-slate-900 rounded-xl overflow-hidden border border-slate-800 hover:border-purple-600 transition-all group">
            <img 
              src={f.image} 
              alt={f.name}
              class="w-full h-64 object-cover"
            />
            <div class="p-5 text-center">
              <h3 class="text-xl font-bold text-white group-hover:text-purple-400 transition">
                {f.name}
              </h3>
              <div class="flex justify-center items-center gap-1 mt-2 text-yellow-400">
                <span class="text-lg">★★★★★</span>
                <span class="text-slate-300 text-sm">{f.rating} ({f.reviews})</span>
              </div>

              <!-- ¡Aquí está el cambio! Botón convertido en enlace dinámico con ID -->
              <a 
                href="/perfilFreelance"
                class="mt-5 w-full py-3 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition block text-center"
              >
                Ver perfil
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>



  <!-- Tus proyectos activos -->
  <section class="py-16 bg-slate-900">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-white mb-10">
        Tus proyectos activos
      </h2>

      <div class="space-y-6">
        {activeProjects.map(p => (
          <div class="bg-slate-800 rounded-xl p-6 border border-slate-700">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
              <div>
                <h3 class="text-xl font-bold text-white">{p.title}</h3>
                <p class="text-slate-400 mt-2">con {p.freelancer}</p>
              </div>
              <div class="w-full md:w-64">
                <div class="bg-slate-700 rounded-full h-3 overflow-hidden">
                  <div 
                    class="bg-purple-600 h-3 rounded-full transition-all"
                    style={`width: ${p.progress}%`}
                  ></div>
                </div>
                <div class="text-right mt-2 text-purple-400 font-medium">
                  {p.progress}%
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Servicios populares -->
  <section class="py-16 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-white mb-10">
        Servicios populares
      </h2>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {popularServices.map(s => (
          <div class="bg-slate-900 rounded-xl overflow-hidden border border-slate-800 hover:border-purple-600 transition group">
            <img 
              src={s.image} 
              alt={s.title}
              class="w-full h-48 object-cover"
            />
            <div class="p-5 text-center">
              <h3 class="text-xl font-bold text-white group-hover:text-purple-400 transition">
                {s.title}
              </h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tus últimas búsquedas (adaptado a oscuro) -->
  <section class="py-16 bg-slate-900">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-white mb-8">
        Tus últimas búsquedas
      </h2>

      <div class="flex flex-wrap gap-4">
        <div class="bg-slate-800 px-8 py-5 rounded-xl border border-slate-700 hover:border-purple-600 transition">
          Desarrollo Web en Astro
        </div>
        <div class="bg-slate-800 px-8 py-5 rounded-xl border border-slate-700 hover:border-purple-600 transition">
          Diseño de Logo Profesional
        </div>
      </div>
    </div>
  </section>

  <!-- Las 3 tarjetas grandes -->
  <section class="py-16 bg-slate-950">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-8">
      <a href="/satisfaccion" class="bg-purple-900/40 border border-purple-700/50 p-10 rounded-2xl text-white hover:bg-purple-900/60 hover:scale-[1.02] transition-all duration-300 shadow-xl">
        <h3 class="text-2xl font-bold mb-4">Satisfacción garantizada</h3>
        <p class="text-purple-200">Garantizamos la mejor experiencia para nuestros usuarios.</p>
      </a>

      <a href="/red" class="bg-purple-900/40 border border-purple-700/50 p-10 rounded-2xl text-white hover:bg-purple-900/60 hover:scale-[1.02] transition-all duration-300 shadow-xl">
        <h3 class="text-2xl font-bold mb-4">Tu red de freelancers</h3>
        <p class="text-purple-200">Conecta y administra todos tus freelancers en un solo lugar.</p>
      </a>

      <a href="/metodosPagos" class="bg-purple-900/40 border border-purple-700/50 p-10 rounded-2xl text-white hover:bg-purple-900/60 hover:scale-[1.02] transition-all duration-300 shadow-xl">
        <h3 class="text-2xl font-bold mb-4">Métodos de pago</h3>
        <p class="text-purple-200">Pagos seguros y múltiples opciones adaptadas a ti.</p>
      </a>
    </div>
  </section>

</HomeLayout>