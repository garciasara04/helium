---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="admin">
  <section class="max-w-7xl mx-auto px-6 py-8 space-y-6">
    <div class="flex items-center justify-between gap-4">
      <h1 class="text-2xl font-bold">Perfil de usuario</h1>
      <a href="/dashboard/admin/usuarios" class="text-slate-300 hover:text-white transition">
        Volver a usuarios
      </a>
    </div>

    <div id="detailAlert" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

    <div class="grid lg:grid-cols-3 gap-6">
      <article class="lg:col-span-2 bg-slate-900 border border-slate-800 p-6 rounded-xl">
        <div class="flex items-center gap-4 mb-4">
          <img
            id="userProfilePhoto"
            src="https://via.placeholder.com/120"
            alt="Foto usuario"
            class="w-16 h-16 rounded-full object-cover border border-slate-700"
          />
          <h2 class="text-lg font-semibold">Informacion general</h2>
        </div>

        <div id="userInfoSkeleton" class="grid sm:grid-cols-2 gap-4">
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
        </div>

        <dl id="userInfo" class="hidden grid sm:grid-cols-2 gap-4 text-sm"></dl>
      </article>

      <aside class="bg-slate-900 border border-slate-800 p-6 rounded-xl">
        <h2 class="text-lg font-semibold mb-4">Acciones</h2>
        <p id="statusHelp" class="text-slate-400 text-sm mb-5">Cargando estado...</p>

        <div class="space-y-3">
          <button
            id="btnActivate"
            type="button"
            class="w-full bg-emerald-600 hover:bg-emerald-500 px-4 py-2 rounded-lg transition disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Activar cuenta
          </button>

          <button
            id="btnDeactivate"
            type="button"
            class="w-full bg-rose-600 hover:bg-rose-500 px-4 py-2 rounded-lg transition disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Desactivar cuenta
          </button>
        </div>
      </aside>
    </div>

    <article class="bg-slate-900 border border-slate-800 p-6 rounded-xl">
      <h2 class="text-lg font-semibold mb-4">Resumen del perfil</h2>
      <div id="profileBlocks" class="grid md:grid-cols-3 gap-4">
        <div class="h-24 bg-slate-700/70 rounded-xl animate-pulse"></div>
        <div class="h-24 bg-slate-700/70 rounded-xl animate-pulse"></div>
        <div class="h-24 bg-slate-700/70 rounded-xl animate-pulse"></div>
      </div>
    </article>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/admin/admin-user-detail.js"></script>
