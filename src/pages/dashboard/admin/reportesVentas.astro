---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

const ventas = [
  { mes: "Enero", ingresos: 4200 },
  { mes: "Febrero", ingresos: 5300 },
  { mes: "Marzo", ingresos: 6100 }
];
---

<DashboardLayout title="Reportes de ventas" userRole="admin">
  <h2 class="text-xl font-semibold mb-6">
    Ingresos por mes
  </h2>

  <div class="space-y-4">
    {ventas.map(v => (
      <div class="bg-slate-900 border border-slate-800 p-4 rounded-lg flex justify-between">
        <span>{v.mes}</span>

        <span class="font-bold text-green-400">
          ${v.ingresos}
        </span>
      </div>
    ))}
  </div>
</DashboardLayout>