---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="admin">
  <section class="max-w-7xl mx-auto px-6 py-8 space-y-6">
    <h1 class="text-2xl font-bold">Monitoreo de reputacion</h1>

    <div id="reputationAlert" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

    <div class="grid xl:grid-cols-2 gap-6">
      <section class="bg-slate-900 border border-slate-800 p-6 rounded-xl">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-semibold">Freelancers con peor reputacion (top 10)</h2>
          <a href="/dashboard/admin/usuarios" class="text-indigo-400 hover:underline text-sm">Ver todos</a>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="text-slate-400 border-b border-slate-800">
              <tr>
                <th class="py-2 pr-3">Nombre</th>
                <th class="py-2 pr-3">Rating promedio</th>
                <th class="py-2 pr-3">Reviews</th>
                <th class="py-2">Servicios</th>
              </tr>
            </thead>
            <tbody id="reputationFreelancersBody">
              <tr><td class="py-3 text-slate-400" colspan="4">Cargando freelancers...</td></tr>
            </tbody>
          </table>
        </div>
      </section>

      <section class="bg-slate-900 border border-slate-800 p-6 rounded-xl">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-semibold">Resenas (ultimas 10)</h2>
          <a href="/dashboard/admin/reviews" class="text-indigo-400 hover:underline text-sm">Ver todas</a>
        </div>

        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="text-slate-400 border-b border-slate-800">
              <tr>
                <th class="py-2 pr-3">Rating</th>
                <th class="py-2 pr-3">Servicio</th>
                <th class="py-2 pr-3">Comentario</th>
                <th class="py-2">Fecha</th>
              </tr>
            </thead>
            <tbody id="reputationReviewsBody">
              <tr><td class="py-3 text-slate-400" colspan="4">Cargando resenas...</td></tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/admin/admin-reputation.js"></script>

