---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="admin">
  <section class="max-w-7xl mx-auto px-6 py-8 space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold">Detalle de review</h1>
      <a href="/dashboard/admin/reviews" class="bg-slate-700 hover:bg-slate-600 px-4 py-2 rounded-lg transition">Volver</a>
    </div>

    <div id="reviewDetailAlert" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

    <div class="grid md:grid-cols-2 gap-8">
      <article class="bg-slate-900 border border-slate-800 p-6 rounded-xl">
        <h2 class="text-lg font-semibold text-slate-300 mb-6">Informacion de la review</h2>

        <div id="reviewInfoSkeleton" class="space-y-4">
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
        </div>

        <div id="reviewInfo" class="hidden space-y-4 text-sm">
          <div>
            <p class="text-slate-400">Usuario</p>
            <p id="reviewUser" class="text-white font-semibold">-</p>
          </div>
          <div>
            <p class="text-slate-400">Freelancer</p>
            <p id="reviewFreelancer" class="text-white font-semibold">-</p>
          </div>
          <div>
            <p class="text-slate-400">Servicio</p>
            <p id="reviewService" class="text-white">-</p>
          </div>
          <div>
            <p class="text-slate-400">Fecha</p>
            <p id="reviewDate" class="text-white">-</p>
          </div>
          <div>
            <p class="text-slate-400">Rating</p>
            <p id="reviewRating" class="font-bold">-</p>
          </div>
        </div>
      </article>

      <article class="bg-slate-900 border border-slate-800 p-6 rounded-xl">
        <h2 class="text-lg font-semibold text-slate-300 mb-6">Comentario</h2>
        <p id="reviewComment" class="text-slate-300 leading-relaxed">Cargando comentario...</p>
      </article>
    </div>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/admin/admin-review-detail.js"></script>
