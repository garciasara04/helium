---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

const stats = [
  { key: "clientes", label: "Clientes", href: "/dashboard/admin/usuarios" },
  { key: "freelancers", label: "Freelancers activos", href: "/dashboard/admin/usuarios" },
  { key: "empresas", label: "Empresas activas", href: "/dashboard/admin/usuarios" },
  { key: "servicios", label: "Servicios activos", href: "/dashboard/admin/servicios" },
  { key: "ordenes", label: "Ordenes", href: "/dashboard/admin/ordenes" },
  { key: "reviews", label: "Reviews", href: "/dashboard/admin/reviews" }
];
---

<DashboardLayout userRole="admin">

<div id="adminDashBoot" class="mb-8 space-y-5 transition-all duration-500">
  <div class="h-10 w-56 rounded-lg bg-slate-800/80 animate-pulse"></div>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-6">
    <div class="h-32 rounded-xl bg-slate-800/70 animate-pulse"></div>
    <div class="h-32 rounded-xl bg-slate-800/70 animate-pulse"></div>
    <div class="h-32 rounded-xl bg-slate-800/70 animate-pulse"></div>
    <div class="h-32 rounded-xl bg-slate-800/70 animate-pulse"></div>
    <div class="h-32 rounded-xl bg-slate-800/70 animate-pulse"></div>
    <div class="h-32 rounded-xl bg-slate-800/70 animate-pulse"></div>
  </div>
  <div class="h-72 rounded-2xl bg-slate-800/60 animate-pulse"></div>
</div>

<div id="adminDashContent" class="opacity-0 pointer-events-none transition-opacity duration-500">
<div class="mb-6 flex justify-end">
  <a href="/dashboard/admin/reviews" class="inline-flex items-center bg-purple-700 hover:bg-purple-600 px-4 py-2 rounded-lg text-sm font-medium transition">Gestion de reviews</a>
</div>
<section class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-6 mb-12" data-reveal-stagger>
{stats.map((stat) => (
<a
  href={stat.href}
  data-reveal-item
  class="bg-slate-900 border border-slate-800 p-6 rounded-xl hover:border-purple-500 transition block group reveal-item"
>
  <p class="text-slate-400 text-sm">
    {stat.label}
  </p>

  <p id={`stat-${stat.key}`} class="text-3xl font-bold text-white mt-2 group-hover:text-purple-400 transition">--</p>

  <span class="text-purple-400 text-sm mt-3 inline-block">
    Gestionar ->
  </span>
</a>
))}
</section>

<section class="mb-14 bg-slate-900 border border-slate-800 rounded-2xl p-6 reveal-item" data-reveal>
<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
  <div>
    <h2 class="text-2xl font-bold text-white">Salud del negocio</h2>
    <p class="text-slate-400 text-sm">Resumen operativo y financiero del periodo seleccionado.</p>
  </div>

  <div class="flex gap-2" id="healthRangeButtons">
    <button type="button" data-range="1" class="health-range-btn px-4 py-2 rounded-lg bg-slate-800 text-slate-300 border border-slate-700 hover:border-purple-500 cursor-pointer">Hoy</button>
    <button type="button" data-range="7" class="health-range-btn px-4 py-2 rounded-lg bg-purple-700 text-white border border-purple-600 cursor-pointer">7 dias</button>
    <button type="button" data-range="30" class="health-range-btn px-4 py-2 rounded-lg bg-slate-800 text-slate-300 border border-slate-700 hover:border-purple-500 cursor-pointer">30 dias</button>
  </div>
</div>

<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6" data-reveal-stagger>
  <div class="bg-slate-800/60 border border-slate-700 rounded-xl p-4 reveal-item" data-reveal-item>
    <p class="text-slate-400 text-xs uppercase tracking-wide">Ordenes totales</p>
    <p id="health-total-orders" class="text-2xl font-bold text-white mt-1">--</p>
  </div>
  <div class="bg-slate-800/60 border border-slate-700 rounded-xl p-4 reveal-item" data-reveal-item>
    <p class="text-slate-400 text-xs uppercase tracking-wide">Tasa de finalizacion</p>
    <p id="health-completion-rate" class="text-2xl font-bold text-green-400 mt-1">--</p>
  </div>
  <div class="bg-slate-800/60 border border-slate-700 rounded-xl p-4 reveal-item" data-reveal-item>
    <p class="text-slate-400 text-xs uppercase tracking-wide">Tasa de cancelacion</p>
    <p id="health-cancel-rate" class="text-2xl font-bold text-red-400 mt-1">--</p>
  </div>
  <div class="bg-slate-800/60 border border-slate-700 rounded-xl p-4 reveal-item" data-reveal-item>
    <p class="text-slate-400 text-xs uppercase tracking-wide">Ticket promedio</p>
    <p id="health-avg-ticket" class="text-2xl font-bold text-purple-300 mt-1">--</p>
  </div>
</div>

<div class="grid lg:grid-cols-3 gap-6" data-reveal-stagger>
  <div class="lg:col-span-2 bg-slate-800/40 border border-slate-700 rounded-xl p-4 reveal-item" data-reveal-item>
    <h3 class="text-white font-semibold mb-4">Distribucion de estados</h3>
    <div id="health-status-list" class="space-y-3"></div>
  </div>

  <div class="bg-slate-800/40 border border-slate-700 rounded-xl p-4 reveal-item" data-reveal-item>
    <h3 class="text-white font-semibold mb-4">Alertas</h3>
    <div id="health-alerts" class="space-y-3"></div>
  </div>
</div>

<div class="mt-6 bg-slate-800/40 border border-slate-700 rounded-xl p-4 reveal-item" data-reveal>
  <h3 class="text-white font-semibold mb-4">Comparativa por rango</h3>
  <div id="health-range-chart" class="grid md:grid-cols-3 gap-4">
    <div class="text-slate-400">Cargando comparativa...</div>
  </div>
</div>
</section>

<section class="reveal-item" data-reveal>
<h2 class="text-2xl font-bold text-white mb-6">
Servicios con peor puntuacion
</h2>

<div id="worstRatedServices" class="grid grid-cols-2 md:grid-cols-4 gap-6">
  <div class="col-span-full text-slate-400">Cargando servicios...</div>
</div>
</section>

<section class="mt-16 reveal-item" data-reveal>
<div class="flex items-center justify-between mb-6">
  <h2 class="text-2xl font-bold text-white">Reviews negativas recientes</h2>
  <a href="/dashboard/admin/reviews" class="text-purple-400 hover:underline text-sm">Ver todas</a>
</div>

<div id="negativeRecentReviews" class="grid md:grid-cols-3 gap-6">
  <div class="text-slate-400">Cargando reviews...</div>
</div>
</section>
</div>

<style>
  .reveal-item {
    opacity: 0;
    transform: translateY(14px) scale(0.985);
    transition: opacity 520ms ease, transform 520ms ease;
    will-change: opacity, transform;
  }

  .reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal-item {
      opacity: 1;
      transform: none;
      transition: none;
    }

    #adminDashContent {
      opacity: 1 !important;
      pointer-events: auto !important;
      transition: none !important;
    }

    #adminDashBoot {
      display: none !important;
    }
  }
</style>

<script type="module" src="/src/js/admin/admin-dashboard.js"></script>

</DashboardLayout>


