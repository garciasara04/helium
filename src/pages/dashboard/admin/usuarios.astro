---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="admin">
  <section class="max-w-7xl mx-auto px-6 py-8">
    <h1 class="text-2xl font-bold mb-6">Gestion de usuarios</h1>

    <div class="flex flex-wrap gap-4 mb-6">
      <input
        id="usersSearch"
        type="text"
        placeholder="Buscar por nombre, apellido o email..."
        class="bg-slate-800 border border-slate-700 rounded-lg px-4 py-2 min-w-[260px]"
      />

      <select id="usersRoleFilter" class="bg-slate-800 border border-slate-700 rounded-lg px-4 py-2">
        <option value="">Todos los roles</option>
        <option value="1">Cliente</option>
        <option value="2">Freelancer</option>
        <option value="3">Empresa</option>
        <option value="4">Admin</option>
      </select>
    </div>

    <div id="usersEmpty" class="text-center text-slate-400 py-8 border border-slate-800 rounded-xl mb-4 hidden">
      No se encontraron usuarios con esos filtros.
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
      <table class="w-full text-left">
        <thead class="bg-slate-800 text-slate-400">
          <tr>
            <th class="p-4">Nombre</th>
            <th class="p-4">Correo</th>
            <th class="p-4">Rol</th>
            <th class="p-4">Estado</th>
            <th class="p-4">Accion</th>
          </tr>
        </thead>

        <tbody id="usersTableBody"></tbody>
      </table>
    </div>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/admin/admin-users.js"></script>
