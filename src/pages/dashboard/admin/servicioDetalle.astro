---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="admin">
  <section class="max-w-7xl mx-auto px-6 py-8 space-y-6">
    <div class="flex items-center justify-between gap-3">
      <h1 class="text-2xl font-bold">Detalle del servicio</h1>
      <a href="/dashboard/admin/servicios" class="text-indigo-400 hover:underline">Volver a servicios</a>
    </div>

    <div id="serviceDetailAlert" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

    <div class="grid lg:grid-cols-3 gap-6">
      <article class="lg:col-span-2 bg-slate-900 border border-slate-800 rounded-xl p-6">
        <div class="flex items-center gap-4 mb-4">
          <img
            id="serviceMainPhoto"
            src="/image.png"
            alt="Foto del servicio"
            class="w-20 h-20 rounded-xl object-cover border border-slate-700"
          />
          <h2 class="text-lg font-semibold">Informacion basica</h2>
        </div>

        <div id="serviceInfoSkeleton" class="grid sm:grid-cols-2 gap-4">
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
        </div>

        <dl id="serviceInfo" class="hidden grid sm:grid-cols-2 gap-4 text-sm"></dl>
      </article>

      <aside class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold mb-4">Freelancer</h2>
        <div class="flex items-center gap-3 mb-3">
          <img
            id="serviceFreelancerPhoto"
            src="/logo.jpeg"
            alt="Foto freelancer"
            class="w-14 h-14 rounded-full object-cover border border-slate-700"
          />
          <div>
            <p id="serviceFreelancerName" class="font-semibold">-</p>
            <p id="serviceFreelancerEmail" class="text-slate-400 text-sm mt-1">-</p>
          </div>
        </div>
        <a id="serviceFreelancerLink" href="/dashboard/admin/usuarios" class="inline-block mt-1 text-indigo-400 hover:underline text-sm">Ver perfil</a>

        <div class="mt-6">
          <h3 class="text-sm text-slate-400 uppercase tracking-wide mb-2">Categoria</h3>
          <p id="serviceCategory" class="font-medium">-</p>
        </div>

        <div class="mt-6 border-t border-slate-800 pt-4">
          <p id="serviceActionHelp" class="text-slate-400 text-sm mb-3">Acciones del servicio</p>
          <div class="space-y-2">
            <button id="serviceBtnActivate" type="button" class="w-full bg-emerald-600 hover:bg-emerald-500 px-4 py-2 rounded-lg transition disabled:opacity-50 disabled:cursor-not-allowed">
              Activar servicio
            </button>
            <button id="serviceBtnDeactivate" type="button" class="w-full bg-rose-600 hover:bg-rose-500 px-4 py-2 rounded-lg transition disabled:opacity-50 disabled:cursor-not-allowed">
              Desactivar servicio
            </button>
          </div>
        </div>
      </aside>
    </div>

    <article class="bg-slate-900 border border-slate-800 rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-3">Descripcion</h2>
      <p id="serviceDescription" class="text-slate-300 whitespace-pre-line">-</p>
    </article>

    <article class="bg-slate-900 border border-slate-800 rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-4">Historial de resenas (ultimas 10)</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="text-slate-400 border-b border-slate-800">
            <tr>
              <th class="py-2 pr-3">Rating</th>
              <th class="py-2 pr-3">Comentario</th>
              <th class="py-2">Fecha</th>
            </tr>
          </thead>
          <tbody id="serviceReviewsBody">
            <tr><td class="py-3 text-slate-400" colspan="3">Cargando resenas...</td></tr>
          </tbody>
        </table>
      </div>
    </article>
  </section>
  <div id="deactivateServiceModal" class="hidden fixed inset-0 z-50">
    <div id="deactivateServiceBackdrop" class="absolute inset-0 bg-black/70"></div>
    <div class="relative z-10 min-h-full flex items-center justify-center p-4">
      <div class="w-full max-w-lg bg-slate-900 border border-slate-700 rounded-2xl p-6 shadow-2xl">
        <h3 class="text-lg font-semibold mb-2">Desactivar servicio</h3>
        <p class="text-slate-400 text-sm mb-4">Escribe el motivo de desactivacion. Este campo es obligatorio.</p>

        <textarea
          id="deactivateReasonInput"
          rows="4"
          placeholder="Ej: Incumple lineamientos de calidad del marketplace."
          class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-sm outline-none focus:border-rose-400"
        ></textarea>
        <p id="deactivateReasonError" class="hidden text-rose-300 text-xs mt-2">Debes escribir un motivo para continuar.</p>

        <div class="mt-5 flex justify-end gap-2">
          <button id="deactivateCancelBtn" type="button" class="bg-slate-700 hover:bg-slate-600 px-4 py-2 rounded-lg text-sm transition">Cancelar</button>
          <button id="deactivateConfirmBtn" type="button" class="bg-rose-600 hover:bg-rose-500 px-4 py-2 rounded-lg text-sm transition">Confirmar desactivacion</button>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script type="module" src="/src/js/admin/admin-service-detail.js"></script>



