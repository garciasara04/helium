---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="admin">
  <section class="max-w-7xl mx-auto px-6 py-8 space-y-6">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <h1 class="text-2xl font-bold">Reportes del sistema</h1>
      <select id="reportsRange" class="bg-slate-800 border border-slate-700 rounded-lg px-4 py-2">
        <option value="today">Hoy</option>
        <option value="7d" selected>Ultimos 7 dias</option>
        <option value="30d">Ultimos 30 dias</option>
      </select>
    </div>

    <div id="reportsAlert" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

    <section class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <article class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
        <p class="text-slate-400 text-sm">Ordenes</p>
        <p id="reportTotalOrders" class="text-2xl font-bold mt-1">-</p>
      </article>
      <article class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
        <p class="text-slate-400 text-sm">Finalizacion</p>
        <p id="reportCompletionRate" class="text-2xl font-bold mt-1">-</p>
      </article>
      <article class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
        <p class="text-slate-400 text-sm">Cancelacion</p>
        <p id="reportCancellationRate" class="text-2xl font-bold mt-1">-</p>
      </article>
      <article class="bg-slate-900 border border-slate-800 p-4 rounded-xl">
        <p class="text-slate-400 text-sm">Ticket promedio</p>
        <p id="reportAvgTicket" class="text-2xl font-bold mt-1">-</p>
      </article>
    </section>

    <section class="grid xl:grid-cols-2 gap-6">
      <article class="bg-slate-900 border border-slate-800 rounded-xl p-5">
        <h2 class="text-lg font-bold mb-4">Distribucion por estado</h2>
        <div id="reportsStatusBars" class="space-y-3"></div>
      </article>

      <article class="bg-slate-900 border border-slate-800 rounded-xl p-5">
        <h2 class="text-lg font-bold mb-4">Comparativo por rango</h2>
        <div id="reportsRangeBars" class="space-y-3"></div>
      </article>
    </section>

    <section>
      <h2 class="text-xl font-bold mb-3">Ordenes recientes</h2>
      <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
        <table class="w-full text-left">
          <thead class="bg-slate-800 text-slate-400">
            <tr>
              <th class="p-4">ID</th>
              <th class="p-4">Cliente</th>
              <th class="p-4">Freelancer</th>
              <th class="p-4">Servicio</th>
              <th class="p-4">Monto</th>
              <th class="p-4">Estado</th>
            </tr>
          </thead>
          <tbody id="reportsRecentOrders"></tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="text-xl font-bold mb-3">Servicios con peor puntuacion</h2>
      <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">
        <table class="w-full text-left">
          <thead class="bg-slate-800 text-slate-400">
            <tr>
              <th class="p-4">Servicio</th>
              <th class="p-4">Categoria</th>
              <th class="p-4">Rating</th>
              <th class="p-4">Reviews</th>
            </tr>
          </thead>
          <tbody id="reportsWorstServices"></tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="text-xl font-bold mb-3">Alertas del sistema</h2>
      <div id="reportsAlerts" class="grid md:grid-cols-3 gap-4"></div>
    </section>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/admin/admin-reports.js"></script>
