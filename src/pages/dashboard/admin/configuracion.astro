---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout  userRole="admin">

<div class="space-y-10">

<!-- PERFIL ADMIN -->

<section class="bg-slate-900 border border-slate-800 p-8 rounded-xl">

<h2 class="text-xl font-bold mb-6">
Perfil del administrador
</h2>

<div class="grid md:grid-cols-2 gap-6">

<div>
<label class="block text-slate-400 mb-2">
Nombre
</label>

<input
type="text"
value="Sara Lopez"
class="w-full bg-slate-800 border border-slate-700 rounded-lg p-3"
/>
</div>

<div>
<label class="block text-slate-400 mb-2">
Correo
</label>

<input
type="email"
value="admin@helium.com"
class="w-full bg-slate-800 border border-slate-700 rounded-lg p-3"
/>
</div>

</div>

<button class="mt-6 bg-purple-700 hover:bg-purple-600 px-6 py-2 rounded-lg">
Guardar cambios
</button>

</section>


<!-- CONFIGURACIÓN PLATAFORMA -->

<section class="bg-slate-900 border border-slate-800 p-8 rounded-xl">

<h2 class="text-xl font-bold mb-6">
Configuración de la plataforma
</h2>

<div class="grid md:grid-cols-2 gap-6">

<div>
<label class="block text-slate-400 mb-2">
Nombre de la plataforma
</label>

<input
type="text"
value="Helium"
class="w-full bg-slate-800 border border-slate-700 rounded-lg p-3"
/>
</div>

<div>
<label class="block text-slate-400 mb-2">
Email de soporte
</label>

<input
type="email"
value="soporte@helium.com"
class="w-full bg-slate-800 border border-slate-700 rounded-lg p-3"
/>
</div>

</div>

<div class="mt-6 flex items-center gap-4">

<label class="text-slate-300">
Modo mantenimiento
</label>

<input type="checkbox" class="w-5 h-5">

</div>

<button class="mt-6 bg-purple-700 hover:bg-purple-600 px-6 py-2 rounded-lg">
Guardar configuración
</button>

</section>


<!-- SEGURIDAD -->

<section class="bg-slate-900 border border-slate-800 p-8 rounded-xl">

<h2 class="text-xl font-bold mb-6">
Seguridad
</h2>

<div class="space-y-4">

<div>
<label class="block text-slate-400 mb-2">
Nueva contraseña
</label>

<input
type="password"
class="w-full bg-slate-800 border border-slate-700 rounded-lg p-3"
/>
</div>

<div>
<label class="block text-slate-400 mb-2">
Confirmar contraseña
</label>

<input
type="password"
class="w-full bg-slate-800 border border-slate-700 rounded-lg p-3"
/>
</div>

</div>

<button class="mt-6 bg-red-600 hover:bg-red-500 px-6 py-2 rounded-lg">
Actualizar contraseña
</button>

</section>


<!-- NOTIFICACIONES -->

<section class="bg-slate-900 border border-slate-800 p-8 rounded-xl">

<h2 class="text-xl font-bold mb-6">
Notificaciones
</h2>

<div class="space-y-4">

<label class="flex items-center gap-3">

<input type="checkbox" checked class="w-5 h-5">

<span>
Alertar cuando un usuario sea reportado
</span>

</label>

<label class="flex items-center gap-3">

<input type="checkbox" checked class="w-5 h-5">

<span>
Notificar nuevos registros
</span>

</label>

<label class="flex items-center gap-3">

<input type="checkbox" class="w-5 h-5">

<span>
Alertar disputas entre cliente y freelancer
</span>

</label>

</div>

<button class="mt-6 bg-purple-700 hover:bg-purple-600 px-6 py-2 rounded-lg">
Guardar preferencias
</button>

</section>

</div>

</DashboardLayout>