---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="admin">
  <section class="max-w-7xl mx-auto px-6 py-8 space-y-6">
    <div class="flex items-center justify-between gap-4">
      <h1 class="text-2xl font-bold">Detalle de la orden</h1>
      <a href="/dashboard/admin/ordenes" class="text-indigo-400 hover:underline">Volver a ordenes</a>
    </div>

    <div id="orderDetailAlert" class="hidden rounded-xl border px-4 py-3 text-sm"></div>

    <div class="grid lg:grid-cols-3 gap-6">
      <article class="lg:col-span-2 bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold mb-4">Informacion de la orden</h2>

        <div id="orderInfoSkeleton" class="grid sm:grid-cols-2 gap-4">
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
          <div class="h-5 bg-slate-700/70 rounded animate-pulse"></div>
        </div>

        <dl id="orderInfo" class="hidden grid sm:grid-cols-2 gap-4 text-sm"></dl>
      </article>

      <aside class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold mb-4">Estado</h2>
        <div id="orderStatusBadge" class="inline-flex px-3 py-1 rounded-lg text-sm bg-slate-800 text-slate-300">-</div>

        <div class="mt-6 space-y-3 text-sm">
          <p><span class="text-slate-400">Creada:</span> <span id="orderCreatedAt" class="ml-2 text-white">-</span></p>
          <p><span class="text-slate-400">Iniciada:</span> <span id="orderStartedAt" class="ml-2 text-white">-</span></p>
          <p><span class="text-slate-400">Entregada:</span> <span id="orderDeliveredAt" class="ml-2 text-white">-</span></p>
          <p><span class="text-slate-400">Completada:</span> <span id="orderCompletedAt" class="ml-2 text-white">-</span></p>
          <p><span class="text-slate-400">Cancelada:</span> <span id="orderCancelledAt" class="ml-2 text-white">-</span></p>
        </div>
      </aside>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <article class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold mb-4">Comprador (cliente/empresa)</h2>
        <p id="orderBuyerName" class="font-semibold">-</p>
        <p id="orderBuyerEmail" class="text-slate-400 text-sm mt-1">-</p>
        <a id="orderBuyerLink" href="/dashboard/admin/usuarios" class="inline-block mt-3 text-indigo-400 hover:underline text-sm">Ver perfil</a>
      </article>

      <article class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold mb-4">Freelancer</h2>
        <p id="orderFreelancerName" class="font-semibold">-</p>
        <p id="orderServiceTitle" class="text-slate-300 text-sm mt-1">-</p>
        <a id="orderFreelancerLink" href="/dashboard/admin/perfilFreelancer" class="inline-block mt-3 text-indigo-400 hover:underline text-sm">Ver perfil</a>
      </article>
    </div>

    <article class="bg-slate-900 border border-slate-800 rounded-xl p-6">
      <h2 class="text-lg font-semibold mb-3">Requerimientos del servicio</h2>
      <p id="orderRequirements" class="text-slate-300 whitespace-pre-line">-</p>
    </article>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/admin/admin-order-detail.js"></script>
