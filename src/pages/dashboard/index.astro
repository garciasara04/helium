---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Dashboard" userRole="cliente">
  <h1>Redirigiendo...</h1>
</DashboardLayout>

<script type="module">
  const rawUser = localStorage.getItem("user");
  if (!rawUser) {
    window.location.href = "/Login";
  } else {
    try {
      const user = JSON.parse(rawUser);
      const roleId = Number(user?.role_id);
      if (roleId === 1) window.location.href = "/dashboard/cliente";
      else if (roleId === 2) window.location.href = "/dashboard/freelance";
      else if (roleId === 3) window.location.href = "/dashboard/company";
      else if (roleId === 4) window.location.href = "/dashboard/admin";
      else window.location.href = "/";
    } catch (err) {
      localStorage.removeItem("user");
      localStorage.removeItem("token");
      window.location.href = "/Login";
    }
  }
</script>
