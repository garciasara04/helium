---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout  userRole="company">

<section class="max-w-6xl mx-auto px-6 py-10">

<!-- Header -->
<div class="mb-10">
<h1 class="text-3xl font-bold text-white">
Contratar servicio
</h1>
<p class="text-slate-400 mt-2">
Completa los detalles para iniciar el proyecto con el freelancer
</p>
</div>


<div class="grid lg:grid-cols-3 gap-8">

<!-- Freelancer info -->
<div class="bg-slate-900 border border-slate-800 rounded-2xl p-6">

<div class="flex items-center gap-4 mb-6">
<img
id="contractFreelancerImage"
src="https://via.placeholder.com/200"
class="w-16 h-16 rounded-full object-cover"
/>

<div>
<h3 id="contractFreelancerName" class="text-lg font-semibold text-white">
Freelancer
</h3>

<p id="contractServiceTitle" class="text-slate-400 text-sm">
Servicio
</p>

<div id="contractFreelancerRating" class="text-yellow-400 text-sm mt-1">
Sin calificacion
</div>
</div>
</div>

<div class="border-t border-slate-800 pt-5">

<div class="flex justify-between text-sm text-slate-400 mb-2">
<span>Precio base</span>
<span id="contractServicePrice" class="text-white font-semibold">
$0
</span>
</div>

<p class="text-xs text-slate-500">
El precio final puede cambiar dependiendo de los requisitos del proyecto.
</p>

</div>

</div>


<!-- Formulario -->
<div class="lg:col-span-2 bg-slate-900 border border-slate-800 rounded-2xl p-8">

<form id="contractForm" class="space-y-6">

<!-- Nombre del proyecto -->
<div>
<label class="block text-sm text-slate-400 mb-2">
Nombre del proyecto
</label>

<input
id="projectName"
type="text"
placeholder="Ej: Desarrollo de sitio web corporativo"
class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
/>
</div>


<!-- Descripcion / Requerimientos -->
<div>
<label class="block text-sm text-slate-400 mb-2">
Descripcion del proyecto
</label>

<textarea
id="requirements"
rows="4"
placeholder="Describe los objetivos y requerimientos del proyecto..."
class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
></textarea>
</div>


<!-- Presupuesto -->
<div class="grid md:grid-cols-2 gap-6">


<div>
<label class="block text-sm text-slate-400 mb-2">
Presupuesto
</label>

<input
id="budget"
type="number"
placeholder="Ej: 500"
class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
/>
</div>



<div>
<label class="block text-sm text-slate-400 mb-2">
Fecha limite
</label>

<input
id="deadline"
type="date"
class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500"
/>
</div>

</div>


<!-- Archivos -->
<div>
<label class="block text-sm text-slate-400 mb-2">
Adjuntar archivos
</label>

<input
id="attachments"
type="file"
class="w-full text-sm text-slate-400 file:bg-indigo-600 file:text-white file:border-none file:px-4 file:py-2 file:rounded-lg cursor-pointer file:cursor-pointer"
/>
</div>

<div id="contractMessage" class="text-sm text-slate-400"></div>

<!-- Boton -->
<div class="pt-4">

<button
id="contractSubmit"
type="submit"
class="w-full bg-indigo-600 hover:bg-indigo-500 transition py-3 rounded-lg text-white font-semibold active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-indigo-400 focus:ring-offset-2 focus:ring-offset-slate-900 disabled:opacity-60 disabled:cursor-not-allowed cursor-pointer"
>
Enviar solicitud al freelancer
</button>

</div>

</form>

</div>

</div>

</section>

</DashboardLayout>

<script type="module" src="/src/js/company/contract-service.js"></script>



