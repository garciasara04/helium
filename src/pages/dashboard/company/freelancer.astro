---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="company">

<div class="max-w-6xl mx-auto">

<div id="freelancerLoading" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl">
  Cargando perfil...
</div>

<div id="freelancerEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
  No se encontro el perfil.
</div>

<div id="freelancerContent" class="hidden">

  <!-- HEADER -->
  <div class="flex flex-col md:flex-row gap-10 items-center">

    <img
      id="freelancerPhoto"
      src="https://via.placeholder.com/400"
      class="w-48 h-48 rounded-full border-4 border-purple-600 object-cover"
    />

    <div>

      <h1 id="freelancerName" class="text-3xl font-bold">
        Freelancer
      </h1>

      <p id="freelancerProfession" class="text-purple-400 text-xl">
        Profesion
      </p>

      <p id="freelancerRating" class="text-yellow-400 mt-2">
        Sin calificacion
      </p>

      <p id="freelancerLocation" class="text-slate-400 mt-2">
        -
      </p>

      <p id="freelancerLanguages" class="text-slate-400 mt-1">
        Idiomas: -
      </p>

      <div id="freelancerRate" class="mt-4 text-2xl text-purple-400 font-bold">
        
      </div>

    </div>

  </div>

  <!-- SKILLS -->
  <section class="mt-12">
    <h2 class="text-2xl font-bold mb-6">Skills</h2>
    <div id="freelancerSkills" class="flex flex-wrap gap-3"></div>
  </section>

  <!-- SERVICIOS ACTIVOS -->
  <section class="mt-16">
    <h2 class="text-2xl font-bold mb-8">Servicios activos</h2>
    <div id="freelancerServices" class="grid md:grid-cols-3 gap-6"></div>
    <div id="freelancerServicesEmpty" class="text-center text-slate-400 py-12 border border-slate-800 rounded-xl hidden">
      No hay servicios activos.
    </div>
  </section>


</div>

</DashboardLayout>

<script type="module" src="/src/js/company/freelancer-profile.js"></script>


