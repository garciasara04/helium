---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout  userRole="company">
  <section class="max-w-6xl mx-auto px-6 py-10">
    <h2 class="text-3xl font-bold text-violet-300 mb-8">
      Calificar servicios realizados
    </h2>

    <div id="companyReviewsList" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>

    <div id="companyReviewsEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
      No tienes servicios pendientes por calificar.
    </div>

    <div id="companyReviewsLoading" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl">
      Cargando servicios...
    </div>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/company/reviews.js"></script>
