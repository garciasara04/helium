---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";


---

<DashboardLayout  userRole="company">

<!-- HERO -->

<section id="companyHero" class="relative h-72 rounded-2xl overflow-hidden mb-14 bg-cover bg-center will-change-transform transition-transform duration-200" style="background-image:url('https://images.unsplash.com/photo-1557804506-669a67965ba0?w=1600')">

<div class="absolute inset-0 bg-black/60"></div>

<div class="relative z-10 flex flex-col justify-center h-full px-10 max-w-3xl">

<h2 class="text-4xl font-black mb-4">
Bienvenido Helium
</h2>

<p class="text-slate-200 mb-6">
Gestiona tus proyectos, contrata freelancers y encuentra talento para tu empresa.
</p>

<a
href="/dashboard/company/marketplace"
class="bg-purple-700 hover:bg-purple-600 px-8 py-3 rounded-xl font-bold w-fit transition duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-purple-900/40 active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-purple-400 focus:ring-offset-2 focus:ring-offset-slate-900 cursor-pointer">

Explorar marketplace →

</a>

</div>

</section>


<!-- BOTONES RAPIDOS -->

<section data-reveal class="grid md:grid-cols-3 lg:grid-cols-5 gap-6 mb-16 opacity-0 translate-y-3">

<a href="/dashboard/company/servicios"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500 transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-purple-900/20 cursor-pointer focus:outline-none focus:ring-2 focus:ring-purple-500/70">

<h3 class="text-lg font-bold mb-1">
Servicios
</h3>

<p class="text-slate-400 text-sm">
Explorar Servicios
</p>

</a>


<a href="/dashboard/company/marketplace"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500 transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-purple-900/20 cursor-pointer focus:outline-none focus:ring-2 focus:ring-purple-500/70">

<h3 class="text-lg font-bold mb-1">
Marketplace
</h3>

<p class="text-slate-400 text-sm">
Explorar freelancers
</p>

</a>


<a href="/dashboard/company/ordenes"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500 transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-purple-900/20 cursor-pointer focus:outline-none focus:ring-2 focus:ring-purple-500/70">

<h3 class="text-lg font-bold mb-1">
Órdenes
</h3>

<p class="text-slate-400 text-sm">
Gestionar proyectos
</p>

</a>


<a href="/dashboard/company/reviews"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500 transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-purple-900/20 cursor-pointer focus:outline-none focus:ring-2 focus:ring-purple-500/70">

<h3 class="text-lg font-bold mb-1">
Reviews
</h3>

<p class="text-slate-400 text-sm">
Calificar freelancers
</p>

</a>


<a href="/dashboard/company/notificaciones"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500 transition duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-purple-900/20 cursor-pointer focus:outline-none focus:ring-2 focus:ring-purple-500/70">

<h3 class="text-lg font-bold mb-1">
Notificaciones
</h3>

<p class="text-slate-400 text-sm">
Actividad reciente
</p>

</a>

</section>



<!-- FREELANCERS -->

<section data-reveal class="mb-16 opacity-0 translate-y-3">

<h2 class="text-2xl font-bold mb-6">
Freelancers recomendados
</h2>

<div id="recommendedFreelancers" class="grid grid-cols-2 md:grid-cols-4 gap-6">
  <div class="col-span-full text-slate-400">Cargando freelancers...</div>
</div>

</section>


<!-- PROYECTOS -->

<section data-reveal class="mb-16 opacity-0 translate-y-3">

<h2 class="text-2xl font-bold mb-6">
Proyectos activos
</h2>

<div id="activeProjects" class="space-y-6">
  <div class="text-slate-400">Cargando proyectos...</div>
</div>

</section>

<!-- SERVICIOS -->

<section data-reveal class="opacity-0 translate-y-3">

<h2 class="text-2xl font-bold mb-6">
Servicios populares
</h2>

<div id="popularServices" class="grid grid-cols-2 md:grid-cols-4 gap-6">
  <div class="col-span-full text-slate-400">Cargando servicios...</div>
</div>

</section>

<script type="module" src="/src/js/company/company-dashboard.js"></script>

</DashboardLayout>







