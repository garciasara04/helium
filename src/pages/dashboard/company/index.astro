---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Panel Empresa" userRole="company">

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<a href="/dashboard/company/perfil"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500 transition">

<h3 class="text-xl font-bold text-white mb-2">
Perfil de empresa
</h3>

<p class="text-slate-400">
Ver perfil y datos de la empresa
</p>

</a>


<a href="/dashboard/company/editar"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500">

<h3 class="text-xl font-bold">
Editar datos
</h3>

<p class="text-slate-400">
Actualizar información y foto
</p>

</a>


<a href="/dashboard/company/marketplace"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500">

<h3 class="text-xl font-bold">
Explorar marketplace
</h3>

<p class="text-slate-400">
Buscar freelancers y servicios
</p>

</a>


<a href="/dashboard/company/servicios"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500">

<h3 class="text-xl font-bold">
Servicios
</h3>

<p class="text-slate-400">
Ver y contratar servicios
</p>

</a>


<a href="/dashboard/company/ordenes"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500">

<h3 class="text-xl font-bold">
Órdenes
</h3>

<p class="text-slate-400">
Ver órdenes creadas
</p>

</a>


<a href="/dashboard/company/reviews"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500">

<h3 class="text-xl font-bold">
Reviews
</h3>

<p class="text-slate-400">
Ver reputación y reseñas
</p>

</a>


<a href="/dashboard/company/notificaciones"
class="bg-slate-900 p-6 rounded-xl border border-slate-800 hover:border-purple-500">

<h3 class="text-xl font-bold">
Notificaciones
</h3>

<p class="text-slate-400">
Ver notificaciones internas
</p>

</a>

</div>

</DashboardLayout>