---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

const services = [
{
title:"Landing Page",
price:450,
image:"https://images.unsplash.com/photo-1461749280684-dccba630e2f6"
},
{
title:"SEO Profesional",
price:300,
image:"https://images.unsplash.com/photo-1556155092-8707de31f9c4"
}
];
// agregar descripcion y mas impormacion que queramos de los servicios del freelancer
---

<DashboardLayout title="Marketplace" userRole="company">

<div class="grid md:grid-cols-3 gap-6">

{services.map(service => (

<div class="bg-slate-900 rounded-xl overflow-hidden">

<img src={service.image}
class="h-44 w-full object-cover"/>

<div class="p-5">

<h3 class="font-bold">{service.title}</h3>

<p class="text-purple-400 mb-4">${service.price}</p>

<a href="/dashboard/company/servicio-detalle"
class="bg-purple-600 px-4 py-2 rounded-lg">

Ver servicio

</a>

</div>

</div>

))}

</div>

</DashboardLayout>