---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

const company = {
name:"Helium Tech",
email:"contact@helium.com",
website:"helium.com",
phone:"+34 555 888",
address:"Madrid España",
avatar:"https://images.unsplash.com/photo-1560179707-f14e90ef3623"
};
---

<DashboardLayout title="Perfil Empresa" userRole="company">

<section class="bg-slate-900 rounded-xl overflow-hidden">

<div class="h-40 bg-gradient-to-r from-purple-600 to-indigo-600"></div>

<div class="p-8">

<div class="flex items-center gap-6">

<img src={company.avatar}
class="w-24 h-24 rounded-full border-4 border-slate-900 object-cover"/>

<div>

<h2 class="text-2xl font-bold">{company.name}</h2>
<p class="text-slate-400">{company.email}</p>

<a href="/dashboard/company/editar"
class="mt-3 inline-block bg-purple-600 px-6 py-2 rounded-lg">

Editar perfil

</a>

</div>

</div>

<div class="grid md:grid-cols-2 gap-6 mt-8 text-slate-300">

<p><b>Teléfono:</b> {company.phone}</p>
<p><b>Website:</b> {company.website}</p>
<p><b>Dirección:</b> {company.address}</p>

</div>

</div>

</section>

</DashboardLayout>