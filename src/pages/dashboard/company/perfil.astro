---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="company">
  <section class="relative overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/70 shadow-xl shadow-indigo-950/20">
    <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_20%_20%,rgba(99,102,241,0.22),transparent_45%),radial-gradient(circle_at_80%_10%,rgba(168,85,247,0.18),transparent_40%)]"></div>

    <div class="relative h-44 bg-gradient-to-r from-indigo-600 via-purple-600 to-fuchsia-600">
      <div class="absolute inset-0 bg-[linear-gradient(120deg,rgba(255,255,255,0.18),rgba(255,255,255,0))]"></div>
    </div>

    <div id="companyProfileLoading" class="relative p-8 md:p-10">
      <div class="animate-pulse">
        <div class="-mt-20 mb-6 flex items-end gap-5">
          <div class="h-28 w-28 rounded-full bg-slate-700 border-4 border-slate-900"></div>
          <div class="space-y-3 pb-3">
            <div class="h-5 w-52 rounded bg-slate-700"></div>
            <div class="h-4 w-72 rounded bg-slate-800"></div>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
          <div class="h-24 rounded-xl bg-slate-800 border border-slate-700"></div>
          <div class="h-24 rounded-xl bg-slate-800 border border-slate-700"></div>
          <div class="h-24 rounded-xl bg-slate-800 border border-slate-700"></div>
          <div class="h-24 rounded-xl bg-slate-800 border border-slate-700"></div>
        </div>
      </div>
    </div>

    <div id="companyProfileEmpty" class="relative hidden p-10">
      <div class="rounded-xl border border-rose-500/30 bg-rose-500/10 p-5 text-rose-200">
        No se pudo cargar la información de la empresa.
      </div>
    </div>

    <div id="companyProfileContent" class="relative hidden p-8 md:p-10">
      <div class="-mt-20 mb-7 flex flex-col sm:flex-row sm:items-end gap-5">
        <img
          id="companyAvatar"
          src="/logo.jpeg"
          class="h-28 w-28 rounded-full border-4 border-slate-900 object-cover bg-slate-800 shadow-xl"
          alt="Avatar empresa"
        />

        <div class="flex-1">
          <h2 id="companyName" class="text-3xl font-black text-white tracking-tight">Empresa</h2>
          <p id="companyEmail" class="mt-1 text-slate-300">-</p>
        </div>

        <a
          href="/dashboard/company/editar"
          class="inline-flex items-center justify-center rounded-lg bg-purple-600 px-5 py-2.5 font-semibold text-white transition hover:bg-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-400"
        >
          Editar perfil
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
        <article class="rounded-xl border border-slate-800 bg-slate-900/80 p-4">
          <p class="text-xs uppercase tracking-wide text-slate-400">Teléfono</p>
          <p id="companyPhone" class="mt-2 text-sm font-semibold text-white break-words">-</p>
        </article>

        <article class="rounded-xl border border-slate-800 bg-slate-900/80 p-4">
          <p class="text-xs uppercase tracking-wide text-slate-400">Website</p>
          <p id="companyWebsite" class="mt-2 text-sm font-semibold text-white break-words">-</p>
        </article>

        <article class="rounded-xl border border-slate-800 bg-slate-900/80 p-4 md:col-span-2 xl:col-span-2">
          <p class="text-xs uppercase tracking-wide text-slate-400">Dirección</p>
          <p id="companyAddress" class="mt-2 text-sm font-semibold text-white break-words">-</p>
        </article>
      </div>
    </div>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/company/company-profile.js"></script>
