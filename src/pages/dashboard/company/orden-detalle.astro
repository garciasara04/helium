---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Detalle del servicio" userRole="company">

<section class="max-w-6xl mx-auto px-6 py-10">

<div id="orderLoading" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl">
  Cargando detalle...
</div>

<div id="orderEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
  No se encontro la orden.
</div>

<div id="orderContent" class="hidden">

  <!-- Header -->
  <div class="flex items-center justify-between mb-10">
    <div>
      <h1 class="text-3xl font-bold text-white">Detalle del servicio</h1>
      <p class="text-slate-400 mt-1">Informacion completa del servicio contratado</p>
    </div>

    <span id="orderStatus" class="px-3 py-1 rounded-lg text-sm"></span>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

    <!-- INFORMACION PRINCIPAL -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Servicio -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h2 class="text-xl font-semibold text-white mb-4">Servicio contratado</h2>
        <p id="orderServiceTitle" class="text-slate-300"></p>
      </div>

      <!-- Descripcion -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h2 class="text-xl font-semibold text-white mb-4">Descripcion del proyecto</h2>
        <p id="orderRequirements" class="text-slate-400 leading-relaxed"></p>
      </div>

    </div>

    <!-- SIDEBAR -->
    <div class="space-y-6">

      <!-- Freelancer -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <h2 class="text-lg font-semibold text-white mb-4">Freelancer</h2>
        <div class="flex items-center gap-4">
          <img id="orderFreelancerPhoto" src="https://via.placeholder.com/200" class="w-14 h-14 rounded-full object-cover" />
          <div>
            <p id="orderFreelancerName" class="text-white font-medium"></p>
            <p class="text-sm text-slate-400">Freelancer</p>
          </div>
        </div>
      </div>

      <!-- Informacion -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 space-y-3">
        <div class="flex justify-between text-sm">
          <span class="text-slate-400">Precio</span>
          <span id="orderPrice" class="text-white"></span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-slate-400">Fecha de inicio</span>
          <span id="orderStartDate" class="text-white"></span>
        </div>
        <div class="flex justify-between text-sm">
          <span class="text-slate-400">Entrega estimada</span>
          <span id="orderDeliveredDate" class="text-white"></span>
        </div>
      </div>

      <!-- Acciones -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
        <a id="orderFreelancerLink" href="#" class="block w-full text-center bg-slate-800 hover:bg-slate-700 transition py-2 rounded-lg">
          Ver perfil
        </a>
      </div>

    </div>

  </div>

</div>

</section>

</DashboardLayout>

<script type="module" src="/src/js/company/order-detail.js"></script>
