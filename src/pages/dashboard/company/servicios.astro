---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Servicios" userRole="company">
  <section class="max-w-7xl mx-auto px-6 py-10">
    <div class="mb-12 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-white">
        Servicios de Freelancers
      </h1>
      <p class="text-slate-400 mt-3">
        Explora los servicios disponibles en Helium
      </p>
    </div>

    <div id="servicesGrid" class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"></div>

    <div id="servicesEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
      No hay servicios activos para estos filtros.
    </div>

    <div id="servicesLoading" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl">
      Cargando servicios...
    </div>
  </section>
</DashboardLayout>

<script type="module" src="/src/js/company-services.js"></script>
