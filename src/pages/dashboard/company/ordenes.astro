---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="company">

<section class="max-w-7xl mx-auto px-6 py-10">

<!-- Header -->
<div class="mb-10">
  <h1 class="text-3xl font-bold text-white">
    Ordenes de servicios
  </h1>

  <p class="text-slate-400 mt-2">
    Aqui puedes ver todos los servicios que tu empresa ha solicitado a freelancers.
  </p>
</div>

<div id="ordersGrid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6"></div>

<div id="ordersEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
  No tienes ordenes de servicios todavia.
</div>

<div id="ordersLoading" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl">
  Cargando ordenes...
</div>

</section>

</DashboardLayout>

<script type="module" src="/src/js/company/orders.js"></script>
