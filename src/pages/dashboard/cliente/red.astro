---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Red Cliente" userRole="cliente">

  <main class="min-h-screen bg-slate-950 text-slate-100">
    <div class="container mx-auto px-4 py-8 lg:py-12">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

        <!-- Sidebar izquierda -->
        <aside class="lg:w-64 shrink-0">
          <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 sticky top-8">
            <h1 class="text-2xl font-bold text-violet-400 mb-8">Red de autónomos</h1>

            <nav class="space-y-8">
              <div>
                <h2 class="text-lg font-semibold text-slate-300 mb-4">Basado en tu actividad</h2>
                <ul class="space-y-3">
                  <li>
                    <a href="#todas" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-violet-900/30 hover:bg-violet-800/50 transition-colors">
                      <span class="text-violet-400">✦</span> Todas las contrataciones
                    </a>
                  </li>
                  <li>
                    <a href="#vistos" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors">
                      <span class="text-violet-400">⌛</span> Vistos recientemente
                    </a>
                  </li>
                </ul>
              </div>
            </nav>
          </div>
        </aside>

        <!-- Contenido principal -->
        <div class="flex-1 space-y-12">

          <!-- Sección: Todas las contrataciones -->
          <section id="todas">
            <h2 class="text-3xl font-bold text-violet-300 mb-6">Todas las contrataciones</h2>
            <div id="ordersAll" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
            <div id="ordersAllEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
              No tienes contrataciones todavia.
            </div>
            <div id="ordersAllLoading" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl">
              Cargando contrataciones...
            </div>
          </section>

          <!-- Sección: Vistos recientemente -->
          <section id="vistos">
            <h2 class="text-3xl font-bold text-violet-300 mb-6">Vistos recientemente</h2>
            <div id="ordersRecent" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
            <div id="ordersRecentEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
              No has visto freelancers recientemente.
            </div>
          </section>

        </div>
      </div>
    </div>
  </main>

</DashboardLayout>

<script>
  const API_BASE = "http://127.0.0.1:8000";

  const elAll = document.getElementById("ordersAll");
  const elAllEmpty = document.getElementById("ordersAllEmpty");
  const elAllLoading = document.getElementById("ordersAllLoading");
  const elRecent = document.getElementById("ordersRecent");
  const elRecentEmpty = document.getElementById("ordersRecentEmpty");

  function escapeHtml(value) {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function buildCard(order) {
    const freelancerName = order?.freelancer?.user?.name || order?.freelancer_name || "Freelancer";
    const serviceName = order?.service?.title || order?.service?.name || "Servicio";
    const status = order?.status || "pending";
    const price = order?.price || order?.total || order?.amount || "Sin precio";
    const imageUrl = order?.freelancer?.profile_photo_url || order?.freelancer?.photo || "";
    const reviewed = order?.review_exists === true;    const canReview = status === "completed" && !reviewed;

    const reviewButton = canReview      ? `<a href="/dashboard/cliente/reviews?order_id=${escapeHtml(order.id)}" class="px-6 py-2 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-xl transition shadow-md shadow-purple-900/30">Dejar resena</a>`      : reviewed        ? `<button disabled class="px-6 py-2 bg-emerald-700 text-white font-medium rounded-xl cursor-not-allowed">Resena enviada</button>`        : `<button disabled class="px-6 py-2 bg-slate-700 text-slate-300 font-medium rounded-xl cursor-not-allowed">Resena no disponible</button>`;

    return `
      <div class="bg-gray-900/70 border border-gray-800 rounded-2xl p-6 shadow-lg shadow-purple-900/20 hover:shadow-purple-700/30 transition-all">
        <div class="flex flex-col items-center text-center">
          <img src="${escapeHtml(imageUrl || "https://via.placeholder.com/300")}" alt="${escapeHtml(freelancerName)}" class="w-32 h-32 rounded-full object-cover border-4 border-purple-600 shadow-xl mb-4" />
          <h3 class="text-xl font-bold text-white">${escapeHtml(freelancerName)}</h3>
          <p class="text-purple-400 text-sm">${escapeHtml(serviceName)}</p>
        </div>
        <div class="mt-4 space-y-2 text-center">
          <p class="text-slate-300 font-semibold">Estado: ${escapeHtml(status)}</p>
          <p class="text-purple-300 font-medium mt-2">${escapeHtml(price)}</p>
        </div>
        <div class="mt-6 text-center">
          ${reviewButton}
        </div>
      </div>
    `;
  }

  async function fetchOrders() {
    const token = localStorage.getItem("token");
    if (!token) {
      elAllLoading?.classList.add("hidden");
      elAllEmpty?.classList.remove("hidden");
      elAllEmpty.textContent = "No hay sesion activa. Inicia sesion para ver tus contrataciones.";
      return;
    }

    try {
      const response = await fetch(`${API_BASE}/api/orders`, {
        headers: {
          "Accept": "application/json",
          "Authorization": `Bearer ${token}`
        }
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      const data = await response.json();
      const orders = Array.isArray(data) ? data : (data?.data || []);

      elAllLoading?.classList.add("hidden");

      if (!orders.length) {
        elAllEmpty?.classList.remove("hidden");
        elRecentEmpty?.classList.remove("hidden");
        return;
      }

      elAll.innerHTML = orders.map(buildCard).join("");

      const recent = orders.slice(0, 3);
      elRecent.innerHTML = recent.map(buildCard).join("");

      if (!recent.length) {
        elRecentEmpty?.classList.remove("hidden");
      }
    } catch (err) {
      elAllLoading?.classList.add("hidden");
      elAllEmpty?.classList.remove("hidden");
      elAllEmpty.textContent = "Error al cargar contrataciones.";
      console.error(err);
    }
  }  fetchOrders();
</script>





