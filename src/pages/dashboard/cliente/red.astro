---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout userRole='cliente'>
  <main class="min-h-screen bg-slate-950 text-slate-100">
    <div class="container mx-auto px-4 py-8 lg:py-12">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

        <aside class="lg:w-64 shrink-0">
          <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 sticky top-8">
            <h1 class="text-2xl font-bold text-indigo-400 mb-8">Gestión de Órdenes</h1>
            <nav>
              <a href="#todas" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-indigo-900/30 text-indigo-400 font-bold">
                ✦ Todas las órdenes
              </a>
            </nav>
          </div>
        </aside>

        <div class="flex-1">
          <h2 class="text-3xl font-bold text-white mb-2">Todas las órdenes</h2>
          <p class="text-slate-400 mb-8">Servicios que tu empresa ha solicitado.</p>
          
          <div id="ordersAll" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
          
          <div id="ordersMensaje" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl">
            Cargando órdenes...
          </div>
        </div>

      </div>
    </div>
  </main>
</DashboardLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  const API_BASE = "http://127.0.0.1:8000";
  const contenedor = document.getElementById("ordersAll");
  const mensaje = document.getElementById("ordersMensaje");

  async function cargarOrdenes() {
    try {
      const token = localStorage.getItem("token");
      
      if (!token) {
        mensaje.textContent = "Por favor, inicia sesión para ver tus órdenes.";
        return;
      }

      const respuesta = await fetch(`${API_BASE}/api/orders`, {
        headers: { "Authorization": `Bearer ${token}` }
      });

      const datos = await respuesta.json();
      const ordenes = datos.data || datos;

      contenedor.innerHTML = '';

      if (!ordenes || ordenes.length === 0) {
        mensaje.textContent = "No tienes órdenes de servicios todavía.";
        mensaje.style.display = "block";
        return;
      }

      mensaje.style.display = "none";

      ordenes.forEach(orden => {
        
        const freelancer = orden.service?.freelancer_profile?.user || {};
        const nombre = `${freelancer.names || ''} ${freelancer.last_names || ''}`.trim() || 'Freelancer';
        const fotoUrl = freelancer.photo ? `${API_BASE}/storage/${freelancer.photo}` : 'https://placehold.co/150';
        const servicio = orden.service?.title || 'Servicio sin título';
        const precio = orden.amount ? Number(orden.amount).toLocaleString('es-CO') : '0';
        
        let estadoTexto = orden.status;
        let colorEstado = "text-slate-400 bg-slate-800";
        
        let botonesHtml = `<a href="/dashboard/cliente/detalle_orden?id=${orden.id}" class="block w-full text-center bg-indigo-600 hover:bg-indigo-500 text-white font-medium py-2 rounded-lg mt-3 transition text-sm">Ver detalles</a>`;

        if (orden.status === "pending") {
          estadoTexto = "Pendiente";
          colorEstado = "text-amber-400 bg-amber-400/10 border border-amber-400/20";
          botonesHtml += `<button onclick="cambiarEstado(${orden.id}, 'cancelled')" class="w-full bg-red-900/30 hover:bg-red-600 text-red-400 hover:text-white font-medium py-2 rounded-lg mt-2 transition text-sm">Cancelar Orden</button>`;
        } 
        else if (orden.status === "in_progress") {
          estadoTexto = "En progreso";
          colorEstado = "text-yellow-400 bg-yellow-400/10 border border-yellow-400/20";
          botonesHtml += `<button onclick="cambiarEstado(${orden.id}, 'cancelled')" class="w-full bg-red-900/30 hover:bg-red-600 text-red-400 hover:text-white font-medium py-2 rounded-lg mt-2 transition text-sm">Cancelar Orden</button>`;
        } 
        else if (orden.status === "delivered") {
          estadoTexto = "Entregado";
          colorEstado = "text-blue-400 bg-blue-400/10 border border-blue-400/20";
          botonesHtml += `<button onclick="cambiarEstado(${orden.id}, 'completed')" class="w-full bg-green-600 hover:bg-green-500 text-white font-medium py-2 rounded-lg mt-2 transition text-sm">Confirmar Recepción</button>`;
        } 
        else if (orden.status === "completed") {
          estadoTexto = "Completado";
          colorEstado = "text-green-400 bg-green-400/10 border border-green-400/20";
        } 
        else if (orden.status === "cancelled") {
          estadoTexto = "Cancelado";
          colorEstado = "text-red-400 bg-red-400/10 border border-red-400/20";
        }

        const tarjetaHTML = `
          <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-indigo-500 transition-all flex flex-col h-full shadow-lg">
            
            <div class="flex items-center gap-4 mb-4">
              <img src="${fotoUrl}" class="w-12 h-12 rounded-full object-cover border border-slate-700" alt="${nombre}" />
              <div>
                <h3 class="text-white font-bold line-clamp-1 text-sm">${nombre}</h3>
                <span class="px-2 py-0.5 rounded text-[10px] font-bold ${colorEstado} mt-1 inline-block uppercase tracking-wide">${estadoTexto}</span>
              </div>
            </div>

            <div class="mb-4 flex-grow">
              <p class="text-sm text-slate-300 line-clamp-2">${servicio}</p>
            </div>

            <div class="pt-4 border-t border-slate-800">
              <div class="flex justify-between items-center mb-2">
                <span class="text-xs text-slate-400">Precio</span>
                <span class="text-white font-bold text-sm">$${precio} COP</span>
              </div>
              
              <div>
                ${botonesHtml}
              </div>
            </div>

          </div>
        `;
        
        contenedor.innerHTML += tarjetaHTML;
      });

    } catch (error) {
      mensaje.textContent = "Error al cargar los datos desde el servidor.";
      mensaje.style.display = "block";
    }
  }

  window.cambiarEstado = async function(idOrden, nuevoEstado) {
    const confirmacion = await Swal.fire({
      title: '¿Estás seguro?',
      icon: 'warning',
      showCancelButton: true,
      background: '#0f172a',
      color: '#fff',
      confirmButtonColor: '#4f46e5',
      cancelButtonColor: '#dc2626',
      confirmButtonText: 'Sí, continuar',
      cancelButtonText: 'Cancelar'
    });

    if (!confirmacion.isConfirmed) return;

    try {
      const token = localStorage.getItem("token");
      await fetch(`${API_BASE}/api/orders/${idOrden}/status`, {
        method: "PATCH",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${token}`
        },
        body: JSON.stringify({ status: nuevoEstado })
      });

      cargarOrdenes();
    } catch (error) {
      Swal.fire({
        title: 'Error',
        text: 'Hubo un error al comunicarse con el servidor.',
        icon: 'error',
        background: '#0f172a',
        color: '#fff',
        confirmButtonColor: '#4f46e5'
      });
    }
  };

  cargarOrdenes();
</script>