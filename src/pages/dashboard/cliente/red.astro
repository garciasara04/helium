---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout userRole='cliente'>
  <main class="min-h-screen bg-slate-950 text-slate-100">
    <div class="container mx-auto px-4 py-8 lg:py-12">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

        <aside class="lg:w-64 shrink-0">
          <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 sticky top-8">
            <h1 class="text-2xl font-bold text-violet-400 mb-8">Red de autónomos</h1>

            <nav class="space-y-8">
              <div>
                <h2 class="text-lg font-semibold text-slate-300 mb-4">Basado en tu actividad</h2>
                <ul class="space-y-3">
                  <li>
                    <a href="#todas" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-violet-900/30 hover:bg-violet-800/50 transition-colors">
                      <span class="text-violet-400">✦</span> Todas las contrataciones
                    </a>
                  </li>
                  <li>
                    <a href="#vistos" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-slate-800 transition-colors">
                      <span class="text-violet-400">⌛</span> Vistos recientemente
                    </a>
                  </li>
                </ul>
              </div>
            </nav>
          </div>
        </aside>

        <div class="flex-1 space-y-12">

          <section id="todas">
            <h2 class="text-3xl font-bold text-violet-300 mb-6">Todas las contrataciones</h2>
            <div id="ordersAll" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
            <div id="ordersAllEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
              No tienes contrataciones todavía.
            </div>
            <div id="ordersAllLoading" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl">
              Cargando contrataciones...
            </div>
          </section>

          <section id="vistos">
            <h2 class="text-3xl font-bold text-violet-300 mb-6">Vistos recientemente</h2>
            <div id="ordersRecent" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
            <div id="ordersRecentEmpty" class="text-center text-slate-400 py-20 border border-slate-800 rounded-xl hidden">
              No hay actividad reciente.
            </div>
          </section>

        </div>
      </div>
    </div>
  </main>

</DashboardLayout>

<script>
  const API_BASE = "http://127.0.0.1:8000";

  const elAll = document.getElementById("ordersAll");
  const elAllEmpty = document.getElementById("ordersAllEmpty");
  const elAllLoading = document.getElementById("ordersAllLoading");
  const elRecent = document.getElementById("ordersRecent");
  const elRecentEmpty = document.getElementById("ordersRecentEmpty");

  function escapeHtml(value) {
    return String(value ?? "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  function buildCard(order) {
    const userProfile = order?.service?.freelancer_profile?.user;
    const freelancerName = userProfile ? `${userProfile.names} ${userProfile.last_names}` : "Freelancer";
    const serviceName = order?.service?.title || "Servicio";
    const status = order?.status || "pending";
    const price = order?.amount ? `$${Number(order.amount).toLocaleString('es-CO')}` : "Sin precio";
    const imageUrl = userProfile?.photo ? `${API_BASE}/storage/${userProfile.photo}` : "https://placehold.co/300";

    let actionHtml = '';

    if (status === 'delivered') {
      actionHtml = `<button onclick="finalizarPedido(${order.id})" class="w-full px-6 py-3 bg-green-600 hover:bg-green-500 text-white font-bold rounded-xl transition shadow-lg shadow-green-900/30">Finalizar Pedido ✓</button>`;
    } else if (status === 'completed') {
      actionHtml = `<a href="/dashboard/cliente/reviews?order_id=${order.id}" class="block w-full px-6 py-3 bg-purple-700 hover:bg-purple-600 text-white font-bold rounded-xl transition shadow-lg shadow-purple-900/30 text-center">Dejar reseña ⭐</a>`;
    } else {
      const statusMap = { pending: 'Pendiente', in_progress: 'En progreso', cancelled: 'Cancelado' };
      const statusText = statusMap[status] || status;
      actionHtml = `<div class="w-full px-6 py-3 bg-slate-800 text-slate-300 font-medium rounded-xl text-center border border-slate-700">Estado: ${statusText}</div>`;
    }

    return `
      <div class="bg-gray-900/70 border border-gray-800 rounded-2xl p-6 shadow-lg shadow-purple-900/20 hover:border-purple-500/50 transition-all flex flex-col h-full">
        <div class="flex flex-col items-center text-center">
          <img src="${escapeHtml(imageUrl)}" alt="${escapeHtml(freelancerName)}" class="w-24 h-24 rounded-full object-cover border-4 border-purple-600 shadow-xl mb-4" />
          <h3 class="text-xl font-bold text-white line-clamp-1" title="${escapeHtml(freelancerName)}">${escapeHtml(freelancerName)}</h3>
          <p class="text-purple-400 text-sm font-medium line-clamp-1" title="${escapeHtml(serviceName)}">${escapeHtml(serviceName)}</p>
        </div>
        <div class="mt-4 mb-6 text-center flex-1">
          <p class="text-slate-200 font-bold text-2xl">${escapeHtml(price)}</p>
        </div>
        <div class="mt-auto border-t border-slate-800 pt-5">
          ${actionHtml}
        </div>
      </div>
    `;
  }

  window.finalizarPedido = async function(orderId) {
    const confirmacion = await window.appConfirm({
      title: "Finalizar pedido",
      message: "Marcar este pedido como completado? Ya no podras pedir mas revisiones.",
      confirmText: "Si, finalizar",
      cancelText: "Cancelar",
      tone: "warning"
    });
    if (!confirmacion) return;

    const token = localStorage.getItem("token");
    try {
      const response = await fetch(`${API_BASE}/api/orders/${orderId}/status`, {
        method: 'PATCH',
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "Authorization": `Bearer ${token}`
        },
        body: JSON.stringify({ status: 'completed' })
      });

      if (response.ok) {
        fetchOrders();
      } else {
        const data = await response.json();
        window.appToast(data.error || "No se pudo finalizar el pedido.", { tone: "error" });
      }
    } catch (e) {
      console.error(e);
      window.appToast("Error de conexion con el servidor.", { tone: "error" });
    }
  };

  async function fetchOrders() {
    const token = localStorage.getItem("token");
    if (!token) {
      elAllLoading?.classList.add("hidden");
      elAllEmpty?.classList.remove("hidden");
      elAllEmpty.textContent = "Inicia sesión para ver tus contrataciones.";
      return;
    }

    try {
      const response = await fetch(`${API_BASE}/api/orders`, {
        headers: {
          "Accept": "application/json",
          "Authorization": `Bearer ${token}`
        }
      });

      if (!response.ok) throw new Error(`HTTP ${response.status}`);

      const data = await response.json();
      const orders = Array.isArray(data) ? data : (data?.data || []);

      elAllLoading?.classList.add("hidden");

      if (!orders.length) {
        elAll.innerHTML = "";
        elRecent.innerHTML = "";
        elAllEmpty?.classList.remove("hidden");
        elRecentEmpty?.classList.remove("hidden");
        return;
      }

      elAllEmpty?.classList.add("hidden");
      elAll.innerHTML = orders.map(buildCard).join("");

      const recent = orders.slice(0, 3);
      if (recent.length) {
        elRecentEmpty?.classList.add("hidden");
        elRecent.innerHTML = recent.map(buildCard).join("");
      } else {
        elRecentEmpty?.classList.remove("hidden");
      }
    } catch (err) {
      elAllLoading?.classList.add("hidden");
      elAllEmpty?.classList.remove("hidden");
      elAllEmpty.textContent = "Error al cargar contrataciones.";
      console.error(err);
    }
  }

  fetchOrders();
</script>
