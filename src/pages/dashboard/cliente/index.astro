---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

const userName = "Sara Lopez";

// Datos de ejemplo
const recommendedFreelancers = [
  { id: 1, name: "Ana Martínez", rating: 4.9, reviews: 342, image: "/ana.jpg" },
  { id: 2, name: "Carlos Gómez", rating: 4.8, reviews: 215, image: "/images/carlos.jpg" },
  { id: 3, name: "Laura Herrera", rating: 5.0, reviews: 189, image: "/images/laura.jpg" },
  { id: 4, name: "Diego Torres", rating: 4.7, reviews: 456, image: "/images/diego.jpg" },
];

const activeProjects = [
  { title: "Rediseño sitio web Helium", freelancer: "Ana Martínez", progress: 68 },
  { title: "Contenido blog + SEO 2026", freelancer: "Laura Herrera", progress: 92 },
];

const popularServices = [
  { title: "Logo Profesional", image: "/images/logo-service.jpg" },
  { title: "Edición de Video", image: "/images/video-service.jpg" },
  { title: "Posicionamiento SEO", image: "/images/seo-service.jpg" },
  { title: "Diseño Web Moderno", image: "/images/web-service.jpg" },
];
---


<DashboardLayout title="Cliente" userRole="cliente">

<!-- HERO -->
<section 
  class="relative h-105 rounded-2xl overflow-hidden bg-cover bg-center mb-14"
  style="background-image: url('/hero.jpg');"
>
  <div class="absolute inset-0 bg-black/50"></div>

  <div class="relative z-10 flex flex-col justify-center h-full px-10 max-w-3xl">
    <h2 class="text-4xl font-black text-white mb-4">
      Encuentra el talento perfecto
    </h2>

    <p class="text-slate-200 mb-6">
      Conecta con freelancers profesionales y lleva tu proyecto al siguiente nivel.
    </p>

    <a 
      href="/dashboard/cliente/catalogo"
      class="bg-purple-700 hover:bg-purple-600 px-8 py-3 rounded-xl font-bold text-white w-fit"
    >
      Explorar servicios →
    </a>
  </div>
</section>


<!-- FREELANCERS RECOMENDADOS -->
<section class="mb-16">

  <h2 class="text-2xl font-bold text-white mb-6">
    Recomendados para ti
  </h2>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-6">

    {recommendedFreelancers.map(f => (

      <div class="bg-slate-900 rounded-xl overflow-hidden border border-slate-800 hover:border-purple-600 transition group">

        <img 
          src={f.image} 
          alt={f.name}
          class="w-full h-60 object-cover"
        />

        <div class="p-5 text-center">

          <h3 class="text-lg font-bold text-white group-hover:text-purple-400">
            {f.name}
          </h3>

          <p class="text-yellow-400 text-sm mt-1">
            ★ {f.rating} ({f.reviews})
          </p>

          <a 
            href="/dashboard/cliente/perfilFreelance"
            class="mt-4 block w-full py-2 bg-purple-700 hover:bg-purple-600 text-white rounded-lg"
          >
            Ver perfil
          </a>

        </div>

      </div>

    ))}

  </div>

</section>


<!-- PROYECTOS ACTIVOS -->
<section class="mb-16">
  <h2 class="text-2xl font-bold text-white mb-6">
    Tus proyectos activos
  </h2>
  
  <div class="space-y-6">
    {activeProjects.map(p => (
      <div class="bg-slate-900 p-6 rounded-xl border border-slate-800">
        <div class="flex justify-between items-center">
          <div>
            
            <h3 class="text-lg font-bold text-white">
              {p.title}
            </h3>
            <p class="text-slate-400">
              con {p.freelancer}
            </p>
        </div>
        
        <div class="w-56">
          
          <div class="bg-slate-700 rounded-full h-3 overflow-hidden">
            <div class="bg-purple-600 h-3"
            style={`width:${p.progress}%`}></div>
            </div>
            <p class="text-purple-400 text-right mt-1 text-sm">
              {p.progress}%
              </p>
            </div>
          </div>
         </div>
        ))}
      </div>
    </section>
    <section>
      <h2 class="text-2xl font-bold text-white mb-6">
        Servicios populares
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {popularServices.map(s => (
        <div class="bg-slate-900 rounded-xl overflow-hidden border border-slate-800 hover:border-purple-600 transition">
          <img src={s.image} class="w-full h-44 object-cover" />
          <div class="p-4 text-center">
            
            <h3 class="text-white font-bold">
              {s.title}
            </h3>
          </div>
         </div>
        ))}
      </div>
    </section>
    
  
</D>