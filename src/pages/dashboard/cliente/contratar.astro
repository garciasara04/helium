---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

// Nota: Estos valores estáticos los podrías cargar dinámicamente después
// igual que hiciste en la vista de Detalles, pero por ahora los dejamos así.
const freelancerName = "Carlos Ramírez";
const serviceName = "Desarrollo de Landing Page";
---

<DashboardLayout title="Contratar servicio" userRole="cliente">

<section class="max-w-3xl mx-auto mt-10 px-6">
  
  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow-xl">

    <div class="mb-8">
      <h2 class="text-2xl font-bold text-white">
        Contratar servicio
      </h2>

      <p class="text-slate-400 mt-2">
        Estás solicitando 
        <span class="text-purple-500">{serviceName}</span> a
        <span class="text-purple-500">{freelancerName}</span>
      </p>
    </div>

    <form id="contract-form" class="space-y-6">

      <div>
        <label class="block text-sm text-slate-300 mb-2">
          Describe lo que necesitas *
        </label>

        <textarea
          id="requirements-input"
          required
          rows="5"
          placeholder="Ejemplo: Necesito una página web con diseño moderno, responsive y optimizada para SEO..."
          class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3 text-slate-200 focus:outline-none focus:ring-2 focus:ring-purple-500"
        ></textarea>
      </div>

      <div class="grid md:grid-cols-2 gap-6">

        <div>
          <label class="block text-sm text-slate-300 mb-2">
            Presupuesto (opcional)
          </label>

          <input
            type="number"
            placeholder="$"
            class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3 text-slate-200 focus:ring-2 focus:ring-cyan-500 outline-none"
          />
        </div>

        <div>
          <label class="block text-sm text-slate-300 mb-2">
            Fecha límite
          </label>

          <input
            type="date"
            class="w-full bg-slate-950 border border-slate-700 rounded-xl px-4 py-3 text-slate-200 focus:ring-2 focus:ring-cyan-500 outline-none"
          />
        </div>

      </div>

      <div>
        <label class="block text-sm text-slate-300 mb-2">
          Adjuntar archivo (opcional)
        </label>

        <input
          type="file"
          class="w-full text-slate-300 file:bg-purple-500 file:border-0 file:px-4 file:py-2 file:rounded-lg file:text-white file:cursor-pointer bg-slate-950 border border-slate-700 rounded-xl"
        />

        <p class="text-xs text-slate-500 mt-2">
          Puedes adjuntar documentos, imágenes o especificaciones del proyecto.
        </p>
      </div>

      <div class="flex items-start gap-3">
        <input
          id="confirm-order"
          type="checkbox"
          required
          class="mt-1 accent-purple-500"
        />

        <p class="text-sm text-slate-400">
          Confirmo que la información proporcionada es correcta y deseo contratar este servicio.
        </p>
      </div>

      <div class="flex gap-4 pt-4">

        <button
          id="submit-order-btn"
          type="submit"
          class="flex-1 bg-purple-600 hover:bg-purple-700 text-white font-semibold py-3 rounded-xl transition"
        >
          Contratar servicio
        </button>

        <button
          type="button"
          class="flex-1 border border-slate-700 hover:bg-slate-800 text-slate-300 py-3 rounded-xl transition"
          onclick="history.back()"
        >
          Cancelar
        </button>

      </div>

    </form>

  </div>

</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contract-form');
    const requirementsInput = document.getElementById('requirements-input');
    const confirmOrderInput = document.getElementById('confirm-order');
    const submitBtn = document.getElementById('submit-order-btn');

    if (!form || !requirementsInput || !confirmOrderInput) return;

    function ensureErrorEl(input, key) {
      const id = `error-${key}`;
      let errorEl = document.getElementById(id);
      if (errorEl) return errorEl;

      errorEl = document.createElement('p');
      errorEl.id = id;
      errorEl.className = 'hidden mt-2 text-xs text-red-300';

      const target = input.closest('div') || input.parentElement;
      target?.appendChild(errorEl);
      return errorEl;
    }

    function setFieldError(input, key, message) {
      const errorEl = ensureErrorEl(input, key);
      input.classList.add('border-red-500');
      input.classList.remove('border-purple-500', 'border-cyan-500');
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.classList.remove('hidden');
      }
    }

    function clearFieldError(input, key) {
      const errorEl = ensureErrorEl(input, key);
      input.classList.remove('border-red-500');
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.classList.add('hidden');
      }
    }

    function validateForm(serviceId) {
      let isValid = true;

      clearFieldError(requirementsInput, 'requirements');
      clearFieldError(confirmOrderInput, 'confirm-order');

      const requirements = String(requirementsInput.value || '').trim();
      if (!requirements) {
        setFieldError(requirementsInput, 'requirements', 'Debes describir lo que necesitas.');
        isValid = false;
      } else if (requirements.length < 15) {
        setFieldError(requirementsInput, 'requirements', 'Agrega más detalle (mínimo 15 caracteres).');
        isValid = false;
      }

      if (!confirmOrderInput.checked) {
        setFieldError(confirmOrderInput, 'confirm-order', 'Debes confirmar antes de contratar.');
        isValid = false;
      }

      if (!serviceId) {
        window.appToast('No se encontró el ID del servicio. Regresa al catálogo.', { tone: 'warning' });
        isValid = false;
      }

      return isValid;
    }

    requirementsInput.addEventListener('input', () => clearFieldError(requirementsInput, 'requirements'));
    confirmOrderInput.addEventListener('change', () => clearFieldError(confirmOrderInput, 'confirm-order'));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const token = localStorage.getItem('token');
      if (!token) {
        window.location.href = '/login';
        return;
      }

      const params = new URLSearchParams(window.location.search);
      const serviceId = params.get('id');

      if (!validateForm(serviceId)) {
        window.appToast('Revisa los campos resaltados.', { tone: 'warning' });
        return;
      }

      try {
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Procesando...';
          submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
        }

        const response = await fetch('http://127.0.0.1:8000/api/orders', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({
            service_id: serviceId,
            requirements: requirementsInput.value.trim()
          })
        });

        const data = await response.json().catch(() => ({}));

        if (response.ok) {
          window.appToast('Servicio contratado con éxito.', { tone: 'success' });
          window.location.href = '/dashboard/cliente/red';
        } else {
          window.appToast(data.error || data.message || 'Hubo un problema al procesar tu solicitud.', { tone: 'error' });
        }
      } catch (error) {
        console.error('Error de fetch:', error);
        window.appToast('Hubo un error de conexión con el servidor.', { tone: 'error' });
      } finally {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Contratar servicio';
          submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
      }
    });
  });
</script>

</DashboardLayout>




