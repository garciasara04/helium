---
import DashboardLayout from "../../../layouts/DashboardLayout.astro"
---

<DashboardLayout userRole="cliente" >

  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-10 lg:py-16">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6">
      <div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white">
          Catálogo de Servicios
        </h1>
        <p class="text-xl text-slate-400 mt-3">
          6,687 servicios para sitios web y software con IA
        </p>
      </div>

      <div class="flex items-center gap-4">
        <button class="px-6 py-3 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition">
          Catálogo Pro
        </button>
        <button class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white font-medium rounded-lg transition border border-slate-600">
          Catálogo completo
        </button>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
      
      <aside class="lg:col-span-1 space-y-8">
        <div class="bg-slate-900/80 border border-slate-700 rounded-xl p-6">
          <h3 class="text-xl font-bold text-white mb-6">Opciones de servicio</h3>

          <div class="space-y-6">
            <div>
              <h4 class="font-semibold text-slate-300 mb-3">Tipo de aplicación</h4>
              <ul class="space-y-2 text-slate-400">
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> Web</label></li>
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> Móvil</label></li>
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> Escritorio</label></li>
              </ul>
            </div>

            <div>
              <h4 class="font-semibold text-slate-300 mb-3">Lenguaje de programación</h4>
              <ul class="space-y-2 text-slate-400">
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> Python</label></li>
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> JavaScript</label></li>
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> Java</label></li>
              </ul>
            </div>

            <div>
              <h4 class="font-semibold text-slate-300 mb-3">Frameworks</h4>
              <ul class="space-y-2 text-slate-400">
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> React / Next.js</label></li>
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> Node.js</label></li>
                <li><label class="flex items-center gap-2"><input type="checkbox" class="accent-purple-600" /> Django</label></li>
              </ul>
            </div>
          </div>
        </div>
      </aside>

      <div class="lg:col-span-3">
        <div id="contenedor-freelancers" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          </div>

        <div class="mt-16 text-center">
          <button class="px-10 py-4 bg-purple-700 hover:bg-purple-600 text-white font-bold rounded-xl transition shadow-lg shadow-purple-900/30">
            Ver más freelancers →
          </button>
        </div>
      </div>
      
    </div>
  </div>

</DashboardLayout>

<script>
const contenedor = document.getElementById('contenedor-freelancers');

async function cargarfreelancers() {
  try{
    const parametro = new URLSearchParams(window.location.search);
    const category_id = parametro.get('category_id');
    const name = parametro.get('search')
    const skill = parametro.get('skill_id');
    let urll = 'http://127.0.0.1:8000/api/services';

    if(category_id){
      urll = `http://127.0.0.1:8000/api/services?category_id=${category_id}`; 
    }
      else if(name){
        urll= `http://127.0.0.1:8000/api/services?search=${name}`;
      }
      else if(skill){
        urll = `http://127.0.0.1:8000/api/services?skill_id=${skill}`
      }
    const respuesta = await fetch(urll);
    const datos = await respuesta.json();
    const servicios = datos.services;

    contenedor.innerHTML = '';
    if (!servicios){
      contenedor.innerHTML = '<p class="text-slate-400 col-span-full text-center py-10">Aún no hay servicios registrados en esta categoría.</p>';
        return;
    }

    servicios.forEach(f => {
        // AQUÍ ESTÁN LOS CAMBIOS VISUALES (Tailwind)
        const tarjetaHTML = `
          <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-purple-600 transition-all duration-300 group shadow-lg hover:shadow-purple-900/20 flex flex-col h-full">
            <div class="h-48 bg-linear-to-br from-slate-800 to-slate-900 relative shrink-0">
              <img 
                src="${f.photo ? 'http://127.0.0.1:8000/storage/' + f.photo : 'https://placehold.co/400'}" 
                alt="${f.freelancer.name}"
                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition"
              />
            </div>

            <div class="p-6 flex flex-col flex-grow">
              
              <div class="mb-3">
                <h3 class="text-xl font-bold text-white group-hover:text-purple-400 transition line-clamp-1">
                  ${f.freelancer.name}
                </h3>
                <span class="text-sm text-purple-400 font-medium block mt-1 line-clamp-1">
                  ${f.freelancer.profession || 'Freelancer'}
                </span>
              </div>

              <p class="text-slate-300 mb-4 line-clamp-2">
                ${f.title}
              </p>
              
              <div class="mb-4">
                <span class="text-xs px-3 py-1 bg-slate-800 rounded-full text-purple-300 inline-block">
                  ${f.category}
                </span>
              </div>

              <div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-800 gap-4">
                <span class="text-lg font-bold text-purple-400 truncate">
                  $${f.price}
                </span>
                
                <a 
                  href="perfilFreelance?id=${f.id}"   
                  class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shrink-0 text-center text-sm"
                >
                  Ver detalle
                </a>
              </div>
            </div>
          </div>
        `;
        
        contenedor.innerHTML += tarjetaHTML;
      });

    } catch (error) {
      console.error("Error al hacer el fetch:", error);
      contenedor.innerHTML = '<p class="text-red-500 col-span-full text-center py-10">Error al cargar los datos desde el servidor.</p>';
    }
  }

  cargarfreelancers();

</script>