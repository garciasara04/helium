---
import DashboardLayout from "../../../layouts/DashboardLayout.astro"
---

<DashboardLayout userRole="cliente" >

  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-10 lg:py-16">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6">
      <div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white">
          Catálogo de Servicios
        </h1>
        <p class="text-xl text-slate-400 mt-3">
          6,687 servicios para sitios web y software con IA
        </p>
      </div>

      <div class="flex items-center gap-4">
        <a href="/dashboard/cliente/catalogo" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white font-medium rounded-lg transition border border-slate-600">
          Catálogo completo
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-10">
      
       <aside class="lg:col-span-1 space-y-8">
        <div class="bg-slate-900/80 border border-slate-700 rounded-xl p-6 sticky top-24 shadow-lg">
          
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
            </svg>
            Explorar por
          </h3>

          <div class="mb-8">
            <h4 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Categorías</h4>
            <div class="flex flex-col gap-2">
              <a href="?category_id=1" class="px-4 py-2.5 bg-slate-800 hover:bg-purple-900/40 border border-transparent hover:border-purple-700 text-slate-300 hover:text-white rounded-lg transition-all text-sm flex justify-between items-center group">
                Desarrollo Web
                <span class="text-xs bg-slate-700 group-hover:bg-purple-600 px-2 py-0.5 rounded-full transition">Ver</span>
              </a>
              <a href="?category_id=2" class="px-4 py-2.5 bg-slate-800 hover:bg-purple-900/40 border border-transparent hover:border-purple-700 text-slate-300 hover:text-white rounded-lg transition-all text-sm flex justify-between items-center group">
                Apps Móviles
                <span class="text-xs bg-slate-700 group-hover:bg-purple-600 px-2 py-0.5 rounded-full transition">Ver</span>
              </a>
              <a href="?category_id=3" class="px-4 py-2.5 bg-slate-800 hover:bg-purple-900/40 border border-transparent hover:border-purple-700 text-slate-300 hover:text-white rounded-lg transition-all text-sm flex justify-between items-center group">
                Diseño UI / UX
                <span class="text-xs bg-slate-700 group-hover:bg-purple-600 px-2 py-0.5 rounded-full transition">Ver</span>
              </a>
            </div>
          </div>

          <div>
            <h4 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Habilidades</h4>
            <div class="flex flex-wrap gap-2">
              <a href="?skill_id=4" class="px-3 py-1.5 border border-slate-700 hover:border-purple-500 bg-slate-800/50 hover:bg-purple-900/30 text-slate-300 hover:text-purple-300 rounded-full text-xs transition cursor-pointer">
                # React
              </a>
              <a href="?skill_id=1" class="px-3 py-1.5 border border-slate-700 hover:border-purple-500 bg-slate-800/50 hover:bg-purple-900/30 text-slate-300 hover:text-purple-300 rounded-full text-xs transition cursor-pointer">
                # Laravel
              </a>
              <a href="?skill_id=6" class="px-3 py-1.5 border border-slate-700 hover:border-purple-500 bg-slate-800/50 hover:bg-purple-900/30 text-slate-300 hover:text-purple-300 rounded-full text-xs transition cursor-pointer">
                # Node.js
              </a>
              <a href="?skill_id=5" class="px-3 py-1.5 border border-slate-700 hover:border-purple-500 bg-slate-800/50 hover:bg-purple-900/30 text-slate-300 hover:text-purple-300 rounded-full text-xs transition cursor-pointer">
                # View.js
              </a>
            </div>
          </div>

          <div class="mt-8 pt-6 border-t border-slate-800">
            <a href="/dashboard/cliente/catalogo" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-800 rounded-lg transition border border-transparent hover:border-slate-700">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              Limpiar filtros
            </a>
          </div>

        </div>
      </aside>

      <div class="lg:col-span-3">
        <div id="contenedor-freelancers" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          </div>

        <div class="mt-16 text-center">
          <a href="/dashboard/cliente/catalogo" class="px-10 py-4 bg-purple-700 hover:bg-purple-600 text-white font-bold rounded-xl transition shadow-lg shadow-purple-900/30">
            Ver más servicios→
          </a>
        </div>
      </div>
      
    </div>
  </div>

</DashboardLayout>

<script>
const contenedor = document.getElementById('contenedor-freelancers');

async function cargarfreelancers() {
  try{
    const parametro = new URLSearchParams(window.location.search);
    const category_id = parametro.get('category_id');
    const name = parametro.get('search')
    const skill = parametro.get('skill_id');
    let urll = 'http://127.0.0.1:8000/api/services';

    if(category_id){
      urll = `http://127.0.0.1:8000/api/services?category_id=${category_id}`; 
    }
      else if(name){
        urll= `http://127.0.0.1:8000/api/services?search=${name}`;
      }
      else if(skill){
        urll = `http://127.0.0.1:8000/api/services?skill_id=${skill}`
      }
    const respuesta = await fetch(urll);
    const datos = await respuesta.json();
    const servicios = datos.services;
    console.log(datos)
    contenedor.innerHTML = '';
    if (!servicios){
      contenedor.innerHTML = '<p class="text-slate-400 col-span-full text-center py-10">Aún no hay servicios registrados en esta categoría.</p>';
        return;
    }

    servicios.forEach(f => {
        
        const tarjetaHTML = `
          <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-purple-600 transition-all duration-300 group shadow-lg hover:shadow-purple-900/20 flex flex-col h-full">
            <div class="h-48 bg-linear-to-br from-slate-800 to-slate-900 relative shrink-0">
              <img 
                src="${f.photo ? 'http://127.0.0.1:8000/storage/' + f.photo : 'https://placehold.co/400'}" 
                alt="${f.freelancer.name}"
                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition"
              />
            </div>

            <div class="p-6 flex flex-col flex-grow">
              
              <div class="mb-3">
                <h3 class="text-xl font-bold text-white group-hover:text-purple-400 transition line-clamp-1">
                  ${f.freelancer.name}
                </h3>
                <span class="text-sm text-purple-400 font-medium block mt-1 line-clamp-1">
                  ${f.freelancer.profession || 'Freelancer'}
                </span>
              </div>

              <p class="text-slate-300 mb-4 line-clamp-2">
                ${f.title}
              </p>
              
              <div class="mb-4">
                <span class="text-xs px-3 py-1 bg-slate-800 rounded-full text-purple-300 inline-block">
                  ${f.category}
                </span>
              </div>

              <div class="flex items-center justify-between mt-auto pt-4 border-t border-slate-800 gap-4">
                <span class="text-lg font-bold text-purple-400 truncate">
                  $${f.price}
                </span>
                
                <a 
                  href="perfilFreelance?id=${f.id}"   
                  class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shrink-0 text-center text-sm"
                >
                  Ver detalle
                </a>
              </div>
            </div>
          </div>
        `;
        contenedor.innerHTML += tarjetaHTML;
      });

    } catch (error) {
      console.error("Error al hacer el fetch:", error);
      contenedor.innerHTML = '<p class="text-red-500 col-span-full text-center py-10">Error al cargar los datos desde el servidor.</p>';
    }
  }

  cargarfreelancers();

</script>