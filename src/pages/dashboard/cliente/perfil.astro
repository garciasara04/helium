---
// src/pages/dashboard/cliente/perfil.astro
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
---

<DashboardLayout  userRole="cliente">
  <div class="min-h-screen bg-slate-950 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="bg-slate-900/80 backdrop-blur-md border border-slate-800 rounded-2xl shadow-2xl shadow-purple-900/20 overflow-hidden">
        <div class="relative h-48 bg-linear-to-r from-purple-900/40 to-indigo-900/40">
          <div class="absolute -bottom-16 left-1/2 -translate-x-1/2">
            <div class="relative">
              <img id="profile-photo" src="https://via.placeholder.com/400" alt="Foto de perfil"
              class="w-32 h-32 rounded-full object-cover border-4 border-purple-600 shadow-xl shadow-purple-900/40"/>
              <div class="absolute -bottom-1 -right-1 bg-green-500 w-6 h-6 rounded-full border-4 border-slate-900">
              </div>
            </div>
          </div>
        </div>
        <div class="pt-20 pb-10 px-6 sm:px-10 text-center">
          <h1 id="profile-name" class="text-3xl sm:text-4xl font-bold text-white mb-2">
            Cargando...
          </h1>
          <p id="profile-email" class="text-lg text-purple-400 font-medium mb-8">
            ...
          </p>
          <a
          href="/dashboard/cliente/editar-perfil"
          class="inline-flex items-center gap-2 px-8 py-4 bg-purple-700 hover:bg-purple-600 text-white font-semibold text-lg rounded-xl transition-all duration-300 shadow-lg shadow-purple-900/40 hover:shadow-purple-600/50 transform hover:-translate-y-1">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round"stroke-linejoin="round"stroke-width="2"d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
          </svg>
          Actualizar perfil
        </a>
        <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-6 text-left">
          <div class="bg-slate-800/50 p-6 rounded-xl border border-slate-700">
            <h3 class="text-lg font-semibold text-purple-300 mb-3">
              Datos básicos
            </h3>
            <p class="text-slate-300 leading-relaxed">
              <span class="font-medium text-white">Nombre:</span> <span id="basic-name">...</span>
              <br>
              <span class="font-medium text-white">Correo:</span> <span id="basic-email">...</span>
              <br>
              <span class="font-medium text-white">Teléfono:</span> <span id="basic-phone">...</span>
            </p>
          </div>
          <div class="bg-slate-800/50 p-6 rounded-xl border border-slate-700">
            <h3 class="text-lg font-semibold text-purple-300 mb-3">
              Estado de cuenta
            </h3>
            <p class="text-slate-300 leading-relaxed">
              Cuenta verificada ✓
              <br>
              Miembro activo
              <br>
              Rol: Cliente
            </p>
          </div>
        </div>
      </div>
    </div>
    
    <div class="mt-10 text-center">
      <button onclick="cerrarSesion()"
      class="text-red-400 hover:text-red-300 font-medium text-lg transition flex items-center justify-center gap-2 mx-auto">
      
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round"stroke-linejoin="round"stroke-width="2"d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Cerrar sesión
    </button>
  </div>
</div>

</div>

<script>
  async function cargarPerfil() {
    const token = localStorage.getItem('token');
    
    if(!token){
      window.location.href = '/login';
      return;
    }

    try {
      const response = await fetch('http://127.0.0.1:8000/api/profile', {
        method: 'GET',
        headers: {
          'Accept': 'application/json',
          'Authorization': `Bearer ${token}`
        }
      });
      const user = await response.json();
      const fullName = `${user.names || ''} ${user.last_names || ''}`.trim() || 'Sin nombre';

      document.getElementById('profile-name').innerText = fullName;
      document.getElementById('basic-name').innerText = fullName;
      document.getElementById('profile-email').innerText = user.email || 'Sin correo';
      document.getElementById('basic-email').innerText = user.email || 'Sin correo';
      document.getElementById('basic-phone').innerText = user.phone || 'No registrado';

  
      if (user.photo) {
        document.getElementById('profile-photo').src = `http://127.0.0.1:8000/storage/${user.photo}`;
      }
      
    } catch (error) {
      console.log("Error cargando perfil:", error);
      document.getElementById('profile-name').innerText = "Error al cargar";
    }
  }

  cargarPerfil();

  window.cerrarSesion = function() {
    if(confirm('¿Seguro que deseas cerrar sesión?')) {
      
      localStorage.removeItem('token');
      // Lo mandamos al login
      window.location.href = '/login';
    }
  }
</script>

</DashboardLayout>