---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Detalle del Servicio" userRole="cliente">

<div class="min-h-screen bg-linear-to-b from-slate-950 to-slate-900 text-slate-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <div class="flex flex-col md:flex-row gap-10 items-start md:items-center">
      <div class="shrink-0 mx-auto md:mx-0">
        <div class="relative">
          <img
            id="f-photo"
            src="https://via.placeholder.com/400"
            alt="Foto Freelancer"
            class="w-40 h-40 sm:w-48 sm:h-48 md:w-56 md:h-56 rounded-full object-cover border-4 border-purple-600 shadow-2xl shadow-purple-900/30"
          />
          <div class="absolute -bottom-3 -right-3 bg-green-500 w-8 h-8 rounded-full border-4 border-slate-900"></div>
        </div>
      </div>

      <div class="flex-1 text-center md:text-left">
        <h1 id="f-name" class="text-3xl sm:text-4xl font-bold text-white">
          Cargando...
        </h1>
        
        <p id="f-profession" class="mt-2 text-xl sm:text-2xl text-purple-400 font-medium">
          ...
        </p>

        <div class="mt-4 flex items-center justify-center md:justify-start gap-6 flex-wrap">
          <div class="flex items-center gap-2">
            <span class="text-yellow-400 text-3xl">★</span>
            <span class="text-2xl font-bold">5.0</span>
            <span class="text-slate-400">(Nuev@)</span>
          </div>
        </div>

        <div class="mt-6 inline-block bg-purple-700/30 backdrop-blur-sm px-6 py-3 rounded-full border border-purple-500/30">
          <span class="text-2xl font-bold text-purple-300" id="s-price">$...</span>
          <span class="text-slate-300"> por este servicio</span>
        </div>
      </div>
    </div>

    <section class="mt-16">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-6 border-b border-purple-800/50 pb-4">
        Sobre el servicio
      </h2>
      <p id="s-description" class="text-lg leading-relaxed text-slate-300 whitespace-pre-line">
        Cargando descripción del servicio...
      </p>
    </section>

    <section class="mt-20">
      <h2 class="text-2xl sm:text-3xl font-bold text-white mb-10 text-center">
        Servicio a contratar
      </h2>

      <div id="service-card-container" class="max-w-md mx-auto">
        </div>
    </section>

    <div class="mt-16 text-center">
      <button 
        id="btn-contratar"
        class="bg-purple-600 hover:bg-purple-700 text-white font-bold text-lg px-10 py-5 rounded-xl shadow-lg shadow-purple-900/30 transition-all duration-300 transform hover:scale-105"
      >
        Contratar servicio →
      </button>
    </div>

  </div>
</div>

<script>

  const params = new URLSearchParams(window.location.search);
  const serviceId = params.get('id');

  async function cargarDetalleServicio() {
    if (!serviceId) {
      alert("No se especificó un servicio.");
      window.location.href = '/dashboard/cliente/catalogo'; 
      return;
    }

    try {
      const response = await fetch(`http://127.0.0.1:8000/api/services/${serviceId}`, {
        method: 'GET',
        headers: {
          'Accept': 'application/json'
        }
      });

      if (!response.ok) throw new Error("Servicio no encontrado");

      const service = await response.json();
      
      const profile = service.freelancer_profile; 
      const user = profile.user;

      document.getElementById('f-name').innerText = `${user.names} ${user.last_names}`;
      document.getElementById('f-profession').innerText = profile.profession || 'Freelancer Independiente';
      if (user.photo) {
        document.getElementById('f-photo').src = `http://127.0.0.1:8000/storage/${user.photo}`;
      }

      document.getElementById('s-price').innerText = `$${service.price}`;
      document.getElementById('s-description').innerText = service.description;

      const serviceContainer = document.getElementById('service-card-container');
      const serviceImage = service.photo ? `http://127.0.0.1:8000/storage/${service.photo}` : 'https://placehold.co/800x400';
      
      serviceContainer.innerHTML = `
        <div class="bg-slate-800/50 backdrop-blur-sm border border-slate-700/50 rounded-2xl overflow-hidden hover:border-purple-600/50 transition-all duration-300 group shadow-xl">
          <div class="aspect-video relative overflow-hidden">
              <img
                src="${serviceImage}"
                alt="${service.title}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
              <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/30 to-transparent"></div>
              <div class="absolute bottom-4 left-4 right-4">
                <span class="text-xs font-bold text-purple-400 uppercase tracking-wider mb-1 block">${service.category?.name || 'Servicio'}</span>
                <h3 class="text-xl font-bold text-white line-clamp-2 drop-shadow-md">
                    ${service.title}
                </h3>
              </div>
          </div>
        </div>
      `;

      document.getElementById('btn-contratar').onclick = async () => {
        try {
          const token = localStorage.getItem('token');
          if(!token) return window.location.href = '/login'; 
          
          const response = await fetch('http://127.0.0.1:8000/api/orders', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({
              service_id: serviceId 
            })
          });

          const data = await response.json();
          console.log(data);

          if(response.ok) {
            console.log('pedido creado con exito')
          }
          
        } catch (error) {
          console.log(error);
        }
      };

    } catch (error) {
      console.error(error);
      document.getElementById('f-name').innerText = "Error al cargar";
      document.getElementById('s-description').innerText = "No se pudo cargar la información de este servicio.";
    }
  }

  cargarDetalleServicio();
</script>

</DashboardLayout>