---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout  userRole="freelance">

<div class="max-w-3xl mx-auto">

<form id="serviceForm" class="space-y-6 bg-slate-900 p-8 rounded-xl border border-slate-800">

  <!-- Titulo -->
  <div>
    <label class="block text-sm mb-2">Título del servicio</label>
    <input
      type="text"
      id="title"
      name="title"
      placeholder="Ej: Desarrollo de API REST con Laravel"
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:border-purple-500"
      required
    />
  </div>

  <!-- Descripción -->
  <div>
    <label class="block text-sm mb-2">Descripción</label>
    <textarea
      id="description"
      name="description"
      rows="4"
      placeholder="Describe que incluye tu servicio..."
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:border-purple-500"
      required
    ></textarea>
  </div>

  <!-- Categoria -->
  <div>
    <label class="block text-sm mb-2">Categoría</label>

    <select
      id="category_id"
      name="category_id"
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:border-purple-500"
    >
      <option value="1">Desarrollo Web</option>
      <option value="2">Desarrollo Móvil</option>
      <option value="3">Diseño Gráfico</option>
      <option value="4">Marketing Digital</option>
      <option value="5">Redacción y Traducción</option>
      <option value="6">Edición de Video</option>
      <option value="7">Soporte TI</option>
    </select>
  </div>

  <!-- Precio -->
  <div>
    <label class="block text-sm mb-2">Precio (COP)</label>
    <input
      type="number"
      id="price"
      name="price"
      placeholder="450000"
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:border-purple-500"
      required
    />
  </div>

  <!-- Tiempo entrega -->
  <div>
    <label class="block text-sm mb-2">Tiempo de entrega (días)</label>
    <input
      type="number"
      id="delivery_time"
      name="delivery_time"
      placeholder="7"
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:border-purple-500"
      required
    />
  </div>

  <!-- Revisiones -->
  <div>
    <label class="block text-sm mb-2">Revisiones (maximo 3)</label>
    <input
      type="number"
      id="revisions"
      name="revisions"
      max="3"
      placeholder="2"
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:border-purple-500"
      required
    />
  </div>
  
  <!-- Requisitos -->
  <div>
    <label class="block text-sm mb-2">Requisitos del cliente</label>
    <textarea
      id="requirements"
      rows="3"
      name="requirements"
      placeholder="Ej: Comparte alcance del proyecto..."
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 focus:outline-none focus:border-purple-500"
    ></textarea>
  </div>
  <div>
    <label class="block text-sm mb-2">Foto de portada (Obligatoria)</label>
    <input
      type="file"
      id="photo"
      name="photo"
      accept="image/png, image/jpeg, image/webp"
      class="w-full bg-slate-800 border border-slate-700 rounded-lg px-4 py-3 text-slate-300 focus:outline-none focus:border-purple-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-purple-600 file:text-white hover:file:bg-purple-700 transition"
      required
    />
  </div>

  <!-- Botón -->
  <button
    type="submit" 
    class="w-full bg-purple-600 hover:bg-purple-700 transition py-3 rounded-lg font-semibold"
  >
  
    Publicar Servicio
  </button>

</form>

</div>

<script>
  const createService = document.getElementById('serviceForm');

  function validateCreateService(form) {
    const title = String(form.title?.value || '').trim();
    const description = String(form.description?.value || '').trim();
    const price = Number(form.price?.value || 0);
    const delivery = Number(form.delivery_time?.value || 0);
    const revisions = Number(form.revisions?.value || 0);
    const photo = form.photo?.files?.[0];

    if (!title || title.length < 5) {
      window.appToast('El título debe tener al menos 5 caracteres.', { tone: 'warning' });
      return false;
    }
    if (!description || description.length < 20) {
      window.appToast('La descripción debe tener al menos 20 caracteres.', { tone: 'warning' });
      return false;
    }
    if (!Number.isFinite(price) || price <= 0) {
      window.appToast('Ingresa un precio válido mayor a 0.', { tone: 'warning' });
      return false;
    }
    if (!Number.isFinite(delivery) || delivery < 1) {
      window.appToast('El tiempo de entrega debe ser de al menos 1 día.', { tone: 'warning' });
      return false;
    }
    if (!Number.isFinite(revisions) || revisions < 1 || revisions > 3) {
      window.appToast('Las revisiones deben estar entre 1 y 3.', { tone: 'warning' });
      return false;
    }
    if (!photo) {
      window.appToast('Debes cargar una foto de portada.', { tone: 'warning' });
      return false;
    }

    const allowed = ['image/png', 'image/jpeg', 'image/webp'];
    if (!allowed.includes(photo.type)) {
      window.appToast('La foto debe ser PNG, JPG o WEBP.', { tone: 'warning' });
      return false;
    }

    return true;
  }

  createService?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!validateCreateService(createService)) return;

    const formdata = new FormData(createService);
    const token = localStorage.getItem('token');

    try {
      const response = await fetch('http://127.0.0.1:8000/api/services', {
        method: 'POST',
        headers: {
          authorization: `Bearer ${token}`,
          Accept: 'application/json',
        },
        body: formdata
      });
      const data = await response.json().catch(() => ({}));

      if (response.ok) {
        window.appToast('Servicio creado con exito.', { tone: 'success' });
        window.location.href = '/dashboard/freelance/misServicios';
      } else {
        window.appToast(data.message || 'Datos incorrectos.', { tone: 'error' });
      }
    } catch (error) {
      console.log('error', error);
      window.appToast('Error de conexión con el servidor.', { tone: 'error' });
    }
  });
</script>

</DashboardLayout>


