---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";


---

<DashboardLayout userRole="freelance">

<div class="max-w-3xl mx-auto bg-slate-900 border border-slate-800 rounded-2xl p-8">

  <h2 class="text-xl font-semibold mb-6">
    Editar Servicio
  </h2>

  <form id="editServiceForm" class="space-y-6">

    <input type="hidden" id="serviceId" value=id />

   
    <div>
      <label class="block text-sm text-slate-400 mb-2">
        TÃ­tulo del servicio
      </label>
      <input
        name="title"
        id="title"
        type="text" required
        class="w-full bg-slate-800 border border-slate-700 rounded-xl p-3"
      />
    </div>
    <div>
      <label class="block text-sm text-slate-400 mb-2">
        DescripciÃ³n
      </label>
      <textarea
        name="description"
        id="description"
        rows="4"
        class="w-full bg-slate-800 border border-slate-700 rounded-xl p-3"
      ></textarea>
    </div>

   
    <div>
      <label class="block text-sm text-slate-400 mb-2">
        CategorÃ­a
      </label>

      <select
        id="category_id"
        name="category_id"
        class="w-full bg-slate-800 border border-slate-700 rounded-xl p-3"
      >
        <option value="1">Desarrollo Web</option>
        <option value="2">Desarrollo MÃ³vil</option>
        <option value="3">DiseÃ±o GrÃ¡fico</option>
        <option value="4">Marketing Digital</option>
        <option value="5">RedacciÃ³n y TraducciÃ³n</option>
        <option value="6">EdiciÃ³n de Video</option>
        <option value="7">Soporte TI</option>
      </select>
    </div>


    <div>
      <label class="block text-sm text-slate-400 mb-2">
        Precio
      </label>
      <input
        id="price"
        name="price"
        type="number" min="1"
        class="w-full bg-slate-800 border border-slate-700 rounded-xl p-3"
      />
    </div>

    <div>
      <label class="block text-sm text-slate-400 mb-2">
        DÃ­as de entrega
      </label>
      <input
        name="delivery_time"
        id="delivery_time"
        type="number" min="1"
        class="w-full bg-slate-800 border border-slate-700 rounded-xl p-3"
      />
    </div>

  
    <div>
      <label class="block text-sm text-slate-400 mb-2">
        Revisiones
      </label>
      <input
        name="revisions"
        id="revisions"
        type="number" min="1"
        class="w-full bg-slate-800 border border-slate-700 rounded-xl p-3"
      />
    </div>
    <div>
      <label class="block text-sm text-slate-400 mb-2">
        photo
      </label>
      <input
        id="photo"
        name="photo"
        type="file"
        class="w-full bg-slate-800 border border-slate-700 rounded-xl p-3"
      />
    </div>

   
    <div>
      <label class="block text-sm text-slate-400 mb-2">
        Requisitos del cliente
      </label>
      <textarea
        name="requirements"
        id="requirements"
        rows="3"
        class="w-full bg-slate-800 border border-slate-700 rounded-xl p-3"
      ></textarea>
    </div>

    <button
      type="submit"
      class="w-full bg-purple-600 hover:bg-purple-700 transition py-3 rounded-xl font-semibold"
    >
      Actualizar servicio
    </button>

  </form>

</div>

<script>
  const form = document.getElementById('editServiceForm');
  const token = localStorage.getItem('token');
  const parametros = new URLSearchParams(window.location.search);
  const serviceId= parametros.get('id');

  if (!token) window.location.href = '/login';

  function validateEditService(formEl) {
    const title = String(formEl.title?.value || '').trim();
    const description = String(formEl.description?.value || '').trim();
    const price = Number(formEl.price?.value || 0);
    const delivery = Number(formEl.delivery_time?.value || 0);
    const revisions = Number(formEl.revisions?.value || 0);

    if (!title || title.length < 5) {
      window.appToast('El título debe tener al menos 5 caracteres.', { tone: 'warning' });
      return false;
    }
    if (!description || description.length < 20) {
      window.appToast('La descripción debe tener al menos 20 caracteres.', { tone: 'warning' });
      return false;
    }
    if (!Number.isFinite(price) || price <= 0) {
      window.appToast('Ingresa un precio válido mayor a 0.', { tone: 'warning' });
      return false;
    }
    if (!Number.isFinite(delivery) || delivery < 1) {
      window.appToast('El tiempo de entrega debe ser de al menos 1 día.', { tone: 'warning' });
      return false;
    }
    if (!Number.isFinite(revisions) || revisions < 1 || revisions > 3) {
      window.appToast('Las revisiones deben estar entre 1 y 3.', { tone: 'warning' });
      return false;
    }
    return true;
  }

  form?.addEventListener('submit', async (e)=>{
    e.preventDefault();

    if (!validateEditService(form)) return;

    try {
      const formdata = new FormData(form);
      formdata.append('_method', 'put');
      const response = await fetch(`http://127.0.0.1:8000/api/services/${serviceId}`,{
        method: 'POST',
        headers: {
          Accept: 'application/json',
          Authorization: `Bearer ${token}`,
        },
        body: formdata
      });
      const data = await response.json().catch(() => ({}));
      if (response.ok) {
        window.appToast('Servicio actualizado correctamente.', { tone: 'success' });
      } else {
        window.appToast(data.message || 'No se pudo actualizar el servicio.', { tone: 'error' });
      }
    } catch (error) {
      console.log(error);
      window.appToast('Error de conexión con el servidor.', { tone: 'error' });
    }
  });
</script>

</DashboardLayout>



