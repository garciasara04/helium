---
// src/pages/dashboard/freelance/index.astro
import DashboardLayout from "../../../layouts/DashboardLayout.astro";

// Datos de ejemplo
const user = {
  name: "Sara",
  level: "Pro",
  rating: 4.8,
  reviews: 42,
  monthlyEarnings: 2850,
  monthlyChange: "+12%",
  activeOrders: 5,
  newRequests: 3,
  unreadMessages: 7,
};

const recentOrders = [
  { client: "Juan Pérez", service: "Gestión de leads bilingüe", status: "En proceso", deadline: "28 Mar 2026", action: "Entregar" },
  { client: "María Gómez", service: "Atención al cliente nivel 1", status: "Pendiente", deadline: "30 Mar 2026", action: "Ver" },
  { client: "Carlos Ruiz", service: "Soporte técnico remoto", status: "En revisión", deadline: "25 Mar 2026", action: "Abrir chat" },
];
---

<DashboardLayout userRole="freelance">

<div class="min-h-screen bg-slate-900 pt-8 pb-16">

  <!-- Bienvenida -->
  <section class="mb-12 max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">
    <p class="mt-2 text-lg text-slate-400">
      Aquí está el resumen de tu actividad de hoy
    </p>

    <div class="mt-6 flex flex-wrap gap-4">

      <span class="px-5 py-2 bg-purple-900/50 text-purple-300 rounded-full text-sm font-medium border border-purple-800/50">
        Nivel {user.level}
      </span>

      <span class="px-5 py-2 bg-green-900/50 text-green-300 rounded-full text-sm font-medium border border-green-800/50">
        Verificado ✓
      </span>

      <div class="flex items-center gap-3">

        <div class="w-40 h-2.5 bg-slate-800 rounded-full overflow-hidden">
          <div class="w-[78%] h-full bg-purple-600 rounded-full"></div>
        </div>

        <span class="text-sm text-slate-400">
          78% al siguiente nivel
        </span>

      </div>

    </div>

  </section>


  <!-- Cards resumen -->
  <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 mb-12">

    <div class="bg-slate-900/90 border border-slate-800 rounded-xl p-6 hover:border-purple-600/60 transition-all duration-300 shadow">

      <h3 class="text-base font-medium text-slate-400 mb-2">
        Ingresos del mes
      </h3>

      <p class="text-3xl font-bold text-purple-400">
        ${user.monthlyEarnings}
      </p>

      <p class={`text-sm mt-1 ${user.monthlyChange.startsWith('+') ? 'text-green-400' : 'text-red-400'}`}>
        {user.monthlyChange}
      </p>

    </div>


    <div class="bg-slate-900/90 border border-slate-800 rounded-xl p-6 hover:border-purple-600/60 transition-all duration-300 shadow">

      <h3 class="text-base font-medium text-slate-400 mb-2">
        Pedidos activos
      </h3>

      <p class="text-3xl font-bold text-purple-400">
        {user.activeOrders}
      </p>

    </div>


    <div class="bg-slate-900/90 border border-slate-800 rounded-xl p-6 hover:border-purple-600/60 transition-all duration-300 shadow">

      <h3 class="text-base font-medium text-slate-400 mb-2">
        Rating promedio
      </h3>

      <p class="text-3xl font-bold text-yellow-400">
        {user.rating} ★
      </p>

      <p class="text-sm text-slate-400 mt-1">
        ({user.reviews} reseñas)
      </p>

    </div>


    <div class="bg-slate-900/90 border border-slate-800 rounded-xl p-6 hover:border-purple-600/60 transition-all duration-300 shadow">

      <h3 class="text-base font-medium text-slate-400 mb-2">
        Nuevas solicitudes
      </h3>

      <p class="text-3xl font-bold text-purple-400">
        {user.newRequests}
      </p>

      <p class="text-sm text-slate-400 mt-1">
        {user.unreadMessages} mensajes sin leer
      </p>

    </div>

  </section>


  <!-- Estadísticas -->
  <section class="mb-12 max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">

    <h2 class="text-2xl font-bold text-white mb-6">
      Estadísticas
    </h2>

    <div class="bg-slate-900/90 border border-slate-800 rounded-xl p-8 h-96 flex items-center justify-center shadow">

      <p class="text-slate-400 text-xl">
        Gráfica de ingresos, servicios más vendidos y satisfacción
      </p>

    </div>

  </section>


  <!-- Pedidos activos -->
  <section class="mb-12 max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">

    <h2 class="text-2xl font-bold text-white mb-6">
      Pedidos activos
    </h2>

    <div class="bg-slate-900/90 border border-slate-800 rounded-xl overflow-hidden shadow">

      <div class="overflow-x">

        <table class="w-full text-left min-w-max">

          <thead class="bg-slate-800">

            <tr>
              <th class="px-6 py-4 text-slate-300 font-medium">Cliente</th>
              <th class="px-6 py-4 text-slate-300 font-medium">Servicio</th>
              <th class="px-6 py-4 text-slate-300 font-medium">Estado</th>
              <th class="px-6 py-4 text-slate-300 font-medium">Fecha límite</th>
              <th class="px-6 py-4 text-slate-300 font-medium">Acción</th>
            </tr>

          </thead>

          <tbody class="divide-y divide-slate-800">

            {recentOrders.map(order => (

              <tr class="hover:bg-slate-800/60 transition">

                <td class="px-6 py-5">{order.client}</td>
                <td class="px-6 py-5">{order.service}</td>

                <td class="px-6 py-5">

                  <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium ${
                    order.status === 'En proceso'
                      ? 'bg-blue-900/60 text-blue-300'
                      : order.status === 'Pendiente'
                      ? 'bg-yellow-900/60 text-yellow-300'
                      : 'bg-purple-900/60 text-purple-300'
                  }`}>

                    {order.status}

                  </span>

                </td>

                <td class="px-6 py-5 text-slate-400">
                  {order.deadline}
                </td>

                <td class="px-6 py-5">

                  <a href="#" class="text-purple-400 hover:text-purple-300 transition font-medium">
                    {order.action}
                  </a>

                </td>

              </tr>

            ))}

          </tbody>

        </table>

      </div>

    </div>

  </section>


  <!-- Acciones rápidas -->
  <section class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12">

    <h2 class="text-2xl font-bold text-white mb-6">
      Acciones rápidas
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <a href="/dashboard/freelance/crearServicio"
        class="bg-purple-700 hover:bg-purple-600 text-white font-semibold py-6 px-8 rounded-xl text-center transition shadow-lg shadow-purple-900/30 flex items-center justify-center gap-3">

        Crear servicio

      </a>

      <a href="/dashboard/freelance/editarPerfil"
        class="bg-slate-800 hover:bg-slate-700 text-white font-semibold py-6 px-8 rounded-xl text-center transition flex items-center justify-center">

        Editar perfil

      </a>

      <a href="/dashboard/freelance/misServicios"
        class="bg-slate-800 hover:bg-slate-700 text-white font-semibold py-6 px-8 rounded-xl text-center transition flex items-center justify-center">

        Mis servicios

      </a>
      
      <a href="/dashboard/freelance/seguimiento"
        class="bg-slate-800 hover:bg-slate-700 text-white font-semibold py-6 px-8 rounded-xl text-center transition flex items-center justify-center">

        Seguimiento

      </a>

    </div>

  </section>

</div>

</DashboardLayout>
