---

import DashboardLayout from "../../../layouts/DashboardLayout.astro";

const orders = [
  {
    id: 1,
    client: "TechCorp",
    service: "Desarrollo API REST",
    price: 450000,
    status: "En progreso",
    date: "20 Mar 2026"
  },
  {
    id: 2,
    client: "StartUp Inc",
    service: "Diseño de Landing Page",
    price: 300000,
    status: "Pendiente",
    date: "18 Mar 2026"
  },
  {
    id: 3,
    client: "Agencia Pixel",
    service: "Soporte TI remoto",
    price: 150000,
    status: "Entregado",
    date: "15 Mar 2026"
  }
];
---

<DashboardLayout title="Pedidos Activos" userRole="freelance">

<div class="max-w-7xl mx-auto">

  <!-- Encabezado -->
  <div class="flex justify-between items-center mb-8">

    <h2 class="text-2xl font-bold text-white">
      Pedidos del Freelancer
    </h2>

    <a
      href="/dashboard/freelance"
      class="bg-slate-800 hover:bg-slate-700 px-5 py-2 rounded-lg text-sm transition"
    >
      Volver al Dashboard
    </a>

  </div>

  <!-- Tabla de pedidos -->
  <div class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden">

    <table class="w-full text-left">

      <thead class="bg-slate-800 text-slate-300 text-sm">

        <tr>
          <th class="px-6 py-4">Cliente</th>
          <th class="px-6 py-4">Servicio</th>
          <th class="px-6 py-4">Precio</th>
          <th class="px-6 py-4">Estado</th>
          <th class="px-6 py-4">Fecha</th>
          <th class="px-6 py-4">Acciones</th>
        </tr>

      </thead>

      <tbody class="divide-y divide-slate-800">

        {orders.map(order => (

          <tr class="hover:bg-slate-800/60 transition">

            <td class="px-6 py-4">{order.client}</td>

            <td class="px-6 py-4">{order.service}</td>

            <td class="px-6 py-4 text-purple-400 font-semibold">
              ${order.price}
            </td>

            <td class="px-6 py-4">

              <span class={`px-3 py-1 text-xs rounded-full font-medium
                ${
                  order.status === "Pendiente"
                    ? "bg-yellow-900/60 text-yellow-300"
                    : order.status === "En progreso"
                    ? "bg-blue-900/60 text-blue-300"
                    : "bg-green-900/60 text-green-300"
                }`}>

                {order.status}

              </span>

            </td>

            <td class="px-6 py-4 text-slate-400">
              {order.date}
            </td>

            <td class="px-6 py-4 flex gap-3">

              <a
                href={`/dashboard/freelance/pedido/${order.id}`}
                class="text-purple-400 hover:text-purple-300 text-sm"
              >
                Ver
              </a>

              <a
                href={`/dashboard/freelance/chat/${order.id}`}
                class="text-blue-400 hover:text-blue-300 text-sm"
              >
                Chat
              </a>

            </td>

          </tr>

        ))}

      </tbody>

    </table>

  </div>

</div>

</DashboardLayout>