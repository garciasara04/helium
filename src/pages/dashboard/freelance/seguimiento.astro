---
// src/pages/dashboard/freelance/seguimiento.astro
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Seguimiento del trabajo" userRole="freelance">

<div class="max-w-7xl mx-auto" id="contenedor-ordenes">
  <p class="text-slate-400 text-center py-10 text-lg">Cargando tus pedidos...</p>
</div>

<script>
  const contenedor = document.getElementById('contenedor-ordenes');

  // 1. FUNCIÓN PARA CARGAR LAS ÓRDENES (GET)
  async function cargarOrdenes() {
    const token = localStorage.getItem('token');
    
    if (!token) {
      window.location.href = '/login';
      return;
    }

    try {
      const respuesta = await fetch('http://127.0.0.1:8000/api/orders', {
        method: 'GET',
        headers: {
          'Accept': 'application/json',
          'Authorization': `Bearer ${token}`
        }
      });

      const datos = await respuesta.json();
      const ordenes = datos.data; // Recuerda que viene paginado

      contenedor.innerHTML = '';

      if (!ordenes || ordenes.length === 0) {
        contenedor.innerHTML = '<p class="text-slate-400 text-center py-10 bg-slate-900 border border-slate-800 rounded-2xl">No tienes pedidos actualmente.</p>';
        return;
      }

      ordenes.forEach(order => {
        const clienteNombre = order.user ? `${order.user.names} ${order.user.last_names}` : 'Cliente Desconocido';
        const servicioNombre = order.service ? order.service.title : 'Servicio borrado/inactivo';
        
        const tarjetaOrden = `
          <div class="flex flex-col lg:flex-row gap-8 mb-10 border-b border-slate-800 pb-10 last:border-0">
            
            <div class="flex-1 space-y-6">
              
              <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow">
                <h2 class="text-xl font-bold text-white mb-6">
                  Pedido #${order.id}
                </h2>

                <div class="grid grid-cols-2 md:grid-cols-3 gap-6 text-sm">
                  <div>
                    <p class="text-slate-400">Cliente</p>
                    <p class="font-semibold text-white">${clienteNombre}</p>
                  </div>
                  <div>
                    <p class="text-slate-400">Servicio</p>
                    <p class="font-semibold text-white line-clamp-1" title="${servicioNombre}">${servicioNombre}</p>
                  </div>
                  <div>
                    <p class="text-slate-400">Precio</p>
                    <p class="font-semibold text-purple-400">$${order.amount}</p>
                  </div>
                  <div>
                    <p class="text-slate-400">Inicio (Creado)</p>
                    <p class="font-semibold text-white">${new Date(order.created_at).toLocaleDateString()}</p>
                  </div>
                  <div>
                    <p class="text-slate-400">Requisitos</p>
                    <p class="font-semibold text-white truncate" title="${order.requirements || ''}">${order.requirements || 'Ninguno'}</p>
                  </div>
                  <div>
                    <p class="text-slate-400 mb-1">Estado</p>
                    <span class="px-3 py-1 bg-blue-900/60 text-blue-300 rounded-full text-xs font-medium uppercase tracking-wider">
                      ${order.status}
                    </span>
                  </div>
                </div>
              </div>

              <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow">
                <h2 class="text-xl font-bold text-white mb-8">Estado visual del trabajo</h2>
                <div class="space-y-6">
                  
                  <div class="flex items-center gap-4">
                    <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold ${['pending', 'in_progress', 'delivered', 'completed'].includes(order.status) ? 'bg-purple-600 text-white' : 'bg-slate-700 text-slate-400'}">1</div>
                    <div class="flex-1"><p class="font-medium ${['pending', 'in_progress', 'delivered', 'completed'].includes(order.status) ? 'text-white' : 'text-slate-400'}">Pedido recibido (Pending)</p></div>
                  </div>
                  
                  <div class="flex items-center gap-4">
                    <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold ${['in_progress', 'delivered', 'completed'].includes(order.status) ? 'bg-purple-600 text-white' : 'bg-slate-700 text-slate-400'}">2</div>
                    <div class="flex-1"><p class="font-medium ${['in_progress', 'delivered', 'completed'].includes(order.status) ? 'text-white' : 'text-slate-400'}">En progreso (In_progress)</p></div>
                  </div>
                  
                  <div class="flex items-center gap-4">
                    <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold ${['delivered', 'completed'].includes(order.status) ? 'bg-purple-600 text-white' : 'bg-slate-700 text-slate-400'}">3</div>
                    <div class="flex-1"><p class="font-medium ${['delivered', 'completed'].includes(order.status) ? 'text-white' : 'text-slate-400'}">Entregado (Delivered)</p></div>
                  </div>
                  
                  <div class="flex items-center gap-4">
                    <div class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold ${order.status === 'completed' ? 'bg-purple-600 text-white' : 'bg-slate-700 text-slate-400'}">4</div>
                    <div class="flex-1"><p class="font-medium ${order.status === 'completed' ? 'text-white' : 'text-slate-400'}">Completado (Completed)</p></div>
                  </div>
                  
                </div>
              </div>
            </div>

            <div class="w-full lg:w-72 shrink-0">
              <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow sticky top-24">
                <h3 class="text-lg font-bold text-white mb-4 text-center border-b border-slate-800 pb-3">
                  Actualizar Estado
                </h3>
                
                <div class="flex flex-col gap-3">
                  
                  ${order.status === 'pending' ? `
                    <button onclick="cambiarEstado(${order.id}, 'in_progress')" class="w-full py-2.5 px-4 bg-blue-500/10 text-blue-500 border border-blue-500/50 hover:bg-blue-500 hover:text-white rounded-lg font-medium transition-colors">
                      Pasar a En Progreso
                    </button>
                  ` : ''}
                  
                  ${order.status === 'in_progress' ? `
                    <button onclick="cambiarEstado(${order.id}, 'delivered')" class="w-full py-2.5 px-4 bg-purple-500/10 text-purple-400 border border-purple-500/50 hover:bg-purple-600 hover:text-white rounded-lg font-medium transition-colors">
                      Marcar Entregado
                    </button>
                  ` : ''}

                  ${!['cancelled', 'completed'].includes(order.status) ? `
                    <button onclick="cambiarEstado(${order.id}, 'cancelled')" class="w-full py-2.5 px-4 mt-4 bg-red-500/10 text-red-500 border border-red-500/50 hover:bg-red-500 hover:text-white rounded-lg font-medium transition-colors">
                      Cancelar Orden
                    </button>
                  ` : ''}

                  ${['cancelled', 'completed'].includes(order.status) ? `
                    <p class="text-center text-slate-500 text-sm py-2">No hay acciones disponibles para este estado.</p>
                  ` : ''}
                  
                  ${order.status === 'delivered' ? `
                    <p class="text-center text-slate-400 text-sm py-2 bg-slate-800 rounded mt-2 border border-slate-700">Esperando que el cliente marque como completado.</p>
                  ` : ''}
                  
                </div>
              </div>
            </div>
            
          </div>
        `;

        contenedor.innerHTML += tarjetaOrden;
      });

    } catch (error) {
      console.error("Error cargando órdenes:", error);
      contenedor.innerHTML = '<p class="text-red-500 text-center py-10">Hubo un problema al cargar los datos.</p>';
    }
  }

  // 2. FUNCIÓN PARA ACTUALIZAR EL ESTADO (PATCH)
  window.cambiarEstado = async function(orderId, nuevoEstado) {
    const token = localStorage.getItem('token');
    if (!token) return;

    const confirmacion = confirm(`¿Estás seguro de que deseas cambiar la orden a '${nuevoEstado}'?`);
    if (!confirmacion) return;

    try {
      const respuesta = await fetch(`http://127.0.0.1:8000/api/orders/${orderId}/status`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'Authorization': `Bearer ${token}`
        },
        body: JSON.stringify({
          status: nuevoEstado
        })
      });

      const datos = await respuesta.json();

      if (respuesta.ok) {
        // Volvemos a llamar cargarOrdenes() para que la vista se actualice sola
        cargarOrdenes(); 
      } else {
        console.error("Error devuelto por el servidor:", datos);
        alert(datos.error || 'Hubo un problema al actualizar el estado.');
      }

    } catch (error) {
      console.error("Error al realizar la petición PATCH:", error);
      alert('Hubo un error de conexión con el servidor.');
    }
  };

  // Inicializamos la vista
  cargarOrdenes();
</script>

</DashboardLayout>