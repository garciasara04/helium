---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Mis Servicios" userRole="freelance">

<div class="max-w-6xl mx-auto">

  <div class="flex justify-between items-center mb-8">
    <h2 class="text-xl font-semibold">Servicios publicados</h2>

    <a
      href="/dashboard/freelance/crearServicio"
      class="bg-purple-600 hover:bg-purple-700 px-5 py-2 rounded-lg text-sm font-medium"
    >
      + Crear servicio
    </a>
  </div>

  <div id="contenedor-mis-servicios" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
  </div>

</div>

<script>
  async function cargarServicios(){
    const token = localStorage.getItem('token');
    
    if(!token){
      window.location.href = '/login';
      return; // Importante poner el return para detener la ejecución
    }

    try {
      // Método GET y ruta correcta
      const response = await fetch('http://127.0.0.1:8000/api/personaServices', {
        method: 'GET',
        headers: {
          'Accept': 'application/json',
          'Authorization': `Bearer ${token}` // Tipeo corregido
        },
      });

      const data = await response.json();
      const servicios = data.services;
      
      const contenedor = document.getElementById('contenedor-mis-servicios');
      contenedor.innerHTML = ''; // Limpiamos el contenedor antes de inyectar

      if (!servicios || servicios.length === 0) {
        contenedor.innerHTML = '<p class="text-slate-400 col-span-full">Aún no tienes servicios publicados.</p>';
        return;
      }

      // Dibujamos las tarjetas respetando tu diseño
      servicios.forEach(service => {
        contenedor.innerHTML += `
          <div class="bg-slate-900 border border-slate-800 rounded-xl p-6">
            <h3 class="font-semibold text-lg mb-2">
              ${service.title}
            </h3>
            
            <p class="text-sm text-slate-400 mb-4">
              ${service.category}
            </p>

            <div class="flex justify-between text-sm text-slate-300 mb-4">
              <span>$${service.price}</span>
              <span class="${service.is_active ? 'text-green-400' : 'text-red-400'}">
                ${service.is_active ? 'Activo' : 'Inactivo'}
              </span>
            </div>

            <div class="flex gap-3">
              <a
                href="/dashboard/freelance/editarServicio?id=${service.id}"
                class="flex-1 text-center bg-slate-800 hover:bg-slate-700 py-2 rounded-lg text-sm"
              >
                Editar
              </a>

              <button
                onclick="deleteService(${service.id})"
                class="flex-1 bg-red-600 hover:bg-red-700 py-2 rounded-lg text-sm"
              >
                Eliminar
              </button>
            </div>
          </div>
        `;
      });
      
    } catch (error) {
      console.log(error);
      const contenedor = document.getElementById('contenedor-mis-servicios');
      contenedor.innerHTML = '<p class="text-red-500 col-span-full">Hubo un error al cargar tus servicios.</p>';
    }
  }

  cargarServicios();

  window.deleteService = async function(id){

    const token = localStorage.getItem('token')
    try{
      const response = await fetch(`http://127.0.0.1:8000/api/services/${id}`, {
      method: 'Delete',
      headers: {
        'Accept' : 'Application/json',
        'Authorization' : `Bearer ${token}`,
      }
    });
    const data = await response.json();
    if (data.ok) {
      cargarServicios();
    }
  }
  catch(error){
    console.log('error');
  }
  }
  
</script>

</DashboardLayout>