---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
---

<DashboardLayout userRole="freelance">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">Historial de ordenes por servicio</h1>
        <p class="text-slate-400 text-sm mt-1">Aqui solo veras ordenes finalizadas o canceladas.</p>
      </div>

      <a
        href="/dashboard/freelance/misServicios"
        class="inline-flex items-center justify-center px-4 py-2 rounded-lg bg-slate-800 border border-slate-700 text-slate-200 hover:bg-slate-700 transition"
      >
        Volver a Mis servicios
      </a>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-5 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
          <label for="historyService" class="block text-sm text-slate-300 mb-2">Servicio</label>
          <select id="historyService" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-100"></select>
        </div>

        <div>
          <label for="historyStatus" class="block text-sm text-slate-300 mb-2">Estado</label>
          <select id="historyStatus" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-100">
            <option value="all">Todas (Completadas y canceladas)</option>
            <option value="completed">Completadas</option>
            <option value="cancelled">Canceladas</option>
          </select>
        </div>

        <div>
          <label for="historySearch" class="block text-sm text-slate-300 mb-2">Buscar</label>
          <input id="historySearch" type="search" placeholder="Cliente, #orden o servicio" class="w-full bg-slate-800 border border-slate-700 rounded-lg px-3 py-2 text-slate-100" />
        </div>
      </div>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead class="bg-slate-800/50 border-b border-slate-800">
            <tr>
              <th class="px-5 py-3 text-xs uppercase tracking-wider text-slate-400">Orden</th>
              <th class="px-5 py-3 text-xs uppercase tracking-wider text-slate-400">Cliente</th>
              <th class="px-5 py-3 text-xs uppercase tracking-wider text-slate-400">Servicio</th>
              <th class="px-5 py-3 text-xs uppercase tracking-wider text-slate-400">Estado</th>
              <th class="px-5 py-3 text-xs uppercase tracking-wider text-slate-400">Monto</th>
              <th class="px-5 py-3 text-xs uppercase tracking-wider text-slate-400">Fecha</th>
            </tr>
          </thead>
          <tbody id="serviceHistoryBody" class="divide-y divide-slate-800/70">
            <tr>
              <td colspan="6" class="px-5 py-10 text-center text-slate-400">Cargando historial...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <script type="module" src="/src/js/freelance/service-history.js"></script>
</DashboardLayout>

