---
// src/components/layout/Navbar.astro
const { userName = "", userRole } = Astro.props;
const avatarLetter = userName.charAt(0).toUpperCase();
const dashboardBase = `/dashboard/${userRole}`;
---

<header class="bg-slate-900/80 backdrop-blur-md border-b border-slate-800/60 sticky top-0 z-50 w-full">
  <nav class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-3.5 flex items-center justify-between gap-6">
    <a href={dashboardBase} class="flex items-center">
      <img
        src="/logo.jpeg"
        alt="Helium Logo"
        class="h-9 w-auto object-contain hover:opacity-80 transition"
      />
    </a>

    <!-- Botones horizontales + Búsqueda (solo para cliente y company) -->
    <div class="hidden md:flex items-center gap-6 lg:gap-10 flex-1 justify-center">
      <div class="flex gap-3 lg:gap-5">
        {userRole === 'cliente' && (
          <>
            <a
              href="/dashboard/cliente"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Inicio
            </a>
            <a
              href="/dashboard/cliente/catalogo"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Catálogo
            </a>
            <a
              href="/dashboard/cliente/red"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Red
            </a>
          </>
        )}

        {userRole === 'freelance' && (
          <>
            <a
              href="/dashboard/freelance"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Inicio
            </a>
            <a
              href="/dashboard/freelance/pedidos"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Pedidos
            </a>
            <a
              href="/dashboard/freelance/misServicios"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Mis servicios
            </a>
            <a
              href="/dashboard/freelance/seguimiento"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Seguimiento
            </a>
          </>
        )}

        {userRole === 'company' && (
          <>
            <a
              href="/dashboard/company"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Inicio
            </a>
            <a
              href="/dashboard/company/ordenes"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
                Ordenes
            </a>
            <a
              href="/dashboard/company/marketplace"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Explorar Freelancers
            </a>
          </>
        )}

        {userRole === 'admin' && (
          <>
            <a href="/dashboard/admin" class="px-4 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">Inicio</a>
            <a href="/dashboard/admin/usuarios" class="px-4 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">Usuarios</a>
            <a href="/dashboard/admin/servicios" class="px-4 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">Servicios</a>
            <a href="/dashboard/admin/ordenes" class="px-4 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">Ordenes</a>
            <a href="/dashboard/admin/reviews" class="px-4 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">Reviews</a>
            <a href="/dashboard/admin/reputacion" class="px-4 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">Reputacion</a>
            <a href="/dashboard/admin/reportes" class="px-4 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30">Reportes</a>
          </>
        )}

      </div>

      <!-- Búsqueda - SOLO para cliente y company -->
      {(userRole === 'cliente' || userRole === 'company') && (
        <form action="/catalogo" method="get" class="relative max-w-md w-full">
          <input
            type="search"
            name="search"
            placeholder="Buscar servicios, freelanc..."
            class="w-full pl-10 pr-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition"
          />
          <svg
            class="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-slate-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
            />
          </svg>
        </form>
      )}
    </div>

    <!-- Avatar + Dropdown -->
    <div class="relative group">
      <button class="flex items-center gap-3 focus:outline-none">
                <div id="navbarAvatar" class="w-9 h-9 rounded-full bg-purple-700 flex items-center justify-center text-white font-bold border-2 border-purple-500/60 group-hover:border-purple-400 transition">
          {avatarLetter}
        </div>
                <span id="navbarUserName" class="font-medium text-slate-200 group-hover:text-purple-400 transition hidden sm:block">
          {userName}
        </span>
        <svg
          class="h-4 w-4 text-slate-400 group-hover:text-purple-400 transition"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <div class="absolute right-0 mt-3 w-64 bg-slate-900 border border-slate-700 rounded-xl shadow-2xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
        {userRole === 'cliente' && (
          <a
            href="/dashboard/cliente/perfil"
            class="block px-5 py-2.5 hover:bg-purple-900/30 hover:text-purple-300 transition"
          >
            Perfil
          </a>
        )}
        {userRole === 'freelance' && (
          <a
            href="/dashboard/freelance/miCuenta"
            class="block px-5 py-2.5 hover:bg-purple-900/30 hover:text-purple-300 transition"
          >
            Perfil
          </a>
        )}
        {userRole === 'company' && (
          <a
            href="/dashboard/company/perfil"
            class="block px-5 py-2.5 hover:bg-purple-900/30 hover:text-purple-300 transition"
          >
            Perfil
          </a>
        )}

        <hr class="my-2 border-slate-700" />
        <button
          id="btn-logout"
          class="block w-full text-left px-5 py-2.5 text-red-400 hover:bg-red-900/30 hover:text-red-300 transition"
          >     
          Cerrar sesión
</button>
        <a href="/cambiarContraseña"
          id="ChangePassword"
          class="block w-full text-left px-5 py-2.5 text-red-400 hover:bg-red-900/30 hover:text-red-300 transition"
               >
          Cambiar contraseña
          </a>
      </div>
    </div>
      <div class="relative group mt-1">
        <button class="relative p-2 text-slate-400 focus:outline-none">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          <span id="campanita-badge" class="absolute top-0 right-0 flex items-center justify-center w-4 h-4 text-[10px] text-white bg-red-500 rounded-full hidden">0</span>
        </button>

          <div id="notifications-dropdown" class="absolute right-0 top-full pt-2 w-80 bg-slate-900 border border-slate-700 rounded-lg shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible z-50 overflow-hidden flex flex-col">
    
    <div class="flex justify-between items-center px-4 py-3 bg-slate-800/80 border-b border-slate-700">
      <span class="text-sm font-bold text-white">Notificaciones</span>
      
      <button id="btn-read-all" class="text-xs font-semibold text-purple-400 hover:text-purple-300 transition flex items-center gap-1 focus:outline-none">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Todas leídas
      </button>
    </div>

    <div id="notifications-list" class="max-h-72 overflow-y-auto">
      
      <div class="flex justify-between items-start gap-3 p-4 border-b border-slate-800 hover:bg-slate-800/50 transition">
        
        <div class="text-sm text-slate-200">
          Tienes un nuevo pedido de diseño.
        </div>
        
        <button class="text-slate-500 hover:text-green-400 transition shrink-0 focus:outline-none" title="Marcar como leída">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </button>

      </div>
      </div>
  </div>
      </div>
  </nav>
<script>
  const API_BASE = "http://127.0.0.1:8000";

  const nameEl = document.getElementById("navbarUserName");
  const avatarEl = document.getElementById("navbarAvatar");

  function setUserName(name) {
    if (!name) return;
    if (nameEl) nameEl.textContent = name;
    if (avatarEl) avatarEl.textContent = name.charAt(0).toUpperCase();
  }

  async function loadProfileName() {
    const token = localStorage.getItem("token");
    if (!token) return;

    try {
      const res = await fetch(`${API_BASE}/api/profile`, {
        headers: {
          "Accept": "application/json",
          "Authorization": `Bearer ${token}`
        }
      });

      if (!res.ok) return;
      const profile = await res.json();

      const name =
        profile?.company?.name ||
        profile?.company_name ||
        [profile?.names, profile?.last_names].filter(Boolean).join(" ") ||
        profile?.name;

      setUserName(name);
      if (profile.photo && avatarEl) {
        avatarEl.innerHTML = `<img src="${API_BASE}/storage/${profile.photo}" class="w-full h-full object-cover rounded-full border-none" alt="Avatar" />`;
      }
    } catch (err) {
      console.error("No se pudo cargar el perfil", err);
    }
  }

  loadProfileName();
  
  const btnLogout = document.getElementById('btn-logout');
  
  if (btnLogout) {
    btnLogout.addEventListener('click', async () => {
      const token = localStorage.getItem('token');
      
      if (token) {
        try {
          await fetch('http://127.0.0.1:8000/api/logout', {
            method: 'POST', 
            headers: {
              'Accept': 'application/json',
              'Authorization': `Bearer ${token}`
            }
          });
        } catch (error) {
          console.error("Error al desconectar del servidor:", error);
        }
      }

      localStorage.removeItem('token');
      window.location.href = '/Login';
    });
  }
</script>
<script>
  async function notificationsRed(){
    try{
    const token = localStorage.getItem('token');
    if(!token){
      window.location.href = ('/Login');
    }
    const response = await fetch('http://127.0.0.1:8000/api/notifications',{
      method : 'GET',
      headers: {
        'Accept' : 'application/json',
        'Authorization' : `Bearer ${token}`,
      } 
    });
    const data = await response.json();
    const unreadCount = data.unread_count
    const badge = document.getElementById('campanita-badge');
    if (badge) {
        if (unreadCount > 0) {
          badge.textContent = unreadCount;
          badge.classList.remove('hidden'); 
        } else {
          badge.classList.add('hidden'); 
        }
      }
      const notifs_ = data.notifications.data;
      const notifs = notifs_.filter(n => n.read_at === null)
      const list = document.getElementById('notifications-list');
      list.innerHTML = '';  
      
      if (notifs.length === 0) {
        list.innerHTML = '<div class="p-3 text-sm text-slate-400">Sin notificaciones</div>';
        } else {

      notifs.forEach(n => {
       const mensaje = n.data.message || 'Notificación';
        list.innerHTML += `<div class="flex justify-between items-center p-3 border-b border-slate-800 text-sm text-white">
            <span>${mensaje}</span>
            <button onclick="selectOne('${n.id}')" class="text-slate-500 hover:text-green-400 transition focus:outline-none" title="Marcar leída">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </button>
          </div>`;
      });
    }
  }
  catch(error){
    console.log(error);
  }

  }
  window.selectOne = async function(id){
    const token = localStorage.getItem('token');

    try{
    const response = await fetch(`http://127.0.0.1:8000/api/notifications/${id}/read`,{
      method: 'PATCH',
      headers: {
        'Accept': 'application/json',
        'Authorization': `Bearer ${token}`, 
      }
    })
    const data = await response.json();
    console.log(data)
    notificationsRed()
    if (data) {
      console.log('enviado correctamente');
    }
    }
    catch(error){
      console.log(error);
    }
  }
  const readAll = document.getElementById('btn-read-all');
  readAll?.addEventListener('click', async (e) =>{
    e.preventDefault();
    try{
    const token = localStorage.getItem('token');
    const response = await fetch('http://127.0.0.1:8000/api/notifications/read-all',{
      method: 'PATCH',
      headers: {
        'Accept': 'application/json',
        'Authorization': `Bearer ${token}`
      }
    })
    notificationsRed();
  }
  catch(error){
    console.log(error);
  }
  })
  notificationsRed();

</script>


  
</header>







