---
// src/components/layout/Navbar.astro
const { userName = "user", userRole } = Astro.props;

const avatarLetter = userName.charAt(0).toUpperCase();
const dashboardBase = `/dashboard/${userRole}`;
---

<header class="bg-slate-900/80 backdrop-blur-md border-b border-slate-800/60 sticky top-0 z-50 w-full">
  <nav class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-3.5 flex items-center justify-between gap-6">
    <a href={dashboardBase} class="flex items-center">
      <img
        src="/logo.jpeg"
        alt="Helium Logo"
        class="h-9 w-auto object-contain hover:opacity-80 transition"
      />
    </a>

    <!-- Botones horizontales + Búsqueda (solo para cliente y company) -->
    <div class="hidden md:flex items-center gap-6 lg:gap-10 flex-1 justify-center">
      <div class="flex gap-3 lg:gap-5">
        {userRole === 'cliente' && (
          <>
            <a
              href="/dashboard/cliente"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Inicio
            </a>
            <a
              href="/dashboard/cliente/catalogo"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Catálogo
            </a>
            <a
              href="/dashboard/cliente/red"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Red
            </a>
          </>
        )}

        {userRole === 'freelance' && (
          <>
            <a
              href="/dashboard/freelance"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Inicio
            </a>
            <a
              href="/dashboard/freelance/pedidos"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Pedidos
            </a>
            <a
              href="/dashboard/freelance/misServicios"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Mis servicios
            </a>
            <a
              href="/dashboard/freelance/seguimiento"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Seguimiento
            </a>
          </>
        )}

        {userRole === 'company' && (
          <>
            <a
              href="/dashboard/company"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Inicio
            </a>
            <a
              href="/dashboard/company/ordenes"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
                Ordenes
            </a>
            <a
              href="/dashboard/company/marketplace"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Explorar Freelancers
            </a>
          </>
        )}

        {userRole === 'admin' && (
          <>
            <a
              href="/dashboard/admin"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Inicio
            </a>
            <a
              href="/dashboard/admin/usuarios"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Usuarios
            </a>
            <a
              href="/dashboard/admin/ordenes"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Ordenes
            </a>
            <a
              href="/dashboard/admin/reportes"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Reportes
            </a>
            <a
              href="/dashboard/admin/reputacion"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Reputacion
            </a>
            <a
              href="/dashboard/admin/servicios"
              class="px-5 py-2.5 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-lg transition shadow-sm shadow-purple-900/30"
            >
              Servicios
            </a>
          </>
        )}
      </div>

      <!-- Búsqueda - SOLO para cliente y company -->
      {(userRole === 'cliente' || userRole === 'company') && (
        <form action="/catalogo" method="get" class="relative max-w-md w-full">
          <input
            type="search"
            name="search"
            placeholder="Buscar servicios, freelanc..."
            class="w-full pl-10 pr-4 py-2.5 bg-slate-800 border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition"
          />
          <svg
            class="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 text-slate-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
            />
          </svg>
        </form>
      )}
    </div>

    <!-- Avatar + Dropdown -->
    <div class="relative group">
      <button class="flex items-center gap-3 focus:outline-none">
                <div id="navbarAvatar" class="w-9 h-9 rounded-full bg-purple-700 flex items-center justify-center text-white font-bold border-2 border-purple-500/60 group-hover:border-purple-400 transition">
          {avatarLetter}
        </div>
                <span id="navbarUserName" class="font-medium text-slate-200 group-hover:text-purple-400 transition hidden sm:block">
          {userName}
        </span>
        <svg
          class="h-4 w-4 text-slate-400 group-hover:text-purple-400 transition"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <div class="absolute right-0 mt-3 w-64 bg-slate-900 border border-slate-700 rounded-xl shadow-2xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
        {userRole === 'cliente' && (
          <a
            href="/dashboard/cliente/perfil"
            class="block px-5 py-2.5 hover:bg-purple-900/30 hover:text-purple-300 transition"
          >
            Perfil
          </a>
        )}
        {userRole === 'freelance' && (
          <a
            href="/dashboard/freelance/miCuenta"
            class="block px-5 py-2.5 hover:bg-purple-900/30 hover:text-purple-300 transition"
          >
            Perfil
          </a>
        )}
        {userRole === 'company' && (
          <a
            href="/dashboard/company/perfil"
            class="block px-5 py-2.5 hover:bg-purple-900/30 hover:text-purple-300 transition"
          >
            Perfil
          </a>
        )}
        {userRole === 'admin' && (
          <a
            href="/dashboard/admin/configuracion"
            class="block px-5 py-2.5 hover:bg-purple-900/30 hover:text-purple-300 transition"
          >
            Configuración
          </a>
        )}
        <hr class="my-2 border-slate-700" />
        <button
          id="btn-logout"
          class="block w-full text-left px-5 py-2.5 text-red-400 hover:bg-red-900/30 hover:text-red-300 transition"
          >     
          Cerrar sesión
</button>
      </div>
    </div>
  </nav>
<script>
  const API_BASE = "http://127.0.0.1:8000";

  const nameEl = document.getElementById("navbarUserName");
  const avatarEl = document.getElementById("navbarAvatar");

  function setUserName(name) {
    if (!name) return;
    if (nameEl) nameEl.textContent = name;
    if (avatarEl) avatarEl.textContent = name.charAt(0).toUpperCase();
  }

  async function loadProfileName() {
    const token = localStorage.getItem("token");
    if (!token) return;

    try {
      const res = await fetch(`${API_BASE}/api/profile`, {
        headers: {
          "Accept": "application/json",
          "Authorization": `Bearer ${token}`
        }
      });

      if (!res.ok) return;
      const profile = await res.json();

      const name =
        profile?.company?.name ||
        profile?.company_name ||
        [profile?.names, profile?.last_names].filter(Boolean).join(" ") ||
        profile?.name;

      setUserName(name);
      if (profile.photo && avatarEl) {
        avatarEl.innerHTML = `<img src="${API_BASE}/storage/${profile.photo}" class="w-full h-full object-cover rounded-full border-none" alt="Avatar" />`;
      }
    } catch (err) {
      console.error("No se pudo cargar el perfil", err);
    }
  }

  loadProfileName();
  
  const btnLogout = document.getElementById('btn-logout');
  
  if (btnLogout) {
    btnLogout.addEventListener('click', async () => {
      const token = localStorage.getItem('token');
      
      if (token) {
        try {
          await fetch('http://127.0.0.1:8000/api/logout', {
            method: 'POST', 
            headers: {
              'Accept': 'application/json',
              'Authorization': `Bearer ${token}`
            }
          });
        } catch (error) {
          console.error("Error al desconectar del servidor:", error);
        }
      }

      localStorage.removeItem('token');
      window.location.href = '/Login';
    });
  }
</script>
</header>


