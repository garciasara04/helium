---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section id={id} class="bg-slate-900 border border-purple-600 rounded-xl p-8">

  <!-- Título -->
  <h2 class="text-2xl font-bold mb-6 text-purple-500">
    {title}
  </h2>

  <!-- Contenido -->
  <div class="text-slate-300 leading-relaxed">
    <slot />
  </div>

</section>