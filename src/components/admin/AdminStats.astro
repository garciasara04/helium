---
const stats = [
  { label: "Usuarios", value: 1284 },
  { label: "Freelancers", value: 342 },
  { label: "Empresas", value: 82 },
  { label: "Servicios activos", value: 210 },
  { label: "Órdenes", value: 97 },
  { label: "Reviews", value: 560 }
];
---

<div class="grid md:grid-cols-3 lg:grid-cols-6 gap-6">
  {stats.map(stat => (
    <div class="bg-slate-800 border border-slate-700 rounded-xl p-6">
      <p class="text-slate-400 text-sm">
        {stat.label}
      </p>

      <p class="text-2xl font-bold text-white mt-2">
        {stat.value}
      </p>
    </div>
  ))}
</div>