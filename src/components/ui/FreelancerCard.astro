---
// src/components/ui/FreelancerCard.astro
// Props del freelancer
const { name, role, rating, reviews, price, imageUrl } = Astro.props;
---
<div class="bg-gray-900/70 border border-gray-800 rounded-2xl p-6 shadow-lg shadow-purple-900/20 hover:shadow-purple-700/30 transition-all">
  
  <!-- Imagen y nombre -->
  <div class="flex flex-col items-center text-center">
    <img 
      src={imageUrl || 'https://via.placeholder.com/300'} 
      alt={name} 
      class="w-32 h-32 rounded-full object-cover border-4 border-purple-600 shadow-xl mb-4"
    />
    <h3 class="text-xl font-bold text-white">{name}</h3>
    <p class="text-purple-400 text-sm">{role}</p>
  </div>

  <!-- Información adicional -->
  <div class="mt-4 space-y-2 text-center">
    <p class="text-yellow-400 font-semibold">
      ★ {rating} / 5
    </p>
    <p class="text-slate-400 text-sm">{reviews} reseñas</p>
    <p class="text-purple-300 font-medium mt-2">{price}</p>
  </div>

  <!-- Botón ver perfil -->
  <div class="mt-6 text-center">
    <a 
      href="#" 
      class="px-6 py-2 bg-purple-700 hover:bg-purple-600 text-white font-medium rounded-xl transition shadow-md shadow-purple-900/30"
    >
      Ver perfil
    </a>
  </div>

</div>